// =============================================================================
// SD-Pro-MTF :: Multi-Timeframe Supply & Demand + Trend + Fundamentals + VP
// =============================================================================
// Original implementation. Conceptually covers the GTF Indicator 2.0 Extended
// feature set (swing-pivot S/D zones, ATR-scaled sizing, sensitivity modes,
// EMA/SMA trend layer, multi-timeframe zone projection, multi-TF candle
// overlay, fundamentals table, golden/death cross, body-vs-wick zone basis,
// "boring candle" detection) PLUS several original enhancements:
//   - Break-of-Structure (BOS) zone invalidation (zones expire, not permanent)
//   - Retest/freshness tracking with a numeric strength score per zone
//     (freshness + base tightness vs ATR + volume confirmation at formation)
//   - PVSRA-style volume/spread candle classification (climax/rising vectors)
//   - Confluence dashboard table aggregating D/W/M zone state + trend + PVSRA
//   - Structured alertconditions for zone break, zone retest, golden/death cross
//   - Auto-pruned box/label budget management (oldest broken zones recycled)
//
// Volume Profile module (search "VOLUME PROFILE" below) is merged in from a
// third-party script, used and modified with attribution as required:
//   Original: "Volume Profile" by kv4coins
//   License:  Mozilla Public License 2.0 (https://mozilla.org/MPL/2.0/)
//   This merged file remains available under the same MPL 2.0 terms for the
//   Volume Profile portion; renamed variables/functions only (vp_ / f_vp
//   prefixes) to avoid collisions with the rest of this script -- no logic
//   was altered.
// =============================================================================

//@version=6
indicator("SD-Pro-MTF :: Supply & Demand + Trend + Fundamentals + VP", shorttitle="SD-Pro-MTF",
     overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// -----------------------------------------------------------------------
// INPUTS
// -----------------------------------------------------------------------
grpZone  = "Zone Detection"
sensitivityInput = input.string("Conservative", "Sensitivity", options=["Aggressive", "Dynamic", "Conservative"], group=grpZone)
swingLenOv  = input.int(0, "Swing Length Override (0 = auto)", minval=0, group=grpZone)
atrMultOv   = input.float(0.0, "ATR Multiplier Override (0 = auto)", step=0.05, group=grpZone)
atrLen      = input.int(14, "ATR Length", minval=1, group=grpZone)
zoneBasis   = input.string("Wick", "Zone Basis", options=["Wick", "Body"], group=grpZone)
maxZonesPerSide = input.int(6, "Max Live Zones / Side / Timeframe", minval=1, maxval=20, group=grpZone)

