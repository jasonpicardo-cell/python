//@version=6
// ═══════════════════════════════════════════════════════════
//  NIFTY SCALPER PRO  ·  Single combined script
//  EMA ribbon | VWAP | Bollinger Bands | Supertrend
//  Pivot Points + labels | Prev Day H/L | Buy + Sell Zones
//  Demand + Supply Zones | RSI / Volume info table
// ═══════════════════════════════════════════════════════════
indicator("Nifty Scalper Pro", overlay=true, max_bars_back=1000,
          max_boxes_count=50, max_lines_count=500, max_labels_count=200)

// ─── EMA & RIBBON ───────────────────────────────────────────
fast_len    = input.int(9,    "Fast EMA length",             minval=1,   maxval=50,  group="EMA & Ribbon")
fast_col    = input.color(#00E5FF, "Fast EMA color",                                 group="EMA & Ribbon")
fast_w      = input.int(2,    "Fast EMA width",              minval=1,   maxval=4,   group="EMA & Ribbon")
slow_len    = input.int(21,   "Slow EMA length",             minval=1,   maxval=200, group="EMA & Ribbon")
slow_col    = input.color(#FF9800, "Slow EMA color",                                 group="EMA & Ribbon")
slow_w      = input.int(2,    "Slow EMA width",              minval=1,   maxval=4,   group="EMA & Ribbon")
show_rib    = input.bool(false, "EMA ribbon fill",                                    group="EMA & Ribbon")

// ─── CROSSOVER LINE ─────────────────────────────────────────
show_cx     = input.bool(true,  "Show crossover line",                               group="Crossover Line")
cx_col      = input.color(#ECEFF1, "Color",                                          group="Crossover Line")
cx_style_in = input.string("Dashed", "Style", options=["Solid","Dashed","Dotted"],   group="Crossover Line")
cx_w        = input.int(2,    "Width",                       minval=1,   maxval=4,   group="Crossover Line")

// ─── VWAP ────────────────────────────────────────────────────
vwap_col    = input.color(#FFD600, "VWAP color",                                     group="VWAP")
vwap_w      = input.int(2,    "VWAP width",                  minval=1,   maxval=4,   group="VWAP")

// ─── BOLLINGER BANDS ────────────────────────────────────────
show_bb     = input.bool(false, "Show Bollinger Bands",                              group="Bollinger Bands")
bb_len      = input.int(20,   "BB length",                   minval=5,   maxval=50,  group="Bollinger Bands")
bb_mult     = input.float(2.0, "BB std dev",                 minval=0.5, maxval=4.0, group="Bollinger Bands")
bb_w        = input.int(1,    "BB line width",               minval=1,   maxval=4,   group="Bollinger Bands")

// ─── SUPERTREND ──────────────────────────────────────────────
show_st     = input.bool(false, "Show Supertrend",                                   group="Supertrend")
st_mult     = input.float(3.0, "Multiplier",                 minval=1.0, maxval=6.0, group="Supertrend")
st_period   = input.int(10,   "ATR period",                  minval=5,   maxval=30,  group="Supertrend")
st_w        = input.int(2,    "Supertrend width",            minval=1,   maxval=4,   group="Supertrend")

// ─── PIVOT POINTS ───────────────────────────────────────────
show_piv      = input.bool(true,  "Show pivot lines",                                group="Pivot Points")
piv_type      = input.string("Fibonacci", "Type", options=["Standard","Fibonacci","Camarilla"], group="Pivot Points")
piv_tf_auto   = input.bool(true,  "Auto timeframe (mirrors TradingView)",            group="Pivot Points")
piv_tf_manual = input.timeframe("D", "Manual timeframe override",                   group="Pivot Points")
piv_w         = input.int(2,    "Pivot line width",            minval=1,   maxval=4, group="Pivot Points")
show_plbl     = input.bool(true,  "Show labels on right",                            group="Pivot Points")
show_pval     = input.bool(true,  "Show values in labels",                           group="Pivot Points")
plbl_size     = input.string("Small", "Label size", options=["Tiny","Small","Normal"], group="Pivot Points")

// ─── PREV DAY LEVELS ────────────────────────────────────────
show_pdhl   = input.bool(true,  "Show prev day high / low",                          group="Prev Day Levels")
pdh_col     = input.color(#FF9800, "High line color",                                group="Prev Day Levels")
pdl_col     = input.color(#2196F3, "Low line color",                                 group="Prev Day Levels")
pdhl_w      = input.int(2,    "Line width",                  minval=1,   maxval=4,   group="Prev Day Levels")

// ─── ZONES ──────────────────────────────────────────────────
show_bsz    = input.bool(false, "Show buy / sell zones",                             group="Zones")
show_dsz    = input.bool(true,  "Show demand / supply zones",                        group="Zones")

// ─── SIGNALS ────────────────────────────────────────────────
show_sig    = input.bool(true,  "Show entry signals",                                group="Signals")
show_bg     = input.bool(false, "Trend background",                                  group="Signals")

// ─── INSTITUTIONAL CANDLES ──────────────────────────────────
show_inst      = input.bool(true,    "Highlight institutional candles",              group="Institutional Candles")
inst_bull_col  = input.color(#00E676, "Buy candle color",                            group="Institutional Candles")
inst_bear_col  = input.color(#FF1744, "Sell candle color",                           group="Institutional Candles")
inst_vol_mult  = input.float(2.0,   "Volume threshold (× avg vol)",  minval=1.1, maxval=10.0, step=0.1, group="Institutional Candles")
inst_body_mult = input.float(0.5,   "Min body size (× ATR)",         minval=0.1, maxval=3.0,  step=0.1, group="Institutional Candles")
inst_close_pct = input.float(0.6,   "Min close position (0 – 1)",    minval=0.3, maxval=0.9,  step=0.05, group="Institutional Candles")

// ─── INFO TABLE ─────────────────────────────────────────────
rsi_len     = input.int(14,   "RSI length",                  minval=2,   maxval=30,  group="Info Table")
ob          = input.int(70,   "Overbought",                  minval=55,  maxval=90,  group="Info Table")
os          = input.int(30,   "Oversold",                    minval=10,  maxval=45,  group="Info Table")
vol_ma      = input.int(20,   "Volume MA",                   minval=5,   maxval=100, group="Info Table")
show_tbl    = input.bool(true,  "Show info table",                                   group="Info Table")

// ─── SMART TREND LINES & CHANNELS ────────────────────────────
show_tl      = input.bool(true,  "Show smart trend lines",                        group="Smart Trend & Patterns")
show_channel = input.bool(false, "Show channel fill",                             group="Smart Trend & Patterns")
show_cpat    = input.bool(true,  "Show chart patterns (Double Top/Bottom, H&S, Triangles, Wedges, Flags)", group="Smart Trend & Patterns")
sm_piv_len   = input.int(10,     "Pivot sensitivity",    minval=3,  maxval=30,    group="Smart Trend & Patterns")
tl_res_col   = input.color(#EF5350, "Resistance line color",                      group="Smart Trend & Patterns")
tl_sup_col   = input.color(#26A69A, "Support line color",                         group="Smart Trend & Patterns")
tl_w         = input.int(2,      "Trend line width",     minval=1,  maxval=4,     group="Smart Trend & Patterns")

// ─── PRICE ACTION & AI MOMENTUM ─────────────────────────────
show_patterns  = input.bool(false, "Show candlestick pattern markers",              group="Price Action & AI")
show_false_brk = input.bool(false, "Show false breakout alerts",                   group="Price Action & AI")
show_strong    = input.bool(false, "Show strong momentum signals",                 group="Price Action & AI")
show_bar_score = input.bool(false, "Color bars by momentum score",                 group="Price Action & AI")
min_momentum   = input.int(6,      "Min score for strong signal (0–10)", minval=1, maxval=10, group="Price Action & AI")

// ─── AI TREND SUITE ──────────────────────────────────────────
show_kf      = input.bool(false, "Kalman Filter trend line",                group="AI Trend Suite")
kf_proc_n    = input.float(0.01, "Kalman process noise",   minval=0.001, maxval=0.1, step=0.001, group="AI Trend Suite")
show_kama    = input.bool(false, "KAMA efficiency adaptive MA",              group="AI Trend Suite")
kama_len     = input.int(10,     "KAMA length",             minval=5,  maxval=50,  group="AI Trend Suite")
show_reg     = input.bool(true,  "Regression channel (1σ / 2σ)",             group="AI Trend Suite")
reg_len      = input.int(50,     "Regression length",       minval=20, maxval=200, group="AI Trend Suite")
show_state   = input.bool(false, "Market State Classifier",                  group="AI Trend Suite")
adx_len      = input.int(14,     "ADX length",              minval=7,  maxval=30,  group="AI Trend Suite")
state_filter = input.bool(true,  "Filter L/S signals by state",              group="AI Trend Suite")
show_hurst   = input.bool(true,  "Hurst Exponent in table",                  group="AI Trend Suite")

// ─── AUTO-ADAPTIVE FIBONACCI ─────────────────────────────────
show_fib     = input.bool(false,  "Auto-Adaptive Fibonacci zones",            group="Auto-Fibonacci")
fib_piv_len  = input.int(20,     "Swing sensitivity",    minval=5, maxval=50, group="Auto-Fibonacci")
show_fib_ext = input.bool(false,  "Show extensions (127% / 161%)",            group="Auto-Fibonacci")
show_fib_lbl = input.bool(false,  "Show labels on right",                     group="Auto-Fibonacci")

// ─── MARKET STRUCTURE ENGINE ─────────────────────────────────
show_mse     = input.bool(true,  "Market Structure (BOS / CHoCH / HH·HL·LH·LL)", group="Market Structure")
show_mse_structs = input.bool(false, "Show HH/HL/LH/LL labels (default off — reduces clutter)", group="Market Structure")
mse_piv_len  = input.int(7,      "Structure sensitivity", minval=3, maxval=20,    group="Market Structure")

// ─── NEURAL CONFLUENCE SCORE ─────────────────────────────────
show_ncs     = input.bool(true,  "Neural Confluence Score (NCS 0–100)",      group="Neural Score")
ncs_high_t   = input.int(70,     "Strong bull threshold",  minval=55, maxval=90,  group="Neural Score")
ncs_low_t    = input.int(30,     "Strong bear threshold",  minval=10, maxval=45,  group="Neural Score")

// ─── LEADING INDICATORS ──────────────────────────────────────
show_lead      = input.bool(false,  "Show unified LEAD signal",                    group="Leading Indicators")
show_scd       = input.bool(false,  "Synthetic Cumulative Delta (SCD) divergence", group="Leading Indicators")
show_cmp       = input.bool(false,  "Compression Explosion predictor",             group="Leading Indicators")
show_spring    = input.bool(false,  "Spring & Upthrust with velocity",             group="Leading Indicators")
show_ire       = input.bool(false,  "Intraday Rhythm Engine (IRE)",                group="Leading Indicators")
show_absorb    = input.bool(false,  "Absorption Zone detector",                    group="Leading Indicators")
show_mva       = input.bool(false,  "Momentum Velocity + Acceleration (MVA)",      group="Leading Indicators")
show_phantom   = input.bool(false,  "Phantom Divergence (pre-divergence signal)",  group="Leading Indicators")
show_polarity  = input.bool(false,  "Candle Polarity Drift",                       group="Leading Indicators")
spring_vel     = input.float(0.7,  "Spring snap-back velocity",   minval=0.3, maxval=1.5, step=0.1, group="Leading Indicators")
ire_threshold  = input.float(2.0,  "IRE vol anomaly threshold (× avg vol)", minval=1.5, maxval=5.0, step=0.1, group="Leading Indicators")
min_lead_score = input.int(4,      "Min score for LEAD signal (0–14)", minval=1,  maxval=14,         group="Leading Indicators")

// ─── CORE CALCULATIONS ──────────────────────────────────────
ema_fast = ta.ema(close, fast_len)
ema_slow = ta.ema(close, slow_len)
vwap_val = ta.vwap
atr_val  = ta.atr(14)
rsi_val  = ta.rsi(close, rsi_len)
vol_sma  = ta.sma(volume, vol_ma)

[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)
[st_line, st_dir]            = ta.supertrend(st_mult, st_period)
st_bull                      = st_dir < 0

// ─── INSTITUTIONAL CANDLE DETECTION ─────────────────────────
// Criteria: volume spike + large body + close in strong position
candle_body  = math.abs(close - open)
candle_range = high - low + 0.001          // +0.001 avoids div-by-zero on doji
close_pos    = (close - low) / candle_range // 0 = at low, 1 = at high

inst_buy  = show_inst
          and volume        > inst_vol_mult  * vol_sma
          and candle_body   > inst_body_mult * atr_val
          and close         > open
          and close_pos     > inst_close_pct

inst_sell = show_inst
          and volume        > inst_vol_mult  * vol_sma
          and candle_body   > inst_body_mult * atr_val
          and close         < open
          and close_pos     < (1 - inst_close_pct)

// ─── CANDLESTICK PATTERN DETECTION ──────────────────────────
upper_wick  = high - math.max(close, open)
lower_wick  = math.min(close, open) - low

// Engulfing
bull_engulf = close > open and close[1] < open[1] and
              open < close[1] and close > open[1] and
              candle_body > atr_val * 0.4

bear_engulf = close < open and close[1] > open[1] and
              open > close[1] and close < open[1] and
              candle_body > atr_val * 0.4

// Hammer / Shooting Star
is_hammer   = lower_wick > candle_body * 2.0 and upper_wick < candle_body * 0.5 and
              candle_body > atr_val * 0.05   and lower_wick  > atr_val * 0.25

is_shooting = upper_wick > candle_body * 2.0 and lower_wick < candle_body * 0.5 and
              candle_body > atr_val * 0.05   and upper_wick  > atr_val * 0.25

// Pin Bars
bull_pin    = lower_wick > candle_range * 0.55 and upper_wick < candle_range * 0.2
bear_pin    = upper_wick > candle_range * 0.55 and lower_wick < candle_range * 0.2

// Doji & Inside Bar
is_doji     = candle_body < atr_val * 0.08 and candle_range > atr_val * 0.2
is_inside   = high < high[1] and low > low[1]

// Morning / Evening Star (3-candle reversals)
morning_star = close[2] < open[2] and
               math.abs(close[1] - open[1]) < atr_val * 0.25 and
               close > open and close > (open[2] + close[2]) / 2

evening_star = close[2] > open[2] and
               math.abs(close[1] - open[1]) < atr_val * 0.25 and
               close < open and close < (open[2] + close[2]) / 2

// Marubozu (near-zero wicks — pure momentum candle)
bull_marubozu = close > open and upper_wick < candle_body * 0.05 and lower_wick < candle_body * 0.05 and candle_body > atr_val * 0.75
bear_marubozu = close < open and upper_wick < candle_body * 0.05 and lower_wick < candle_body * 0.05 and candle_body > atr_val * 0.75

// map crossover style input → Pine Script line style constant
cx_style_val = cx_style_in == "Solid" ? line.style_solid :
               cx_style_in == "Dotted" ? line.style_dotted :
               line.style_dashed

// map pivot label size input → Pine Script size constant
plbl_sz = plbl_size == "Normal" ? size.normal :
          plbl_size == "Tiny"   ? size.tiny   :
          size.small

// ─── PIVOT TIMEFRAME (exact TradingView Pivot Points Standard mapping) ─
// Source: TradingView Help → Built-in Indicators → Pivot Points Standard
//   ≤ 15 min          →  1D   (Daily)
//   16 min – 4 h      →  1W   (Weekly)
//   1D                →  1M   (Monthly)
//   1W and above      →  12M  (Yearly)
_tf_secs = timeframe.in_seconds()
_auto_tf = _tf_secs <= 900      ? "D"   :   // ≤ 15 min  → Daily
           timeframe.isintraday  ? "W"   :   // 16 min–4h → Weekly
           timeframe.isdaily     ? "M"   :   // 1D        → Monthly
           "12M"                             // 1W, 1M+   → Yearly
piv_tf   = piv_tf_auto ? _auto_tf : piv_tf_manual

// Previous period OHLC — gaps_off fills session gaps (essential for NSE/Nifty)
pdh = request.security(syminfo.tickerid, piv_tf, high[1],  gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, piv_tf, low[1],   gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)
pdc = request.security(syminfo.tickerid, piv_tf, close[1], gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_on)

// ─── PIVOT CALCULATIONS ─────────────────────────────────────
rng    = pdh - pdl
// Standard
std_p  = (pdh + pdl + pdc) / 3
std_r1 = 2 * std_p - pdl
std_r2 = std_p + rng
std_r3 = pdh  + 2 * (std_p - pdl)
std_s1 = 2 * std_p - pdh
std_s2 = std_p - rng
std_s3 = pdl  - 2 * (pdh - std_p)
// Fibonacci
fib_p  = std_p
fib_r1 = fib_p + 0.382 * rng
fib_r2 = fib_p + 0.618 * rng
fib_r3 = fib_p + 1.000 * rng
fib_s1 = fib_p - 0.382 * rng
fib_s2 = fib_p - 0.618 * rng
fib_s3 = fib_p - 1.000 * rng
// Camarilla
cam_r1 = pdc + 1.1 * rng / 12
cam_r2 = pdc + 1.1 * rng / 6
cam_r3 = pdc + 1.1 * rng / 4
cam_s1 = pdc - 1.1 * rng / 12
cam_s2 = pdc - 1.1 * rng / 6
cam_s3 = pdc - 1.1 * rng / 4
// Select active set
isFib = piv_type == "Fibonacci"
isCam = piv_type == "Camarilla"
p_v   = isCam ? pdc    : std_p
r1_v  = isFib ? fib_r1 : isCam ? cam_r1 : std_r1
r2_v  = isFib ? fib_r2 : isCam ? cam_r2 : std_r2
r3_v  = isFib ? fib_r3 : isCam ? cam_r3 : std_r3
s1_v  = isFib ? fib_s1 : isCam ? cam_s1 : std_s1
s2_v  = isFib ? fib_s2 : isCam ? cam_s2 : std_s2
s3_v  = isFib ? fib_s3 : isCam ? cam_s3 : std_s3

// ─── FALSE BREAKOUT DETECTION ────────────────────────────────
// Wick rejection: price pierced a key level but closed back through it

// Resistance rejections (upper wick through level, close below = bear trap)
rej_r1   = show_piv  and high > r1_v     and close < r1_v
rej_pdh  = show_pdhl and high > pdh      and close < pdh
rej_bbu  = show_bb   and high > bb_upper and close < bb_upper
rej_st_r = show_st   and not st_bull and high > st_line and close < st_line

fake_break_up = (rej_r1 or rej_pdh or rej_bbu or rej_st_r) and upper_wick > candle_body

// Support rejections (lower wick through level, close above = bull trap / bounce)
rej_s1   = show_piv  and low < s1_v      and close > s1_v
rej_pdl  = show_pdhl and low < pdl       and close > pdl
rej_bbl  = show_bb   and low < bb_lower  and close > bb_lower
rej_st_s = show_st   and st_bull and low < st_line and close > st_line

fake_break_dn = (rej_s1 or rej_pdl or rej_bbl or rej_st_s) and lower_wick > candle_body

// ─── MOMENTUM INTELLIGENCE SCORE (0 – 10) ───────────────────
// Composite multi-factor score — mirrors how an AI would weigh each signal

ms_bull =
  (close > vwap_val                                     ? 1 : 0) +
  (ema_fast > ema_slow                                  ? 1 : 0) +
  (st_bull                                              ? 1 : 0) +
  (rsi_val > 55 and rsi_val < ob                        ? 1 : 0) +
  (volume > vol_sma * 1.5                               ? 2 : volume > vol_sma ? 1 : 0) +
  (bull_engulf or morning_star or bull_marubozu         ? 2 : is_hammer or bull_pin ? 1 : 0) +
  (close > p_v                                          ? 1 : 0) +
  (not fake_break_up                                    ? 1 : 0)

ms_bear =
  (close < vwap_val                                     ? 1 : 0) +
  (ema_fast < ema_slow                                  ? 1 : 0) +
  (not st_bull                                          ? 1 : 0) +
  (rsi_val < 45 and rsi_val > os                        ? 1 : 0) +
  (volume > vol_sma * 1.5                               ? 2 : volume > vol_sma ? 1 : 0) +
  (bear_engulf or evening_star or bear_marubozu         ? 2 : is_shooting or bear_pin ? 1 : 0) +
  (close < p_v                                          ? 1 : 0) +
  (not fake_break_dn                                    ? 1 : 0)

// ─── DEMAND / SUPPLY ZONE TRACKING ──────────────────────────
ph_bar = ta.pivothigh(high, 5, 5)
pl_bar = ta.pivotlow(low,   5, 5)

var float sup_top = na
var float sup_bot = na
var float dem_top = na
var float dem_bot = na

if not na(ph_bar)
    sup_top := ph_bar + atr_val * 0.15
    sup_bot := ph_bar - atr_val * 0.30
if not na(pl_bar)
    dem_top := pl_bar + atr_val * 0.30
    dem_bot := pl_bar - atr_val * 0.15

// ─── SMART TREND LINE PIVOT TRACKING ────────────────────────
// Track 3 most recent pivot highs and lows for trendlines + patterns
sm_ph = ta.pivothigh(high, sm_piv_len, sm_piv_len)
sm_pl = ta.pivotlow(low,   sm_piv_len, sm_piv_len)

var float ph1 = na
var int   phb1 = na
var float ph2 = na
var int   phb2 = na
var float ph3 = na
var int   phb3 = na
var float ph4 = na
var int   phb4 = na
var float ph5 = na
var int   phb5 = na
var float pl1 = na
var int   plb1 = na
var float pl2 = na
var int   plb2 = na
var float pl3 = na
var int   plb3 = na
var float pl4 = na
var int   plb4 = na
var float pl5 = na
var int   plb5 = na

if not na(sm_ph)
    ph5  := ph4
    phb5 := phb4
    ph4  := ph3
    phb4 := phb3
    ph3  := ph2
    phb3 := phb2
    ph2  := ph1
    phb2 := phb1
    ph1  := sm_ph
    phb1 := bar_index[sm_piv_len]

if not na(sm_pl)
    pl5  := pl4
    plb5 := plb4
    pl4  := pl3
    plb4 := plb3
    pl3  := pl2
    plb3 := plb2
    pl2  := pl1
    plb2 := plb1
    pl1  := sm_pl
    plb1 := bar_index[sm_piv_len]

// ─── CHART PATTERN ENGINE (breakout-confirmed, two-stage) ────
// Stage 1 — FORMATION: slope geometry tells us what pattern is forming.
// Stage 2 — CONFIRMATION: signal fires only when price actually breaks
//           through the projected trendline, with a 0.15 ATR buffer.
// This matches the behaviour of LuxAlgo / TV AI: no signal during formation,
// one clean signal on the confirmed breakout bar.

_has_res = not na(ph1) and not na(ph2) and phb1 > phb2
_has_sup = not na(pl1) and not na(pl2) and plb1 > plb2

_res_sl  = _has_res ? (ph1 - ph2) / (phb1 - phb2) : na
_sup_sl  = _has_sup ? (pl1 - pl2) / (plb1 - plb2) : na
_rn      = not na(_res_sl) ? _res_sl / math.max(atr_val, 0.001) : na
_sn      = not na(_sup_sl) ? _sup_sl / math.max(atr_val, 0.001) : na
_ok      = _has_res and _has_sup and not na(_rn) and not na(_sn)
_FL      = 0.025

// Minimum pattern height — ignores sub-noise formations
_pat_h   = _ok ? ((ph1 + ph2) * 0.5 - (pl1 + pl2) * 0.5) : na
_min_h   = atr_val * 1.5

// ── STAGE 1: FORMATION — 3-touch · apex · duration · volume ──
// Three-touch requirement: price must have tagged each boundary at
// 3 separate pivot points before the pattern is considered formed.
// This is the core technique used in LuxAlgo and eliminates ~80 %
// of the phantom patterns the 2-point slope approach generates.

// Pattern maturity: must span at least 2 full pivot cycles
_pat_start = _ok ? math.min(nz(phb2, bar_index), nz(plb2, bar_index)) : bar_index
_dur_ok    = (bar_index - _pat_start) >= sm_piv_len * 2

// Apex of converging patterns: bar where resistance and support meet
// (solve for x in: ph1 + res_sl*(x-phb1) = pl1 + sup_sl*(x-plb1))
_apex_x    = not na(_res_sl) and not na(_sup_sl) and math.abs(_res_sl - _sup_sl) > 0.00001 ? (nz(pl1) - nz(ph1) + _res_sl * nz(phb1) - _sup_sl * nz(plb1)) / (_res_sl - _sup_sl) : na
_apex_ok   = not na(_apex_x) and _apex_x > bar_index and _apex_x < bar_index + sm_piv_len * 20

// Volume contraction: volume should be shrinking inside a healthy pattern
_vol_c     = ta.sma(volume, 5) < ta.sma(volume, 20) * 0.9

// Three-point availability
_has3ph    = not na(ph3) and not na(phb3)
_has3pl    = not na(pl3) and not na(plb3)

// ── TRIANGLES — 3-touch, size, apex ─────────────────────────
// Ascending : 3 near-equal highs  +  3 consecutively rising lows
_at_hflat  = _has3ph and math.abs(ph1 - ph2) < atr_val * 0.5 and math.abs(ph2 - ph3) < atr_val * 0.7
_at_lrise  = _has3pl and pl1 > pl2 and pl2 > pl3
_f_asc_t   = _at_hflat and _at_lrise and not na(_pat_h) and _pat_h > _min_h and _dur_ok and _apex_ok

// Descending: 3 consecutively falling highs  +  3 near-equal lows
_dt_hfall  = _has3ph and ph1 < ph2 and ph2 < ph3
_dt_lflat  = _has3pl and math.abs(pl1 - pl2) < atr_val * 0.5 and math.abs(pl2 - pl3) < atr_val * 0.7
_f_dsc_t   = _dt_hfall and _dt_lflat and not na(_pat_h) and _pat_h > _min_h and _dur_ok and _apex_ok

// Symmetrical: 3 lower highs  +  3 higher lows  (both sides converging)
_st_hfall  = _has3ph and ph1 < ph2 and ph2 < ph3
_st_lrise  = _has3pl and pl1 > pl2 and pl2 > pl3
_f_sym_t   = _st_hfall and _st_lrise and not na(_pat_h) and _pat_h > _min_h and _dur_ok and _apex_ok

// ── WEDGES — 3 touches + slope convergence + apex ────────────
// Rising Wedge : 3 higher highs + 3 higher lows, support slope steeper
_rw_3ph    = _has3ph and ph1 > ph2 and ph2 > ph3
_rw_3pl    = _has3pl and pl1 > pl2 and pl2 > pl3
_f_r_wdg   = _rw_3ph and _rw_3pl and _ok and _rn > _FL and _sn > _rn and not na(_pat_h) and _pat_h > _min_h and _dur_ok and _apex_ok

// Falling Wedge: 3 lower highs + 3 lower lows, resistance slope steeper
_fw_3ph    = _has3ph and ph1 < ph2 and ph2 < ph3
_fw_3pl    = _has3pl and pl1 < pl2 and pl2 < pl3
_f_f_wdg   = _fw_3ph and _fw_3pl and _ok and _rn < -_FL and _sn > _rn and not na(_pat_h) and _pat_h > _min_h and _dur_ok and _apex_ok

// ── BROADENING — 3 touches + diverging slopes ────────────────
// Ascending Broadening: 3 higher highs + 3 higher lows, top diverging faster
_ab_3ph    = _has3ph and ph1 > ph2 and ph2 > ph3
_ab_3pl    = _has3pl and pl1 > pl2 and pl2 > pl3
_f_asc_b   = _ab_3ph and _ab_3pl and _ok and _rn > _FL and _sn > _FL and _rn > _sn and not na(_pat_h) and _pat_h > _min_h and _dur_ok

// Descending Broadening: 3 lower highs + 3 lower lows, bottom diverging faster
_db_3ph    = _has3ph and ph1 < ph2 and ph2 < ph3
_db_3pl    = _has3pl and pl1 < pl2 and pl2 < pl3
_f_dsc_b   = _db_3ph and _db_3pl and _ok and _rn < -_FL and _sn < -_FL and _sn < _rn and not na(_pat_h) and _pat_h > _min_h and _dur_ok

// ── STAGE 2: PROJECT TRENDLINE TO CURRENT BAR ────────────────
// Avoids comparing today's close to a pivot that is bars old.
// _res_now / _sup_now = where the line is RIGHT NOW (not at the pivot).
_res_now = _has_res and not na(_res_sl) ? ph1 + _res_sl * (bar_index - phb1) : na
_sup_now = _has_sup and not na(_sup_sl) ? pl1 + _sup_sl * (bar_index - plb1) : na
_buf     = atr_val * 0.15   // 0.15 ATR buffer absorbs wicks / near-misses

_b_asc_t = _f_asc_t and not na(_res_now) and close > _res_now + _buf
_b_dsc_t = _f_dsc_t and not na(_sup_now) and close < _sup_now - _buf
_b_sym_t = _f_sym_t and (close > nz(_res_now, ph1) + _buf or close < nz(_sup_now, pl1) - _buf)
_b_r_wdg = _f_r_wdg and not na(_sup_now) and close < _sup_now - _buf
_b_f_wdg = _f_f_wdg and not na(_res_now) and close > _res_now + _buf
_b_asc_b = _f_asc_b and not na(_res_now) and close > _res_now + _buf
_b_dsc_b = _f_dsc_b and not na(_sup_now) and close < _sup_now - _buf

// ── HEAD & SHOULDERS — timing-symmetric 5-point check ────────
_has_3ph = not na(ph1) and not na(ph2) and not na(ph3) and not na(phb1) and not na(phb2) and not na(phb3)
_has_3pl = not na(pl1) and not na(pl2) and not na(pl3)

// Timing symmetry: right arm within 70 % of left arm (removes skewed shapes)
_hs_sym  = _has_3ph and math.abs((phb1 - phb2) - (phb2 - phb3)) < (phb2 - phb3) * 0.7
_f_hs    = _has_3ph and ph2 > ph1 and ph2 > ph3 and math.abs(ph1 - ph3) < atr_val * 1.5 and _hs_sym and _has_sup
_f_ihs   = _has_3pl  and pl2 < pl1 and pl2 < pl3 and math.abs(pl1 - pl3) < atr_val * 1.5 and _has_res

hs_neck_v  = _f_hs  ? (nz(pl1) + nz(pl2)) * 0.5 : na
ihs_neck_v = _f_ihs ? (nz(ph1) + nz(ph2)) * 0.5 : na

_b_hs    = _f_hs  and not na(hs_neck_v)  and close < hs_neck_v  - _buf
_b_ihs   = _f_ihs and not na(ihs_neck_v) and close > ihs_neck_v + _buf

// ── DOUBLE FORMATIONS — neckline-confirmed ───────────────────
_sep     = sm_piv_len * 4
_tol_dbl = atr_val * 0.8

// Double Top neckline = pl1 (trough between the two peaks)
// Double Bottom neckline = ph1 (peak between the two troughs)
_f_dbl_t  = _has_res and _has_sup and math.abs(ph1 - ph2) < _tol_dbl and (phb1 - phb2) > _sep and pl1 < (ph1 + ph2) * 0.5 - atr_val
_f_dbl_b  = _has_sup  and _has_res and math.abs(pl1 - pl2) < _tol_dbl and (plb1 - plb2) > _sep and ph1 > (pl1 + pl2) * 0.5 + atr_val

_b_dbl_t  = _f_dbl_t and close < pl1 - _buf
_b_dbl_b  = _f_dbl_b and close > ph1 + _buf

dbl_top_neck = _f_dbl_t ? pl1  : na
dbl_bot_neck = _f_dbl_b ? ph1  : na

// ── SIGNAL FIRES (first bar of confirmed breakout only) ───────
asc_tri_sig = show_cpat and _b_asc_t and not _b_asc_t[1]
dsc_tri_sig = show_cpat and _b_dsc_t and not _b_dsc_t[1]
sym_tri_sig = show_cpat and _b_sym_t and not _b_sym_t[1]
r_wdg_sig   = show_cpat and _b_r_wdg and not _b_r_wdg[1]
f_wdg_sig   = show_cpat and _b_f_wdg and not _b_f_wdg[1]
asc_brd_sig = show_cpat and _b_asc_b and not _b_asc_b[1]
dsc_brd_sig = show_cpat and _b_dsc_b and not _b_dsc_b[1]
hs_sig      = show_cpat and _b_hs    and not _b_hs[1]
ihs_sig     = show_cpat and _b_ihs   and not _b_ihs[1]
dbl_top_sig = show_cpat and _b_dbl_t and not _b_dbl_t[1]
dbl_bot_sig = show_cpat and _b_dbl_b and not _b_dbl_b[1]

// Channel direction label for info table
_thr    = close * 0.00004
_rd     = not na(_rn) ? (_rn > _thr ? 1 : _rn < -_thr ? -1 : 0) : na
_sd     = not na(_sn) ? (_sn > _thr ? 1 : _sn < -_thr ? -1 : 0) : na
ch_type = not na(_rd) and not na(_sd) ? (_rd == _sd ? (_rd == 1 ? "↗ Ascending" : _rd == -1 ? "↘ Descending" : "→ Horizontal") : "Wedge / Triangle") : "—"



// ─── TREND & SIGNAL CONDITIONS ──────────────────────────────
bull         = ema_fast > ema_slow and close > vwap_val
bear         = ema_fast < ema_slow and close < vwap_val
prox         = atr_val * 0.5
ema_cross_up = ta.crossover(ema_fast, ema_slow)
ema_cross_dn = ta.crossunder(ema_fast, ema_slow)

long_sig  = ema_cross_up and close > vwap_val and rsi_val < ob and volume > vol_sma
short_sig = ema_cross_dn and close < vwap_val and rsi_val > os and volume > vol_sma

// Strong signals: crossover confirmed by momentum score + no fake breakout
strong_long  = long_sig  and ms_bull >= min_momentum and not fake_break_up
strong_short = short_sig and ms_bear >= min_momentum and not fake_break_dn

// ═══════════════════════════════════════════════════════════
//  LEADING INDICATOR ENGINE
// ═══════════════════════════════════════════════════════════

// ── 1. SYNTHETIC CUMULATIVE DELTA (SCD) ─────────────────────
// Approximates institutional order flow from candle structure.
// When price is at a pivot but SCD is flowing opposite → reversal forming 3–5 bars early.
_scd_rng     = high - low + 0.001
buy_pres     = (close - low)  / _scd_rng * volume
sell_pres    = (high - close) / _scd_rng * volume
bar_delta    = buy_pres - sell_pres
cum_delta    = ta.cum(bar_delta)
scd_slope    = cum_delta - cum_delta[5]   // 5-bar delta momentum

near_ph = not na(ph1) and close >= ph1 - atr_val       and close <= ph1 + atr_val * 0.5
near_pl = not na(pl1) and close <= pl1 + atr_val       and close >= pl1 - atr_val * 0.5

scd_bear_div = show_scd and near_ph and scd_slope < 0 and bar_delta < 0
scd_bull_div = show_scd and near_pl and scd_slope > 0 and bar_delta > 0
scd_bear_sig = scd_bear_div and not scd_bear_div[1]
scd_bull_sig = scd_bull_div and not scd_bull_div[1]

// ── 2. COMPRESSION EXPLOSION PREDICTOR ──────────────────────
// 4 consecutive bars of shrinking range = coiled spring. Signal fires on
// the LAST compression bar so you pre-position before the explosion candle.
_cr0 = high - low
_cr1 = high[1] - low[1]
_cr2 = high[2] - low[2]
_cr3 = high[3] - low[3]
cmp_cond = _cr0 < _cr1 and _cr1 < _cr2 and _cr2 < _cr3 and math.max(_cr0, _cr1, _cr2, _cr3) < atr_val * 0.8

polarity_v   = (close - low) / (high - low + 0.001)  // 0 = full bear, 1 = full bull
polarity_sma = ta.sma(polarity_v, 5)                  // rolling control score

cmp_bull_sig = show_cmp and cmp_cond and not cmp_cond[1] and bull and polarity_sma > 0.5
cmp_bear_sig = show_cmp and cmp_cond and not cmp_cond[1] and bear and polarity_sma < 0.5

// ── 3. SPRING & UPTHRUST WITH VELOCITY ──────────────────────
// Wyckoff's most precise entry. Pierces a key level (stops everyone out),
// then snaps back with high velocity = institutional absorption complete.
_at_s1     = low < s1_v    and close > s1_v
_at_pdl    = low < pdl     and close > pdl
_at_vwaps  = low < vwap_val and close > vwap_val and close_pos > 0.70

spring_sig = show_spring and (_at_s1 or _at_pdl or _at_vwaps) and close_pos > 0.65 and (close - low) / atr_val > spring_vel and volume > vol_sma

_at_r1     = high > r1_v   and close < r1_v
_at_pdh    = high > pdh    and close < pdh
_at_vwapr  = high > vwap_val and close < vwap_val and close_pos < 0.30

upthrust_sig = show_spring and (_at_r1 or _at_pdh or _at_vwapr) and close_pos < 0.35 and (high - close) / atr_val > spring_vel and volume > vol_sma

// ── 4. INTRADAY RHYTHM ENGINE — NSE 9:15–15:30 IST ──────────
// NSE has a clockwork volume rhythm. An unexpected spike during the
// normally quiet mid-session = institutional activity. Follow the flow.
_hr  = hour(time, "Asia/Kolkata")
_min = minute(time, "Asia/Kolkata")
_sm  = _hr * 60 + _min
_nse_open = _sm >= 9 * 60 + 15 and _sm <= 15 * 60 + 30   // within NSE session
_opening  = _sm >= 9 * 60 + 15 and _sm <  9 * 60 + 45    // opening burst – exclude
_closing  = _sm >= 14 * 60 + 30                            // closing rush – exclude
_ire_win  = _nse_open and not _opening and not _closing

ire_bull = show_ire and _ire_win and volume > vol_sma * ire_threshold and close > open and close > vwap_val
ire_bear = show_ire and _ire_win and volume > vol_sma * ire_threshold and close < open and close < vwap_val

// ── 5. ABSORPTION ZONE DETECTOR ─────────────────────────────
// High volume + tiny body + decent range = institutions absorbing all supply/demand.
// Price barely moves despite massive effort → coil before the breakout.
_effort     = volume / vol_sma
_result     = candle_body / atr_val
_absorb_raw = _effort > 1.5 and _result < 0.25 and candle_range > atr_val * 0.5

_near_sup   = math.abs(close - s1_v) < atr_val * 0.5 or math.abs(close - pdl) < atr_val * 0.5 or (math.abs(close - vwap_val) < atr_val * 0.3 and close >= vwap_val)
_near_res   = math.abs(close - r1_v) < atr_val * 0.5 or math.abs(close - pdh) < atr_val * 0.5 or (math.abs(close - vwap_val) < atr_val * 0.3 and close <= vwap_val)

bull_absorb = show_absorb and _absorb_raw and _near_sup
bear_absorb = show_absorb and _absorb_raw and _near_res

// ── 6. MOMENTUM VELOCITY + ACCELERATION (MVA) ───────────────
// 2nd derivative of price. Deceleration at a trend extreme is mathematically
// inevitable before reversal — detects it 2–4 candles before RSI divergence forms.
velocity    = ta.roc(close, 3)
accel       = velocity - velocity[1]

mva_bull_sig = show_mva and close < close[3] and accel > 0 and accel > accel[1] and accel > accel[2]
mva_bear_sig = show_mva and close > close[3] and accel < 0 and accel < accel[1] and accel < accel[2]

// ── 7. PHANTOM DIVERGENCE ────────────────────────────────────
// Stores the RSI value at each confirmed pivot. When current RSI has already
// dropped below that stored level — before price even tests the pivot again —
// divergence is forming invisibly. 3–5 candles earlier than classical divergence.
var float rsi_at_ph = na
var float rsi_at_pl = na

if not na(sm_ph)
    rsi_at_ph := rsi_val[sm_piv_len]
if not na(sm_pl)
    rsi_at_pl := rsi_val[sm_piv_len]

phantom_bear = show_phantom and not na(rsi_at_ph) and not na(ph1) and rsi_val < rsi_at_ph * 0.94 and close < ph1 + atr_val * 0.5 and rsi_val > 45
phantom_bull = show_phantom and not na(rsi_at_pl) and not na(pl1) and rsi_val > rsi_at_pl * 1.06 and close > pl1 - atr_val * 0.5 and rsi_val < 55

phantom_bear_sig = phantom_bear and not phantom_bear[1]
phantom_bull_sig = phantom_bull and not phantom_bull[1]

// ── 8. CANDLE POLARITY DRIFT ─────────────────────────────────
// Rolling close-position average (polarity_sma) crosses 0.5 while price
// is range-bound at a key level = control shifting from sellers to buyers (or vice
// versa) before it shows up in price.
polarity_bull_drift = show_polarity and ta.crossover(polarity_sma, 0.5) and math.abs(close - close[5]) < atr_val * 0.8
polarity_bear_drift = show_polarity and ta.crossunder(polarity_sma, 0.5) and math.abs(close - close[5]) < atr_val * 0.8

// ── UNIFIED LEADING SCORE (0–14) ─────────────────────────────
// 8 independent signal sources across 4 lead-time windows:
// SCD=3–5 bars early · Phantom=3–5 · Compression=1 bar · MVA=2–4 bars · Polarity=1–3 · Absorption=2–4 · IRE=concurrent · Spring/UT=same bar
leading_bull = (scd_bull_div ? 2 : 0) + (cmp_cond and bull and polarity_sma > 0.5 ? 2 : 0) + (spring_sig ? 3 : 0) + (ire_bull ? 1 : 0) + (bull_absorb ? 2 : 0) + (mva_bull_sig ? 1 : 0) + (phantom_bull ? 2 : 0) + (polarity_bull_drift ? 1 : 0)
leading_bear = (scd_bear_div ? 2 : 0) + (cmp_cond and bear and polarity_sma < 0.5 ? 2 : 0) + (upthrust_sig ? 3 : 0) + (ire_bear ? 1 : 0) + (bear_absorb ? 2 : 0) + (mva_bear_sig ? 1 : 0) + (phantom_bear ? 2 : 0) + (polarity_bear_drift ? 1 : 0)

unified_bull_on  = show_lead and leading_bull >= min_lead_score
unified_bear_on  = show_lead and leading_bear >= min_lead_score
unified_bull_sig = unified_bull_on and not unified_bull_on[1]
unified_bear_sig = unified_bear_on and not unified_bear_on[1]

// ═══════════════════════════════════════════════════════════
//  AI TREND SUITE
// ═══════════════════════════════════════════════════════════

// ── 1. ADAPTIVE KALMAN FILTER ────────────────────────────────
// Aerospace-grade signal filter. Separates the true price trend from
// measurement noise by adapting its gain to market volatility in real time.
var float kf_state = na
var float kf_varp  = 1.0

_kf_pn    = math.pow(atr_val * kf_proc_n, 2)
_kf_mn    = math.pow(ta.stdev(close, 20), 2)
_kf_pv    = kf_varp + _kf_pn
_kf_kg    = _kf_pv / math.max(_kf_pv + _kf_mn, 0.0001)
kf_state := na(kf_state) ? close : kf_state + _kf_kg * (close - kf_state)
kf_varp  := (1 - _kf_kg) * _kf_pv

kf_bull   = kf_state > kf_state[1]
kf_col    = kf_bull ? color.new(#00E5FF, 0) : color.new(#FF6B6B, 0)

// ── 2. KAMA — EFFICIENCY RATIO ADAPTIVE MA ──────────────────
// Measures signal-to-noise ratio (Efficiency Ratio). Tracks price
// fast in strong trends, nearly freezes in choppy conditions.
_kd       = math.abs(close - close[kama_len])
_kv       = math.sum(math.abs(close - close[1]), kama_len)
kama_er   = _kv > 0 ? _kd / _kv : 0.0         // 0 = noise, 1 = trend
_kfast    = 2.0 / 3.0
_kslow    = 2.0 / 31.0
_ksc      = math.pow(kama_er * (_kfast - _kslow) + _kslow, 2)

var float kama_v = na
kama_v   := na(kama_v) ? close : kama_v + _ksc * (close - kama_v)
kama_bull = kama_v > kama_v[1]
kama_col  = kama_bull ? color.new(#FFCA28, 0) : color.new(#FF7043, 0)

// ── 3. DYNAMIC REGRESSION CHANNEL ────────────────────────────
// ML's least-squares regression applied to price. The ±σ bands are
// genuine statistical confidence intervals — not arbitrary multiples.
// Price outside the 2σ band is statistically abnormal.
reg_line   = ta.linreg(close, reg_len, 0)
reg_bull   = reg_line > ta.linreg(close, reg_len, 1)

_rc        = ta.correlation(close, bar_index, reg_len)
_rs        = ta.stdev(close, reg_len) * math.sqrt(math.max(1 - _rc * _rc, 0.001))

reg_u1     = reg_line + _rs
reg_l1     = reg_line - _rs
reg_u2     = reg_line + 2 * _rs
reg_l2     = reg_line - 2 * _rs

reg_out_bull = close < reg_l2   // abnormally low — stat outlier, mean-reversion candidate
reg_out_bear = close > reg_u2   // abnormally high — stat outlier, mean-reversion candidate

// ── 4. MARKET STATE CLASSIFIER ───────────────────────────────
// HMM-inspired 3-state classifier. Combines ADX (trend strength),
// BB width (volatility), and KAMA slope (direction) into a single
// state: BULL TREND · BEAR TREND · RANGING.
// When state_filter = true, L/S signals are suppressed in wrong states.
[_di_p, _di_m, adx_v] = ta.dmi(adx_len, adx_len)
_kslope       = (kama_v - kama_v[5]) / math.max(atr_val, 0.001)
_is_ranging   = adx_v < 20 or (adx_v < 25 and math.abs(_kslope) < 0.3)
market_state  = _is_ranging ? 0 : (_kslope > 0.2 and kf_bull ? 1 : _kslope < -0.2 and not kf_bull ? -1 : 0)

state_col  = market_state ==  1 ? color.new(#26A69A, 0) : market_state == -1 ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
state_lbl  = market_state ==  1 ? "▲ Bull Trend" : market_state == -1 ? "▼ Bear Trend" : "→ Ranging"

// ── 5. HURST EXPONENT ────────────────────────────────────────
// Measures long-range dependence. H > 0.55 = persistent trend.
// H < 0.45 = mean-reverting. H ≈ 0.5 = random walk.
_sig8      = ta.stdev(close, 8)
_sig32     = ta.stdev(close, 32)
hurst_val  = _sig8 > 0 ? math.log(math.max(_sig32, 0.0001) / math.max(_sig8, 0.0001)) / math.log(4.0) : 0.5
hurst_lbl  = hurst_val > 0.55 ? "Trending (" + str.tostring(math.round(hurst_val, 2)) + ")" : hurst_val < 0.45 ? "Mean-rev (" + str.tostring(math.round(hurst_val, 2)) + ")" : "Random (" + str.tostring(math.round(hurst_val, 2)) + ")"
hurst_col  = hurst_val > 0.55 ? color.new(#26A69A, 0) : hurst_val < 0.45 ? color.new(#EF5350, 0) : color.new(#607D8B, 0)

// ═══════════════════════════════════════════════════════════
//  AI PREMIUM SUITE
// ═══════════════════════════════════════════════════════════

// ── AUTO-ADAPTIVE FIBONACCI ──────────────────────────────────
// Automatically finds the dominant swing, plots retracements + extensions,
// and highlights the Golden Zone (38.2%–61.8%) — the highest-probability
// reversal area on any timeframe.
fib_ph_s = ta.pivothigh(high, fib_piv_len, fib_piv_len)
fib_pl_s = ta.pivotlow(low,   fib_piv_len, fib_piv_len)

var float fib_hi = na
var float fib_lo = na

if not na(fib_ph_s)
    fib_hi := fib_ph_s
if not na(fib_pl_s)
    fib_lo := fib_pl_s

fib_ok  = not na(fib_hi) and not na(fib_lo) and fib_hi > fib_lo
fib_rng = fib_ok ? fib_hi - fib_lo : na

// Retracements (from high downward)
f_236 = fib_ok ? fib_hi - 0.236 * fib_rng : na
f_382 = fib_ok ? fib_hi - 0.382 * fib_rng : na
f_50  = fib_ok ? fib_hi - 0.500 * fib_rng : na
f_618 = fib_ok ? fib_hi - 0.618 * fib_rng : na
f_786 = fib_ok ? fib_hi - 0.786 * fib_rng : na

// Extensions above high (upside targets)
f_ext_1272 = fib_ok ? fib_hi + 0.272 * fib_rng : na
f_ext_1618 = fib_ok ? fib_hi + 0.618 * fib_rng : na

// Extensions below low (downside targets)
f_dn_1272  = fib_ok ? fib_lo - 0.272 * fib_rng : na
f_dn_1618  = fib_ok ? fib_lo - 0.618 * fib_rng : na

// ── MARKET STRUCTURE ENGINE ───────────────────────────────────
// Continuously tracks HH/HL/LH/LL structure.
// BOS = trend continues · CHoCH = structure reversing (earliest warning)
mse_ph_s = ta.pivothigh(high, mse_piv_len, mse_piv_len)
mse_pl_s = ta.pivotlow(low,   mse_piv_len, mse_piv_len)

var float mse_last_ph = na
var float mse_prev_ph = na
var int   mse_ph_bar  = na
var float mse_last_pl = na
var float mse_prev_pl = na
var int   mse_pl_bar  = na

if not na(mse_ph_s)
    mse_prev_ph := mse_last_ph
    mse_last_ph := mse_ph_s
    mse_ph_bar  := bar_index[mse_piv_len]

if not na(mse_pl_s)
    mse_prev_pl := mse_last_pl
    mse_last_pl := mse_pl_s
    mse_pl_bar  := bar_index[mse_piv_len]

// Structure state
mse_is_bull = not na(mse_last_ph) and not na(mse_prev_ph) and mse_last_ph >= mse_prev_ph
mse_is_bear = not na(mse_last_ph) and not na(mse_prev_ph) and mse_last_ph <  mse_prev_ph

// BOS: break in the direction of structure (continuation)
bull_bos   = show_mse and mse_is_bull and not na(mse_last_ph) and high > mse_last_ph and high[1] <= mse_last_ph
bear_bos   = show_mse and mse_is_bear and not na(mse_last_pl) and low  < mse_last_pl and low[1]  >= mse_last_pl

// CHoCH: first break against structure (earliest reversal warning)
bear_choch = show_mse and mse_is_bull and not na(mse_last_pl) and low  < mse_last_pl and low[1]  >= mse_last_pl
bull_choch = show_mse and mse_is_bear and not na(mse_last_ph) and high > mse_last_ph and high[1] <= mse_last_ph

// Structure labels at each swing pivot
mse_hh = not na(mse_ph_s) and not na(mse_prev_ph) and mse_last_ph > mse_prev_ph
mse_lh = not na(mse_ph_s) and not na(mse_prev_ph) and mse_last_ph < mse_prev_ph
mse_hl = not na(mse_pl_s) and not na(mse_prev_pl) and mse_last_pl > mse_prev_pl
mse_ll = not na(mse_pl_s) and not na(mse_prev_pl) and mse_last_pl < mse_prev_pl

// ── NEURAL CONFLUENCE SCORE (NCS) ────────────────────────────
// A 10-input neural network layer: normalised inputs → weighted sum →
// sigmoid activation → 0–100 score. VWAP and SCD carry highest weights
// (most important for Nifty intraday). Output updates every bar.

// Sigmoid activation (same as every neural network layer)
sigmoid(x) => 1.0 / (1.0 + math.exp(-x))

// Normalise each input to approximately -1 to +1
_nf1  = kf_bull  ? 1.0 : -1.0                                                // Kalman direction
_nf2  = kama_bull ? 0.8 : -0.8                                               // KAMA direction
_nf3  = close > vwap_val ? 1.0 : -1.0                                        // VWAP position
_nf4  = math.max(math.min((rsi_val - 50.0) / 25.0, 2.0), -2.0)             // RSI -2→+2
_nf5  = math.max(math.min((volume / math.max(vol_sma,1) - 1.0) * 1.5, 1.5), -1.5) // Volume
_nf6  = math.max(math.min((hurst_val - 0.5) * 4.0, 2.0), -2.0)            // Hurst
_nf7  = math.max(math.min(scd_slope / math.max(atr_val * 5.0, 0.001), 1.5), -1.5) // SCD delta
_nf8  = float(market_state)                                                   // State -1,0,1
_nf9  = (kama_er - 0.5) * 2.0                                               // Efficiency ratio
_nf10 = reg_bull ? 0.8 : -0.8                                                // Regression slope

// Weights (tuned for Nifty scalping)
_nw1=2.0
_nw2=1.5
_nw3=2.5
_nw4=1.0
_nw5=1.5
_nw6=1.5
_nw7=2.0
_nw8=2.0
_nw9=1.0
_nw10=1.0

_nwsum = _nw1*_nf1 + _nw2*_nf2 + _nw3*_nf3 + _nw4*_nf4 + _nw5*_nf5 + _nw6*_nf6 + _nw7*_nf7 + _nw8*_nf8 + _nw9*_nf9 + _nw10*_nf10
_nwtot = _nw1 + _nw2 + _nw3 + _nw4 + _nw5 + _nw6 + _nw7 + _nw8 + _nw9 + _nw10

ncs_val  = sigmoid(_nwsum / _nwtot * 4.0) * 100.0
ncs_bull = ncs_val >= ncs_high_t
ncs_bear = ncs_val <= ncs_low_t
ncs_col  = ncs_bull ? color.new(#00E676, 0) : ncs_bear ? color.new(#EF5350, 0) : color.new(#90CAF9, 0)

// Visual progress bar for table (Unicode blocks)
_nb = math.round(ncs_val / 10)
ncs_bar = (_nb>=1?"█":"░") + (_nb>=2?"█":"░") + (_nb>=3?"█":"░") + (_nb>=4?"█":"░") + (_nb>=5?"█":"░") + (_nb>=6?"█":"░") + (_nb>=7?"█":"░") + (_nb>=8?"█":"░") + (_nb>=9?"█":"░") + (_nb>=10?"█":"░")

bz1 = show_bsz and math.abs(close - s1_v) <= prox
bz2 = show_bsz and math.abs(close - s2_v) <= prox
sz1 = show_bsz and math.abs(close - r1_v) <= prox
sz2 = show_bsz and math.abs(close - r2_v) <= prox

// ─── EMA + RIBBON ───────────────────────────────────────────
p_fast = plot(ema_fast, "EMA Fast", color=fast_col, linewidth=fast_w)
p_slow = plot(ema_slow, "EMA Slow", color=slow_col, linewidth=slow_w)
fill(p_fast, p_slow,
  color = show_rib ? (ema_fast > ema_slow ? color.new(fast_col, 82) : color.new(slow_col, 82)) : na,
  title = "EMA ribbon"
)

// ─── CROSSOVER CONNECTOR LINE ───────────────────────────────
// Diagonal line connecting each crossover point to the previous one
var int   cx_bar   = na
var float cx_price = na

if show_cx and (ema_cross_up or ema_cross_dn)
    cx_now = math.avg(ema_fast, ema_slow)
    if not na(cx_bar)
        line.new(cx_bar, cx_price, bar_index, cx_now,
                 color  = cx_col,
                 width  = cx_w,
                 style  = cx_style_val,
                 extend = extend.none)
    cx_bar   := bar_index
    cx_price := cx_now

// ─── VWAP ───────────────────────────────────────────────────
plot(vwap_val, "VWAP", color=vwap_col, linewidth=vwap_w)

// ─── BOLLINGER BANDS ────────────────────────────────────────
p_bbu = plot(show_bb ? bb_upper : na, "BB upper", color=color.new(#7986CB, 50), linewidth=bb_w)
p_bbl = plot(show_bb ? bb_lower : na, "BB lower", color=color.new(#7986CB, 50), linewidth=bb_w)
plot(show_bb ? bb_mid : na,           "BB mid",   color=color.new(#7986CB, 75), linewidth=bb_w)
fill(p_bbu, p_bbl, color=show_bb ? color.new(#7986CB, 92) : na, title="BB fill")

// ─── SUPERTREND ──────────────────────────────────────────────
plot(show_st ? st_line : na, "Supertrend",
  color     = st_bull ? color.new(#26A69A, 0) : color.new(#EF5350, 0),
  linewidth = st_w,
  style     = plot.style_line
)

// ─── PREV DAY HIGH / LOW ─────────────────────────────────────
plot(show_pdhl ? pdh : na, "Prev day high", color=pdh_col, linewidth=pdhl_w, style=plot.style_stepline)
plot(show_pdhl ? pdl : na, "Prev day low",  color=pdl_col, linewidth=pdhl_w, style=plot.style_stepline)

// ─── PIVOT LINES ─────────────────────────────────────────────
plot(show_piv ? p_v  : na, "Pivot", color=color.new(#ECEFF1, 40), linewidth=piv_w, style=plot.style_stepline)
plot(show_piv ? r1_v : na, "R1",    color=color.new(#EF5350, 15), linewidth=piv_w, style=plot.style_stepline)
plot(show_piv ? r2_v : na, "R2",    color=color.new(#EF5350, 35), linewidth=piv_w, style=plot.style_stepline)
plot(show_piv ? s1_v : na, "S1",    color=color.new(#26A69A, 15), linewidth=piv_w, style=plot.style_stepline)
plot(show_piv ? s2_v : na, "S2",    color=color.new(#26A69A, 35), linewidth=piv_w, style=plot.style_stepline)
// R3/S3 shown in right-side labels only (removed plots to stay under 64-plot limit)

// ─── PIVOT LABELS (right-side) ───────────────────────────────
// Labels sit at the last bar — label.style_label_left flows text rightward
// into the margin without allocating future bars (prevents zoom desync)
piv_txt(name, val) =>
    show_pval ? name + "  " + str.tostring(math.round(val, 1)) : name

var label lbl_p  = na
var label lbl_r1 = na
var label lbl_r2 = na
var label lbl_r3 = na
var label lbl_s1 = na
var label lbl_s2 = na
var label lbl_s3 = na

if show_piv and show_plbl and barstate.islast
    lx = bar_index
    label.delete(lbl_p)
    label.delete(lbl_r1)
    label.delete(lbl_r2)
    label.delete(lbl_r3)
    label.delete(lbl_s1)
    label.delete(lbl_s2)
    label.delete(lbl_s3)
    lbl_p  := label.new(lx, p_v,  piv_txt("P",  p_v),  style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#ECEFF1, 20))
    lbl_r1 := label.new(lx, r1_v, piv_txt("R1", r1_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#EF5350,  0))
    lbl_r2 := label.new(lx, r2_v, piv_txt("R2", r2_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#EF5350, 20))
    lbl_r3 := label.new(lx, r3_v, piv_txt("R3", r3_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#EF5350, 40))
    lbl_s1 := label.new(lx, s1_v, piv_txt("S1", s1_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#26A69A,  0))
    lbl_s2 := label.new(lx, s2_v, piv_txt("S2", s2_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#26A69A, 20))
    lbl_s3 := label.new(lx, s3_v, piv_txt("S3", s3_v), style=label.style_label_left, size=plbl_sz, color=color.new(#263238, 80), textcolor=color.new(#26A69A, 40))

// ─── DEMAND / SUPPLY ZONE BOXES ─────────────────────────────
// Converted from plot()+fill() to box.new() to stay under 64-plot limit
var box supply_box = na
var box demand_box = na
var float _prev_sup = na
var float _prev_dem = na

if show_dsz and not na(sup_top) and sup_top != _prev_sup
    box.delete(supply_box)
    supply_box := box.new(bar_index - 200, sup_top, bar_index, sup_bot, extend=extend.right, bgcolor=color.new(#EF5350, 77), border_color=color.new(#EF5350, 55), border_width=1)
    _prev_sup := sup_top

if show_dsz and not na(dem_top) and dem_top != _prev_dem
    box.delete(demand_box)
    demand_box := box.new(bar_index - 200, dem_top, bar_index, dem_bot, extend=extend.right, bgcolor=color.new(#26A69A, 77), border_color=color.new(#26A69A, 55), border_width=1)
    _prev_dem := dem_top

// ─── SMART TREND LINES & CHANNEL FILL ───────────────────────
var line tl_res_line = na
var line tl_sup_line = na
var linefill tl_fill = na

if show_tl
    if not na(ph1) and not na(ph2) and phb1 != phb2
        line.delete(tl_res_line)
        tl_res_line := line.new(phb2, ph2, phb1, ph1, extend=extend.right, color=tl_res_col, width=tl_w, style=line.style_solid)
    if not na(pl1) and not na(pl2) and plb1 != plb2
        line.delete(tl_sup_line)
        tl_sup_line := line.new(plb2, pl2, plb1, pl1, extend=extend.right, color=tl_sup_col, width=tl_w, style=line.style_solid)
    if show_channel and not na(tl_res_line) and not na(tl_sup_line)
        linefill.delete(tl_fill)
        tl_fill := linefill.new(tl_res_line, tl_sup_line, color=color.new(color.gray, 92))

// ─── CHART PATTERN VISUAL DRAWINGS (LuxAlgo-style) ───────────

// ── Boundary lines: triangles, wedges, broadening ────────────
// One shared pair recycled per active pattern. Colour signals direction.
var line cpat_res  = na
var line cpat_sup  = na
var linefill cpat_fill = na

_cpat_tw = show_cpat and (_f_asc_t or _f_dsc_t or _f_sym_t or _f_r_wdg or _f_f_wdg or _f_asc_b or _f_dsc_b)

if _cpat_tw and (not na(sm_ph) or not na(sm_pl))
    line.delete(cpat_res)
    line.delete(cpat_sup)
    linefill.delete(cpat_fill)
    _pc = _f_asc_t or _f_f_wdg or _f_dsc_b ? color.new(#26A69A, 0) :
          _f_dsc_t or _f_r_wdg or _f_asc_b  ? color.new(#EF5350, 0) :
          color.new(#7986CB, 0)
    cpat_res  := line.new(phb2, ph2, phb1, ph1, extend=extend.right, color=_pc, width=1, style=line.style_dashed)
    cpat_sup  := line.new(plb2, pl2, plb1, pl1, extend=extend.right, color=_pc, width=1, style=line.style_dashed)
    cpat_fill := linefill.new(cpat_res, cpat_sup, color=color.new(_pc, 90))

// ── H&S neckline ─────────────────────────────────────────────
var line hs_neck = na

if show_cpat and (_f_hs or _f_ihs) and (not na(sm_ph) or not na(sm_pl))
    line.delete(hs_neck)
    _nk  = _f_hs  ? nz(hs_neck_v)  : nz(ihs_neck_v)
    _nkc = _f_hs  ? color.new(#EF5350, 15) : color.new(#26A69A, 15)
    hs_neck := line.new(bar_index - sm_piv_len * 6, _nk, bar_index, _nk, extend=extend.right, color=_nkc, width=2, style=line.style_dotted)

// ── Double Top / Bottom neckline ─────────────────────────────
var line dbl_level = na

if show_cpat and (_f_dbl_t or _f_dbl_b) and (not na(sm_ph) or not na(sm_pl))
    line.delete(dbl_level)
    _dl  = _f_dbl_t ? nz(dbl_top_neck) : nz(dbl_bot_neck)
    _dlc = _f_dbl_t ? color.new(#EF5350, 15) : color.new(#26A69A, 15)
    dbl_level := line.new(bar_index - sm_piv_len * 6, _dl, bar_index, _dl, extend=extend.right, color=_dlc, width=2, style=line.style_solid)

// ── Measured-move target (draws on confirmed breakout bar) ────
var line cpat_target   = na
var label cpat_tgt_lbl = na

_tri_h = not na(_pat_h) ? _pat_h : atr_val * 2

// Compute target price + direction for whichever pattern fires this bar
_tgt_price = float(na)
_tgt_bull  = false

if asc_tri_sig
    _tgt_price := (ph1 + ph2) * 0.5 + _tri_h
    _tgt_bull  := true
if dsc_tri_sig
    _tgt_price := (pl1 + pl2) * 0.5 - _tri_h
if sym_tri_sig
    _sym_bull   = close > (ph1 + pl1) * 0.5
    _tgt_price := _sym_bull ? (ph1 + ph2) * 0.5 + _tri_h : (pl1 + pl2) * 0.5 - _tri_h
    _tgt_bull  := _sym_bull
if f_wdg_sig
    _tgt_price := ph1 + (ph1 - pl1)
    _tgt_bull  := true
if r_wdg_sig
    _tgt_price := pl1 - (ph1 - pl1)
if asc_brd_sig
    _tgt_price := ph1 + (ph1 - pl1) * 0.5
    _tgt_bull  := true
if dsc_brd_sig
    _tgt_price := pl1 - (ph1 - pl1) * 0.5
if hs_sig and not na(hs_neck_v)
    _tgt_price := hs_neck_v - (ph2 - hs_neck_v)
if ihs_sig and not na(ihs_neck_v)
    _tgt_price := ihs_neck_v + (ihs_neck_v - pl2)
    _tgt_bull  := true
if dbl_top_sig and not na(dbl_top_neck)
    _tgt_price := dbl_top_neck - ((ph1 + ph2) * 0.5 - dbl_top_neck)
if dbl_bot_sig and not na(dbl_bot_neck)
    _tgt_price := dbl_bot_neck + (dbl_bot_neck - (pl1 + pl2) * 0.5)
    _tgt_bull  := true

// Draw once, in global scope (no function needed)
_any_pat_sig = asc_tri_sig or dsc_tri_sig or sym_tri_sig or r_wdg_sig or f_wdg_sig or asc_brd_sig or dsc_brd_sig or hs_sig or ihs_sig or dbl_top_sig or dbl_bot_sig

if _any_pat_sig and not na(_tgt_price)
    line.delete(cpat_target)
    label.delete(cpat_tgt_lbl)
    _tc         = _tgt_bull ? color.new(#26A69A, 20) : color.new(#EF5350, 20)
    cpat_target   := line.new(bar_index, _tgt_price, bar_index + sm_piv_len * 3, _tgt_price, extend=extend.right, color=_tc, width=1, style=line.style_arrow_right)
    cpat_tgt_lbl  := label.new(bar_index + 2, _tgt_price, "⊙ " + str.tostring(math.round(_tgt_price, 1)), style=label.style_label_right, color=color.new(_tc, 50), textcolor=color.white, size=size.tiny)

// ── Pattern name label — single recycled slot ────────────────
// Deletes the previous label before drawing the new one.
// Only the most recently confirmed pattern is ever visible on chart.
var label cpat_name_lbl = na

if _any_pat_sig
    label.delete(cpat_name_lbl)
    _cpat_bull = _tgt_bull
    _cpat_y    = _cpat_bull ? low  - atr_val * 0.6 : high + atr_val * 0.6
    _cpat_sty  = _cpat_bull ? label.style_label_up : label.style_label_down
    _cpat_col  = sym_tri_sig ? color.new(#7986CB, 15) : _cpat_bull ? color.new(#26A69A, 15) : color.new(#EF5350, 15)
    _cpat_txt  = dsc_tri_sig ? "Desc Triangle" : r_wdg_sig ? "Rising Wedge" : asc_brd_sig ? "Asc Broadening" : hs_sig ? "H & S" : dbl_top_sig ? "Double Top" : asc_tri_sig ? "Asc Triangle" : f_wdg_sig ? "Falling Wedge" : dsc_brd_sig ? "Desc Broadening" : ihs_sig ? "Inv H & S" : dbl_bot_sig ? "Double Bottom" : "Sym Triangle"
    cpat_name_lbl := label.new(bar_index, _cpat_y, _cpat_txt, style=_cpat_sty, color=_cpat_col, textcolor=color.white, size=size.small)


// ─── BUY / SELL ZONES + TREND BACKGROUND ────────────────────
bgcolor(bz1 ? color.new(#26A69A, 87) : na, title="Buy zone 1 — near S1")
bgcolor(bz2 ? color.new(#26A69A, 82) : na, title="Buy zone 2 — near S2")
bgcolor(sz1 ? color.new(#EF5350, 87) : na, title="Sell zone 1 — near R1")
bgcolor(sz2 ? color.new(#EF5350, 82) : na, title="Sell zone 2 — near R2")
bgcolor(
  show_bg and not bz1 and not bz2 and not sz1 and not sz2 and bull ? color.new(color.teal, 95) :
  show_bg and not bz1 and not bz2 and not sz1 and not sz2 and bear ? color.new(color.red,  95) : na,
  title="Trend background"
)

// ─── CANDLE COLOR (priority: institutional > high score > moderate score) ─
barcolor(
  inst_buy                        ? inst_bull_col           :
  inst_sell                       ? inst_bear_col           :
  show_bar_score and ms_bull >= 8 ? color.new(#00E676,  0)  :
  show_bar_score and ms_bear >= 8 ? color.new(#FF1744,  0)  :
  show_bar_score and ms_bull >= 6 ? color.new(#00E676, 45)  :
  show_bar_score and ms_bear >= 6 ? color.new(#FF1744, 45)  :
  close >= open                   ? color.new(#26A69A,  0)  :
  color.new(#EF5350, 0),
  title = "Candle color"
)

// ─── ENTRY SIGNALS ──────────────────────────────────────────
plotshape(long_sig  and show_sig and (not state_filter or market_state >= 0), "Long",  shape.labelup,   location.belowbar, color.new(#00E676, 0), text="L", textcolor=color.black, size=size.small)
plotshape(short_sig and show_sig and (not state_filter or market_state <= 0), "Short", shape.labeldown, location.abovebar, color.new(#EF5350, 0), text="S", textcolor=color.white, size=size.small)

// ─── STRONG MOMENTUM SIGNALS ────────────────────────────────
plotshape(strong_long  and show_strong, "Strong Long",
          shape.triangleup, location.belowbar,
          color.new(#00FF00, 0), text="▲ STRONG", textcolor=color.new(#00FF00, 0), size=size.normal)
plotshape(strong_short and show_strong, "Strong Short",
          shape.triangledown, location.abovebar,
          color.new(#FF0000, 0), text="▼ STRONG", textcolor=color.new(#FF0000, 0), size=size.normal)

// ─── FALSE BREAKOUT ALERTS ───────────────────────────────────
plotshape(show_false_brk and fake_break_up, "Fake Bullish Break",
          shape.xcross, location.abovebar, color.new(#FF9800, 0), size=size.small)
plotshape(show_false_brk and fake_break_dn, "Fake Bearish Break",
          shape.xcross, location.belowbar, color.new(#FF9800, 0), size=size.small)

// ─── UNIFIED LEADING SIGNAL (fires when 3+ systems agree) ───
plotshape(unified_bull_sig, "LEAD Bull",
          shape.triangleup, location.belowbar,
          color.new(#00E676, 0), text="◉ LEAD", textcolor=color.new(#00FF00, 0), size=size.large)
plotshape(unified_bear_sig, "LEAD Bear",
          shape.triangledown, location.abovebar,
          color.new(#EF5350, 0), text="◉ LEAD", textcolor=color.new(#FF0000, 0), size=size.large)

// ─── INDIVIDUAL LEADING SIGNALS ──────────────────────────────
// ─── INDIVIDUAL LEADING SIGNALS (labels — do not count toward plot limit) ──
if scd_bull_sig
    label.new(bar_index, low  - atr_val*0.4, "Δ SCD",  style=label.style_label_up,   color=color.new(#1D9E75, 50), textcolor=color.new(#1D9E75, 0), size=size.small)
if scd_bear_sig
    label.new(bar_index, high + atr_val*0.4, "∇ SCD",  style=label.style_label_down, color=color.new(#EF5350, 50), textcolor=color.new(#EF5350, 0), size=size.small)
if cmp_bull_sig
    label.new(bar_index, low  - atr_val*0.4, "◈ CMP",  style=label.style_label_up,   color=color.new(#378ADD, 50), textcolor=color.new(#378ADD, 0), size=size.small)
if cmp_bear_sig
    label.new(bar_index, high + atr_val*0.4, "◈ CMP",  style=label.style_label_down, color=color.new(#7986CB, 50), textcolor=color.new(#7986CB, 0), size=size.small)
if spring_sig
    label.new(bar_index, low  - atr_val*0.4, "⚡SPR",  style=label.style_label_up,   color=color.new(#00C853, 40), textcolor=color.black,           size=size.small)
if upthrust_sig
    label.new(bar_index, high + atr_val*0.4, "⚡UT",   style=label.style_label_down, color=color.new(#D50000, 40), textcolor=color.white,           size=size.small)
if ire_bull
    label.new(bar_index, low  - atr_val*0.4, "⏱ IRE",  style=label.style_label_up,   color=color.new(#BA7517, 50), textcolor=color.new(#FFD600, 0), size=size.small)
if ire_bear
    label.new(bar_index, high + atr_val*0.4, "⏱ IRE",  style=label.style_label_down, color=color.new(#BA7517, 50), textcolor=color.new(#FFD600, 0), size=size.small)
if bull_absorb
    label.new(bar_index, low  - atr_val*0.6, "A",      style=label.style_label_up,   color=color.new(#1D9E75, 65), textcolor=color.new(#1D9E75, 0), size=size.tiny)
if bear_absorb
    label.new(bar_index, high + atr_val*0.6, "A",      style=label.style_label_down, color=color.new(#EF5350, 65), textcolor=color.new(#EF5350, 0), size=size.tiny)
if mva_bull_sig
    label.new(bar_index, low  - atr_val*0.6, "v↑",     style=label.style_label_up,   color=color.new(#7F77DD, 60), textcolor=color.new(#7F77DD, 0), size=size.tiny)
if mva_bear_sig
    label.new(bar_index, high + atr_val*0.6, "v↓",     style=label.style_label_down, color=color.new(#7F77DD, 60), textcolor=color.new(#7F77DD, 0), size=size.tiny)
if phantom_bull_sig
    label.new(bar_index, low  - atr_val*0.4, "φ",      style=label.style_label_up,   color=color.new(#CE93D8, 50), textcolor=color.new(#CE93D8, 0), size=size.small)
if phantom_bear_sig
    label.new(bar_index, high + atr_val*0.4, "φ",      style=label.style_label_down, color=color.new(#CE93D8, 50), textcolor=color.new(#CE93D8, 0), size=size.small)
if polarity_bull_drift
    label.new(bar_index, low  - atr_val*0.6, "P↑",     style=label.style_label_up,   color=color.new(#80CBC4, 65), textcolor=color.new(#80CBC4, 0), size=size.tiny)
if polarity_bear_drift
    label.new(bar_index, high + atr_val*0.6, "P↓",     style=label.style_label_down, color=color.new(#FF7043, 65), textcolor=color.new(#FF7043, 0), size=size.tiny)

// Compression active — very subtle background tint
bgcolor(show_cmp and cmp_cond ? color.new(#7986CB, 96) : na, title="Compression zone")

// ─── AI TREND SUITE PLOTS ────────────────────────────────────

// Kalman Filter — zero-lag adaptive trend line
plot(show_kf ? kf_state : na, "Kalman Filter", color=kf_col, linewidth=2)

// KAMA — efficiency-adaptive MA (nearly flat in chop, fast in trend)
plot(show_kama ? kama_v : na, "KAMA", color=kama_col, linewidth=1)

// Regression Channel — statistical confidence bands
p_rl  = plot(show_reg ? reg_line : na, "Reg trend", color=color.new(#90CAF9, 25), linewidth=1)
p_ru1 = plot(show_reg ? reg_u1   : na, "Reg +1σ",  color=color.new(#7986CB, 50), linewidth=1)
p_rl1 = plot(show_reg ? reg_l1   : na, "Reg −1σ",  color=color.new(#7986CB, 50), linewidth=1)
p_ru2 = plot(show_reg ? reg_u2   : na, "Reg +2σ",  color=color.new(#7986CB, 72), linewidth=1)
p_rl2 = plot(show_reg ? reg_l2   : na, "Reg −2σ",  color=color.new(#7986CB, 72), linewidth=1)
fill(p_ru1, p_rl1, color=show_reg ? color.new(#7986CB, 93) : na, title="Reg 1σ fill")
fill(p_ru2, p_rl2, color=show_reg ? color.new(#7986CB, 97) : na, title="Reg 2σ fill")

// Market State Classifier — background tint per state
bgcolor(show_state and market_state ==  1 ? color.new(#26A69A, 96) : na, title="State: Bull Trend")
bgcolor(show_state and market_state == -1 ? color.new(#EF5350, 96) : na, title="State: Bear Trend")
bgcolor(show_state and market_state ==  0 ? color.new(#607D8B, 97) : na, title="State: Ranging")

// ─── AUTO-ADAPTIVE FIBONACCI — line.new() (no plot limit cost) ──
var line fib_l236  = na
var line fib_l382  = na
var line fib_l50   = na
var line fib_l618  = na
var line fib_l786  = na
var line fib_lx1   = na
var line fib_lx2   = na
var line fib_lx3   = na
var line fib_lx4   = na
var box  fib_gz    = na

if show_fib and fib_ok and (not na(fib_ph_s) or not na(fib_pl_s))
    line.delete(fib_l236)
    line.delete(fib_l382)
    line.delete(fib_l50)
    line.delete(fib_l618)
    line.delete(fib_l786)
    box.delete(fib_gz)
    fib_l236 := line.new(bar_index - 1, f_236, bar_index, f_236, extend=extend.both, color=color.new(#FFD600, 60), width=1)
    fib_l382 := line.new(bar_index - 1, f_382, bar_index, f_382, extend=extend.both, color=color.new(#FFD600, 35), width=1)
    fib_l50  := line.new(bar_index - 1, f_50,  bar_index, f_50,  extend=extend.both, color=color.new(#FFD600, 15), width=2)
    fib_l618 := line.new(bar_index - 1, f_618, bar_index, f_618, extend=extend.both, color=color.new(#FFD600, 35), width=1)
    fib_l786 := line.new(bar_index - 1, f_786, bar_index, f_786, extend=extend.both, color=color.new(#FFD600, 60), width=1)
    fib_gz   := box.new(bar_index - 200, f_382, bar_index, f_618, extend=extend.right, bgcolor=color.new(#FFD600, 90), border_color=color.new(#FFD600, 65), border_width=1)
    if show_fib_ext
        line.delete(fib_lx1)
        line.delete(fib_lx2)
        line.delete(fib_lx3)
        line.delete(fib_lx4)
        fib_lx1 := line.new(bar_index - 1, f_ext_1272, bar_index, f_ext_1272, extend=extend.both, color=color.new(#FFD600, 72), width=1)
        fib_lx2 := line.new(bar_index - 1, f_ext_1618, bar_index, f_ext_1618, extend=extend.both, color=color.new(#FFD600, 78), width=1)
        fib_lx3 := line.new(bar_index - 1, f_dn_1272,  bar_index, f_dn_1272,  extend=extend.both, color=color.new(#FFD600, 72), width=1)
        fib_lx4 := line.new(bar_index - 1, f_dn_1618,  bar_index, f_dn_1618,  extend=extend.both, color=color.new(#FFD600, 78), width=1)

// ─── FIBONACCI RIGHT-SIDE LABELS ─────────────────────────────
var label lf236=na, var label lf382=na, var label lf50=na
var label lf618=na, var label lf786=na
var label lf127u=na, var label lf161u=na, var label lf127d=na, var label lf161d=na

if show_fib and show_fib_lbl and fib_ok and barstate.islast
    label.delete(lf236)
    label.delete(lf382)
    label.delete(lf50)
    label.delete(lf618)
    label.delete(lf786)
    lf236 := label.new(bar_index, f_236, "23.6%  " + str.tostring(math.round(f_236, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 25))
    lf382 := label.new(bar_index, f_382, "38.2%  " + str.tostring(math.round(f_382, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600,  0))
    lf50  := label.new(bar_index, f_50,  "50.0%  " + str.tostring(math.round(f_50,  1)), style=label.style_label_left, size=size.small, color=color.new(#FFD600, 50), textcolor=color.white)
    lf618 := label.new(bar_index, f_618, "61.8%  " + str.tostring(math.round(f_618, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600,  0))
    lf786 := label.new(bar_index, f_786, "78.6%  " + str.tostring(math.round(f_786, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 25))
    if show_fib_ext
        label.delete(lf127u)
        label.delete(lf161u)
        label.delete(lf127d)
        label.delete(lf161d)
        lf127u := label.new(bar_index, f_ext_1272, "127.2%↑  " + str.tostring(math.round(f_ext_1272, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 45))
        lf161u := label.new(bar_index, f_ext_1618, "161.8%↑  " + str.tostring(math.round(f_ext_1618, 1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 55))
        lf127d := label.new(bar_index, f_dn_1272,  "127.2%↓  " + str.tostring(math.round(f_dn_1272,  1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 45))
        lf161d := label.new(bar_index, f_dn_1618,  "161.8%↓  " + str.tostring(math.round(f_dn_1618,  1)), style=label.style_label_left, size=size.tiny, color=color.new(#1A2030, 80), textcolor=color.new(#FFD600, 55))

// ─── MARKET STRUCTURE ENGINE LABELS ──────────────────────────
// Each slot holds ONE label — delete + recreate on each new event.
// Maximum labels on chart at any time: 4 (1 high-struct + 1 low-struct
// + 1 BOS + 1 CHoCH). Eliminates the label-accumulation clutter.
var label lbl_mse_high  = na   // most recent HH or LH
var label lbl_mse_low   = na   // most recent HL or LL
var label lbl_mse_bos   = na   // most recent BOS (either direction)
var label lbl_mse_choch = na   // most recent CHoCH (either direction)

// HH / LH labels (only if user opted in — default OFF to reduce noise)
if show_mse and show_mse_structs and mse_hh
    label.delete(lbl_mse_high)
    lbl_mse_high := label.new(mse_ph_bar, mse_last_ph + atr_val*0.25, "HH", style=label.style_label_down, color=color.new(#26A69A, 40), textcolor=color.white, size=size.tiny)
if show_mse and show_mse_structs and mse_lh
    label.delete(lbl_mse_high)
    lbl_mse_high := label.new(mse_ph_bar, mse_last_ph + atr_val*0.25, "LH", style=label.style_label_down, color=color.new(#EF5350, 40), textcolor=color.white, size=size.tiny)

// HL / LL labels (same toggle)
if show_mse and show_mse_structs and mse_hl
    label.delete(lbl_mse_low)
    lbl_mse_low := label.new(mse_pl_bar, mse_last_pl - atr_val*0.25, "HL", style=label.style_label_up, color=color.new(#26A69A, 40), textcolor=color.white, size=size.tiny)
if show_mse and show_mse_structs and mse_ll
    label.delete(lbl_mse_low)
    lbl_mse_low := label.new(mse_pl_bar, mse_last_pl - atr_val*0.25, "LL", style=label.style_label_up, color=color.new(#EF5350, 40), textcolor=color.white, size=size.tiny)

// BOS — always visible when MSE is on (single recycled label)
if show_mse and bull_bos
    label.delete(lbl_mse_bos)
    lbl_mse_bos := label.new(bar_index, high + atr_val*0.5, "BOS ▲", style=label.style_label_down, color=color.new(#26A69A, 20), textcolor=color.white, size=size.small)
if show_mse and bear_bos
    label.delete(lbl_mse_bos)
    lbl_mse_bos := label.new(bar_index, low  - atr_val*0.5, "BOS ▼", style=label.style_label_up,   color=color.new(#EF5350, 20), textcolor=color.white, size=size.small)

// CHoCH — single recycled label (higher priority than BOS visually)
if show_mse and bull_choch
    label.delete(lbl_mse_choch)
    lbl_mse_choch := label.new(bar_index, high + atr_val*0.5, "CHoCH ▲", style=label.style_label_down, color=color.new(#FF9800, 20), textcolor=color.white, size=size.small)
if show_mse and bear_choch
    label.delete(lbl_mse_choch)
    lbl_mse_choch := label.new(bar_index, low  - atr_val*0.5, "CHoCH ▼", style=label.style_label_up,   color=color.new(#FF9800, 20), textcolor=color.white, size=size.small)

// ─── NCS SCORE ON LEAD SIGNALS ───────────────────────────────
if show_ncs and unified_bull_sig
    label.new(bar_index, low - atr_val * 1.1, "NCS " + str.tostring(math.round(ncs_val)) + "/100", style=label.style_label_up, color=color.new(#7F77DD, 35), textcolor=color.white, size=size.tiny)
if show_ncs and unified_bear_sig
    label.new(bar_index, high + atr_val * 1.1, "NCS " + str.tostring(math.round(ncs_val)) + "/100", style=label.style_label_down, color=color.new(#7F77DD, 35), textcolor=color.white, size=size.tiny)

// ─── CANDLESTICK PATTERN MARKERS ────────────────────────────
// ─── CANDLESTICK PATTERN MARKERS (labels — do not count toward plot limit) ─
if show_patterns and bull_engulf
    label.new(bar_index, low  - atr_val*0.3, "●", style=label.style_label_up,   color=color.new(#00BCD4, 60), textcolor=color.new(#00BCD4, 0), size=size.tiny)
if show_patterns and bear_engulf
    label.new(bar_index, high + atr_val*0.3, "●", style=label.style_label_down, color=color.new(#FF7043, 60), textcolor=color.new(#FF7043, 0), size=size.tiny)
if show_patterns and morning_star
    label.new(bar_index, low  - atr_val*0.3, "✦", style=label.style_label_up,   color=color.new(#00E676, 50), textcolor=color.white, size=size.small)
if show_patterns and evening_star
    label.new(bar_index, high + atr_val*0.3, "✦", style=label.style_label_down, color=color.new(#EF5350, 50), textcolor=color.white, size=size.small)
if show_patterns and is_hammer
    label.new(bar_index, low  - atr_val*0.3, "↑", style=label.style_label_up,   color=color.new(#80CBC4, 65), textcolor=color.new(#80CBC4, 0), size=size.tiny)
if show_patterns and is_shooting
    label.new(bar_index, high + atr_val*0.3, "↓", style=label.style_label_down, color=color.new(#FFAB40, 65), textcolor=color.new(#FFAB40, 0), size=size.tiny)
if show_patterns and bull_marubozu
    label.new(bar_index, low  - atr_val*0.3, "■", style=label.style_label_up,   color=color.new(#00E676, 65), textcolor=color.new(#00E676, 0), size=size.tiny)
if show_patterns and bear_marubozu
    label.new(bar_index, high + atr_val*0.3, "■", style=label.style_label_down, color=color.new(#EF5350, 65), textcolor=color.new(#EF5350, 0), size=size.tiny)

// ─── INFO TABLE ─────────────────────────────────────────────
rsi_col  = rsi_val >= ob ? color.new(#EF5350, 0) : rsi_val <= os ? color.new(#26A69A, 0) : color.new(#90CAF9, 0)
rsi_lbl  = rsi_val >= ob ? "Overbought" : rsi_val <= os ? "Oversold" : "Neutral"
vol_col  = volume > vol_sma ? color.new(#26A69A, 0) : color.new(#607D8B, 0)
vol_lbl  = volume > vol_sma ? "Above avg  ✓" : "Below avg"
st_col   = st_bull ? color.new(#26A69A, 0) : color.new(#EF5350, 0)
vwap_col2 = close > vwap_val ? color.new(#26A69A, 0) : color.new(#EF5350, 0)

var tbl = table.new(
  position.bottom_right, 2, 12,
  bgcolor      = color.new(#0D1117, 65),
  frame_color  = color.new(#263238, 55),
  frame_width  = 1,
  border_color = color.new(#263238, 55),
  border_width = 1
)

if show_tbl and barstate.islast
    table.cell(tbl, 0, 0, "Indicator",  text_color=color.new(color.white, 35), text_size=size.small, bgcolor=color.new(#1E2A38, 55))
    table.cell(tbl, 1, 0, "Status",     text_color=color.new(color.white, 35), text_size=size.small, bgcolor=color.new(#1E2A38, 55))
    table.cell(tbl, 0, 1, "RSI " + str.tostring(rsi_len),
               text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(math.round(rsi_val, 1)) + "  " + rsi_lbl,
               text_color=rsi_col, text_size=size.small)
    table.cell(tbl, 0, 2, "Volume",     text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 2, vol_lbl,      text_color=vol_col, text_size=size.small)
    table.cell(tbl, 0, 3, "Supertrend", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 3, st_bull ? "Bullish" : "Bearish", text_color=st_col, text_size=size.small)
    table.cell(tbl, 0, 4, "VWAP bias",  text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 4, close > vwap_val ? "Above" : "Below", text_color=vwap_col2, text_size=size.small)
    // Momentum score
    score_col_t = ms_bull > ms_bear ? (ms_bull >= 7 ? color.new(#00E676, 0) : color.new(#80CBC4, 0)) : (ms_bear >= 7 ? color.new(#EF5350, 0) : color.new(#FF7043, 0))
    table.cell(tbl, 0, 5, "Momentum",   text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 5, "▲ " + str.tostring(ms_bull) + "  /  ▼ " + str.tostring(ms_bear), text_color=score_col_t, text_size=size.small)
    // Pattern detected
    pat_lbl = bull_engulf or bull_marubozu ? "Bull Engulf" : bear_engulf or bear_marubozu ? "Bear Engulf" : morning_star ? "Morning Star" : evening_star ? "Evening Star" : is_hammer ? "Hammer" : is_shooting ? "Shooting Star" : bull_pin ? "Bull Pin Bar" : bear_pin ? "Bear Pin Bar" : is_doji ? "Doji" : is_inside ? "Inside Bar" : "—"
    pat_col_t = bull_engulf or morning_star or is_hammer or bull_pin or bull_marubozu ? color.new(#26A69A, 0) : bear_engulf or evening_star or is_shooting or bear_pin or bear_marubozu ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl, 0, 6, "Pattern",    text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 6, pat_lbl,      text_color=pat_col_t, text_size=size.small)
    table.cell(tbl, 0, 7, "Channel",    text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 7, ch_type,      text_color=color.new(#90CAF9, 0), text_size=size.small)
    table.cell(tbl, 0, 8, "AI State",   text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 8, state_lbl,    text_color=state_col, text_size=size.small)
    table.cell(tbl, 0, 9, show_hurst ? "Hurst H" : "", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 9, show_hurst ? hurst_lbl : "", text_color=hurst_col, text_size=size.small)
    table.cell(tbl, 0, 10, show_ncs ? "NCS" : "",    text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 10, show_ncs ? ncs_bar + " " + str.tostring(math.round(ncs_val)) : "", text_color=ncs_col, text_size=size.small)
    table.cell(tbl, 0, 11, show_mse ? "Structure" : "", text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl, 1, 11, show_mse ? (mse_is_bull ? "▲ Bull struct" : mse_is_bear ? "▼ Bear struct" : "—") : "", text_color=show_mse ? (mse_is_bull ? color.new(#26A69A,0) : mse_is_bear ? color.new(#EF5350,0) : color.new(#607D8B,0)) : color.new(#607D8B,0), text_size=size.small)

// ─── LEADING INDICATOR TABLE (top-right) ─────────────────────
var tbl_lead = table.new(
  position.top_right, 2, 10,
  bgcolor      = color.new(#0D1117, 65),
  frame_color  = color.new(#263238, 55),
  frame_width  = 1,
  border_color = color.new(#263238, 55),
  border_width = 1
)

if show_lead and barstate.islast
    table.cell(tbl_lead, 0, 0, "Leading System", text_color=color.new(color.white, 35), text_size=size.small, bgcolor=color.new(#1E2A38, 55))
    table.cell(tbl_lead, 1, 0, "State",          text_color=color.new(color.white, 35), text_size=size.small, bgcolor=color.new(#1E2A38, 55))

    _scd_s  = scd_bull_div ? "▲ Bull div" : scd_bear_div ? "▼ Bear div" : "Neutral"
    _scd_c  = scd_bull_div ? color.new(#26A69A, 0) : scd_bear_div ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 1, "SCD Delta",      text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 1, _scd_s,           text_color=_scd_c, text_size=size.small)

    _cmp_s  = cmp_cond and bull ? "▲ Coiling" : cmp_cond and bear ? "▼ Coiling" : cmp_cond ? "Coiling" : "—"
    _cmp_c  = cmp_cond and bull ? color.new(#26A69A, 0) : cmp_cond and bear ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 2, "Compression",    text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 2, _cmp_s,           text_color=_cmp_c, text_size=size.small)

    _spr_s  = spring_sig ? "▲ Spring!" : upthrust_sig ? "▼ Upthrust!" : "—"
    _spr_c  = spring_sig ? color.new(#26A69A, 0) : upthrust_sig ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 3, "Spring / UT",    text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 3, _spr_s,           text_color=_spr_c, text_size=size.small)

    _ire_s  = ire_bull ? "▲ Vol surge" : ire_bear ? "▼ Vol surge" : "Normal"
    _ire_c  = ire_bull ? color.new(#26A69A, 0) : ire_bear ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 4, "IRE",            text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 4, _ire_s,           text_color=_ire_c, text_size=size.small)

    _abs_s  = bull_absorb ? "▲ Accumulating" : bear_absorb ? "▼ Distributing" : "—"
    _abs_c  = bull_absorb ? color.new(#26A69A, 0) : bear_absorb ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 5, "Absorption",     text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 5, _abs_s,           text_color=_abs_c, text_size=size.small)

    _mva_s  = mva_bull_sig ? "▲ Re-accel" : mva_bear_sig ? "▼ Decel" : "—"
    _mva_c  = mva_bull_sig ? color.new(#26A69A, 0) : mva_bear_sig ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 6, "MVA",            text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 6, _mva_s,           text_color=_mva_c, text_size=size.small)

    _pht_s  = phantom_bull ? "▲ Phantom div" : phantom_bear ? "▼ Phantom div" : "—"
    _pht_c  = phantom_bull ? color.new(#26A69A, 0) : phantom_bear ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 7, "Phantom",        text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 7, _pht_s,           text_color=_pht_c, text_size=size.small)

    _pol_s  = polarity_bull_drift ? "▲ Shift bull" : polarity_bear_drift ? "▼ Shift bear" : "Neutral"
    _pol_c  = polarity_bull_drift ? color.new(#26A69A, 0) : polarity_bear_drift ? color.new(#EF5350, 0) : color.new(#607D8B, 0)
    table.cell(tbl_lead, 0, 8, "Polarity",       text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 8, _pol_s,           text_color=_pol_c, text_size=size.small)

    _lmax   = math.max(leading_bull, leading_bear)
    _lbias  = leading_bull > leading_bear ? "BULL " : leading_bear > leading_bull ? "BEAR " : ""
    _lc     = leading_bull > leading_bear ? color.new(#00E676, 0) : leading_bear > leading_bull ? color.new(#EF5350, 0) : color.new(#90CAF9, 0)
    table.cell(tbl_lead, 0, 9, "Lead Score",     text_color=color.new(color.white, 30), text_size=size.small)
    table.cell(tbl_lead, 1, 9, _lbias + str.tostring(_lmax) + " / 14", text_color=_lc, text_size=size.small)
