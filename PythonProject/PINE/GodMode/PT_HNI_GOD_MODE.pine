// ╔══════════════════════════════════════════════════════════════════════════════════╗
// ║   PT HNI GOD MODE  ✦  ULTIMATE EDGE                                            ║
// ║   Pine Script v6  |  Prime Technical  |  NSE · BSE · MCX                       ║
// ║                                                                                  ║
// ║   18 ENGINE MODULES:                                                             ║
// ║   01 Trend Engine      (EMA + Supertrend + HTF + ADX)                           ║
// ║   02 Smart Money (SMC) (Order Blocks · FVG · BOS · ChoCH · Liquidity)           ║
// ║   03 Volume Intelligence (Session POC · Climax · Absorption · VWAP)             ║
// ║   04 Volatility Squeeze (TTM: BB+KC · Momentum · Squeeze Fire)                  ║
// ║   05 Divergence Engine (RSI regular · RSI hidden · MACD)                        ║
// ║   06 Advanced Patterns (3-Bar Reversal · Turtle Soup · Pin · Engulf)            ║
// ║   07 Fake Break Shield (8 conditions · Volume gate · Wick ratio)                ║
// ║   08 Market Phase      (Trending · Ranging · Volatile · Transition)             ║
// ║   09 S/R Stack         (CPR · Pivots · VWAP · OR · POC)                         ║
// ║   10 Market Structure  (HH · HL · LH · LL · Swing pivots)                      ║
// ║   11 F&O Intelligence  (Weekly/Monthly expiry · Expiry-day bias)                ║
// ║   12 Session Engine    (IST filter · Opening range · Lunch filter)              ║
// ║   13 15-Factor Scoring (Weighted confluence engine)                             ║
// ║   14 Signal Generation (Gated multi-condition signals)                          ║
// ║   15 Visualisation     (Boxes · Labels · Shapes · Colors · Zones)              ║
// ║   16 Live Dashboard    (26-cell real-time status table)                         ║
// ║   17 Risk Engine       (ATR SL/TP1/TP2/TP3 · R:R calculator)                  ║
// ║   18 Alert Suite       (12 precision alert conditions)                          ║
// ╚══════════════════════════════════════════════════════════════════════════════════╝

//@version=6
indicator("PT HNI GOD MODE — Ultimate Edge", shorttitle="PT·GOD·MODE",
          overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=300)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 01  —  INPUTS
// ══════════════════════════════════════════════════════════════════════════════════

// ── Trend ────────────────────────────────────────────────────────────────────────
g1 = "📈  01 · Trend Engine"
ema_f   = input.int(9,   "Fast EMA",             group=g1)
ema_m   = input.int(21,  "Mid EMA",              group=g1)
ema_s   = input.int(50,  "Slow EMA",             group=g1)
ema_t   = input.int(200, "Trend Wall EMA",       group=g1)
htf_tf  = input.timeframe("60", "HTF Confirm TF",group=g1)
st_f    = input.float(3.0,"Supertrend Factor",   group=g1, step=0.1)
st_p    = input.int(10,  "Supertrend ATR Period",group=g1)
show_ema= input.bool(true,"Show EMA Ribbon",     group=g1)
show_st = input.bool(false,"Show Supertrend Line",group=g1)

// ── Smart Money ──────────────────────────────────────────────────────────────────
g2 = "🧠  02 · Smart Money (SMC)"
show_ob   = input.bool(true, "Show Order Blocks",          group=g2)
ob_min    = input.float(0.8, "OB Impulse Strength (×ATR)", group=g2, step=0.1)
ob_ext    = input.int(40,    "OB Box Extension (bars)",    group=g2)
show_fvg  = input.bool(false, "Show Fair Value Gaps",       group=g2)
fvg_min   = input.float(0.3, "Min FVG Size (×ATR)",        group=g2, step=0.05)
show_liq  = input.bool(true, "Show Liquidity Levels",      group=g2)
liq_tol   = input.float(0.12,"Liquidity Tolerance (×ATR)", group=g2, step=0.01)
show_bos  = input.bool(true, "Show BOS / ChoCH",           group=g2)

// ── Volatility Squeeze ───────────────────────────────────────────────────────────
g3 = "⚡  03 · Volatility Squeeze"
sqz_len   = input.int(20,  "Squeeze Length",    group=g3)
bb_mult   = input.float(2.0,"BB Multiplier",    group=g3, step=0.1)
kc_mult   = input.float(1.5,"KC Multiplier",    group=g3, step=0.1)
show_sqz  = input.bool(true,"Show Squeeze Dots",group=g3)

// ── Volume ───────────────────────────────────────────────────────────────────────
g4 = "📊  04 · Volume Intelligence"
vol_ma_len  = input.int(20,  "Volume MA Length",          group=g4)
vol_sur_m   = input.float(1.3,"Volume Surge ×",           group=g4, step=0.05)
vol_clim_m  = input.float(2.5,"Climax Volume ×",          group=g4, step=0.1)
show_poc    = input.bool(true,"Show Session POC",          group=g4)
show_vwap   = input.bool(true,"Show VWAP + Bands",        group=g4)

// ── Divergence ───────────────────────────────────────────────────────────────────
g5 = "🔄  05 · Divergence Engine"
rsi_len     = input.int(14,  "RSI Length",       group=g5)
rsi_ob      = input.int(65,  "RSI OB Gate",      group=g5)
rsi_os      = input.int(35,  "RSI OS Gate",      group=g5)
div_lb      = input.int(5,   "Divergence Pivot Lookback", group=g5)
show_rsi_d  = input.bool(true,"Show RSI Divergence",      group=g5)
show_hid_d  = input.bool(true,"Show Hidden Divergence",   group=g5)
show_macd_d = input.bool(true,"Show MACD Divergence",     group=g5)

// ── Patterns ─────────────────────────────────────────────────────────────────────
g6 = "🕯️  06 · Advanced Patterns"
pb_wbr      = input.float(1.8,"Pin Bar Wick/Body Ratio",   group=g6, step=0.1)
eng_br      = input.float(1.05,"Engulf Body Ratio",         group=g6, step=0.05)
ts_len      = input.int(20,   "Turtle Soup Lookback",       group=g6)
show_3bar   = input.bool(true, "Show 3-Bar Reversals",      group=g6)
show_turtle = input.bool(false, "Show Turtle Soup",          group=g6)

// ── Fake Break ───────────────────────────────────────────────────────────────────
g7 = "🛡️  07 · Fake Break Shield"
show_fake   = input.bool(false, "Show Fake Break Warnings",    group=g7)
fake_wick_r = input.float(0.6, "Wick Rejection Ratio",        group=g7, step=0.05)
use_vol_gate= input.bool(true, "Require Volume Gate on Breaks",group=g7)

// ── S&R Levels ───────────────────────────────────────────────────────────────────
g8 = "📌  08 · S/R Stack"
show_cpr   = input.bool(true, "Show CPR",              group=g8)
show_piv   = input.bool(true, "Show Classic Pivots",   group=g8)
show_or    = input.bool(true, "Show Opening Range",    group=g8)
swing_lb   = input.int(5,     "Swing Pivot Lookback",  group=g8, minval=3)

// ── Risk ─────────────────────────────────────────────────────────────────────────
g9 = "⚖️  09 · Risk Engine"
atr_len    = input.int(14,  "ATR Length",       group=g9)
sl_m       = input.float(1.0,"SL = N × ATR",   group=g9, step=0.1)
tp1_m      = input.float(1.5,"TP1 = N × ATR",  group=g9, step=0.1)
tp2_m      = input.float(3.0,"TP2 = N × ATR",  group=g9, step=0.1)
tp3_m      = input.float(5.0,"TP3 = N × ATR",  group=g9, step=0.5)
show_rr    = input.bool(true, "Show SL/TP Labels",group=g9)

// ── Signal Gating ────────────────────────────────────────────────────────────────
g10 = "🎯  10 · Signal Gating"
min_sc      = input.int(5,  "Min Confluence Score (1-15)", group=g10, minval=1, maxval=15)
use_session = input.bool(true,"India Session Filter",       group=g10)
use_adx_g   = input.bool(true,"ADX Gate (>20)",             group=g10)
adx_min     = input.int(20,   "Min ADX",                   group=g10)
use_rsi_g   = input.bool(true,"RSI OB/OS Gate",            group=g10)
use_sqz_g   = input.bool(false,"Prefer Squeeze-Fire Entries",group=g10)

// ── Display ──────────────────────────────────────────────────────────────────────
g11 = "🎨  11 · Display"
c_bull     = input.color(color.new(#00C853,0), "Bull Color",  group=g11)
c_bear     = input.color(color.new(#FF1744,0), "Bear Color",  group=g11)
c_warn     = input.color(color.new(#FF6F00,0), "Warn Color",  group=g11)
show_dash  = input.bool(true,"Show Dashboard",               group=g11)
show_str   = input.bool(false,"Show Structure Labels",        group=g11)
show_zones = input.bool(true,"Show Demand/Supply Zones",     group=g11)
show_sigs  = input.bool(false,"Show Buy/Sell Signals",        group=g11)

// ═════════════════════════════════════════════════════════════════════════════════
//  MODULE 02  —  CORE CALCULATIONS
// ═════════════════════════════════════════════════════════════════════════════════

// ── Base ──────────────────────────────────────────────────────────────────────────
atr        = ta.atr(atr_len)
vol_ma     = ta.sma(volume, vol_ma_len)
vol_surge  = volume > vol_ma * vol_sur_m
vol_climax = volume > vol_ma * vol_clim_m
is_bull_c  = close > open
is_bear_c  = close < open
body       = math.abs(close - open)
c_range    = high - low
upper_wick = high  - math.max(close, open)
lower_wick = math.min(close, open) - low

// ── EMAs ──────────────────────────────────────────────────────────────────────────
ema9   = ta.ema(close, ema_f)
ema21  = ta.ema(close, ema_m)
ema50  = ta.ema(close, ema_s)
ema200 = ta.ema(close, ema_t)
ema_bull = ema9 > ema21 and ema21 > ema50 and close > ema50
ema_bear = ema9 < ema21 and ema21 < ema50 and close < ema50

// ── Supertrend ────────────────────────────────────────────────────────────────────
[st_line, st_dir] = ta.supertrend(st_f, st_p)
st_bull = st_dir == -1
st_bear = st_dir ==  1

// ── ADX + DI ─────────────────────────────────────────────────────────────────────
[di_plus, di_minus, adx_val] = ta.dmi(14, 14)
adx_ok   = adx_val >= adx_min
adx_bull = di_plus > di_minus
adx_bear = di_minus > di_plus

// ── RSI ───────────────────────────────────────────────────────────────────────────
rsi_val   = ta.rsi(close, rsi_len)
rsi_buy   = rsi_val < rsi_ob
rsi_sell  = rsi_val > rsi_os

// ── MACD ─────────────────────────────────────────────────────────────────────────
[macd_line, macd_sig, macd_hist] = ta.macd(close, 12, 26, 9)
macd_bull = macd_line > macd_sig
macd_bear = macd_line < macd_sig

// ── Higher TF Trend ───────────────────────────────────────────────────────────────
[htf_c, htf_e50, htf_e200] = request.security(syminfo.tickerid, htf_tf,
     [close, ta.ema(close, 50), ta.ema(close, 200)], lookahead=barmerge.lookahead_off)
htf_bull = htf_c > htf_e50 and htf_e50 > htf_e200
htf_bear = htf_c < htf_e50 and htf_e50 < htf_e200

// ── Previous Day OHLC (non-repainting) ───────────────────────────────────────────
[prev_H, prev_L, prev_C] = request.security(syminfo.tickerid, "D",
     [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

// ── CPR ───────────────────────────────────────────────────────────────────────────
cpr_piv   = (prev_H + prev_L + prev_C) / 3.0
cpr_tc    = (prev_H + prev_L) / 2.0
cpr_bc    = 2.0 * cpr_piv - cpr_tc
cpr_hi    = math.max(cpr_tc, cpr_bc)
cpr_lo    = math.min(cpr_tc, cpr_bc)
cpr_width = cpr_hi - cpr_lo
cpr_narrow= cpr_width < atr * 0.6

// ── Classic Pivots ────────────────────────────────────────────────────────────────
pp  = cpr_piv
r1  = 2.0 * pp - prev_L
r2  = pp + (prev_H - prev_L)
r3  = prev_H + 2.0 * (pp - prev_L)
s1  = 2.0 * pp - prev_H
s2  = pp - (prev_H - prev_L)
s3  = prev_L - 2.0 * (prev_H - pp)

// ── VWAP + Bands ─────────────────────────────────────────────────────────────────
vwap_val  = ta.vwap(hlc3)
vwap_dev  = ta.stdev(hlc3 - vwap_val, 20)
vwap_u1   = vwap_val + vwap_dev
vwap_l1   = vwap_val - vwap_dev
vwap_u2   = vwap_val + 2.0 * vwap_dev
vwap_l2   = vwap_val - 2.0 * vwap_dev
vwap_bull = close > vwap_val
vwap_bear = close < vwap_val

// ── Session & Opening Range ───────────────────────────────────────────────────────
india_sess = "0915-1530:23456"
or_sess    = "0915-0930:23456"
in_market  = not na(time(timeframe.period, india_sess, "Asia/Kolkata"))
in_or      = not na(time(timeframe.period, or_sess,    "Asia/Kolkata"))
new_day    = ta.change(time("D")) != 0

var float or_hi = na
var float or_lo = na
if new_day
    or_hi := na
    or_lo := na
if in_or
    or_hi := na(or_hi) ? high : math.max(or_hi, high)
    or_lo := na(or_lo) ? low  : math.min(or_lo, low)

session_ok = (not use_session) or (in_market and not in_or)

// ── Market Structure ──────────────────────────────────────────────────────────────
s_ph = ta.pivothigh(high, swing_lb, swing_lb)
s_pl = ta.pivotlow(low,  swing_lb, swing_lb)

var float last_ph = na
var float prev_ph = na
var float last_pl = na
var float prev_pl = na
if not na(s_ph)
    prev_ph := last_ph
    last_ph := s_ph
if not na(s_pl)
    prev_pl := last_pl
    last_pl := s_pl

ms_hh = not na(last_ph) and not na(prev_ph) and last_ph > prev_ph
ms_hl = not na(last_pl) and not na(prev_pl) and last_pl > prev_pl
ms_lh = not na(last_ph) and not na(prev_ph) and last_ph < prev_ph
ms_ll = not na(last_pl) and not na(prev_pl) and last_pl < prev_pl
ms_bull = ms_hh and ms_hl
ms_bear = ms_lh and ms_ll

// ── Level Proximity ───────────────────────────────────────────────────────────────
prox = atr * 0.45
at_sup = ((math.abs(low - s1) < prox) or (math.abs(low - s2) < prox) or
          (math.abs(low - cpr_lo) < prox) or (math.abs(low - vwap_val) < prox) or
          (not na(or_lo) and math.abs(low - or_lo) < prox))

at_res = ((math.abs(high - r1) < prox) or (math.abs(high - r2) < prox) or
          (math.abs(high - cpr_hi) < prox) or (math.abs(high - vwap_val) < prox) or
          (not na(or_hi) and math.abs(high - or_hi) < prox))

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 03  —  SMART MONEY CONCEPTS
// ══════════════════════════════════════════════════════════════════════════════════

// ── Order Block Detection ─────────────────────────────────────────────────────────
// Bull OB: last bearish candle before a strong bullish impulse
bull_impulse = is_bull_c and (close - open) >= atr * ob_min and close > high[1]
bull_ob_fire = bull_impulse and is_bear_c[1]

// Bear OB: last bullish candle before a strong bearish impulse
bear_impulse = is_bear_c and (open - close) >= atr * ob_min and close < low[1]
bear_ob_fire = bear_impulse and is_bull_c[1]

var box[]   bull_ob_bx = array.new_box()
var float[] bull_ob_hi = array.new_float()
var float[] bull_ob_lo = array.new_float()

var box[]   bear_ob_bx = array.new_box()
var float[] bear_ob_hi = array.new_float()
var float[] bear_ob_lo = array.new_float()

if bull_ob_fire and show_ob
    ob_t = math.max(open[1], close[1])
    ob_b = math.min(open[1], close[1])
    b = box.new(bar_index - 1, ob_t, bar_index + ob_ext, ob_b,
                bgcolor=color.new(#00C853, 85), border_color=color.new(#00C853, 35), border_width=1)
    array.push(bull_ob_bx, b)
    array.push(bull_ob_hi, ob_t)
    array.push(bull_ob_lo, ob_b)
    if array.size(bull_ob_bx) > 5
        box.delete(array.shift(bull_ob_bx))
        array.shift(bull_ob_hi)
        array.shift(bull_ob_lo)

if bear_ob_fire and show_ob
    ob_t = math.max(open[1], close[1])
    ob_b = math.min(open[1], close[1])
    b = box.new(bar_index - 1, ob_t, bar_index + ob_ext, ob_b,
                bgcolor=color.new(#FF1744, 85), border_color=color.new(#FF1744, 35), border_width=1)
    array.push(bear_ob_bx, b)
    array.push(bear_ob_hi, ob_t)
    array.push(bear_ob_lo, ob_b)
    if array.size(bear_ob_bx) > 5
        box.delete(array.shift(bear_ob_bx))
        array.shift(bear_ob_hi)
        array.shift(bear_ob_lo)

// Check if price is near a bull OB (scoring factor)
near_bull_ob = false
if array.size(bull_ob_hi) > 0
    for i = 0 to array.size(bull_ob_hi) - 1
        if (low <= array.get(bull_ob_hi, i) + atr * 0.2 and
            low >= array.get(bull_ob_lo, i) - atr * 0.2)
            near_bull_ob := true
            break

near_bear_ob = false
if array.size(bear_ob_hi) > 0
    for i = 0 to array.size(bear_ob_hi) - 1
        if (high >= array.get(bear_ob_lo, i) - atr * 0.2 and
            high <= array.get(bear_ob_hi, i) + atr * 0.2)
            near_bear_ob := true
            break

// ── Fair Value Gaps ────────────────────────────────────────────────────────────────
// Bull FVG: low[0] > high[2] — upside gap (unfilled bullish imbalance)
bull_fvg_cond  = low > high[2] and (low - high[2]) >= atr * fvg_min
// Bear FVG: high[0] < low[2] — downside gap
bear_fvg_cond  = high < low[2] and (low[2] - high) >= atr * fvg_min

var box[]   bull_fvg_bx = array.new_box()
var float[] bull_fvg_hi = array.new_float()
var float[] bull_fvg_lo = array.new_float()

var box[]   bear_fvg_bx = array.new_box()
var float[] bear_fvg_hi = array.new_float()
var float[] bear_fvg_lo = array.new_float()

if bull_fvg_cond and show_fvg
    b = box.new(bar_index - 2, low, bar_index + ob_ext, high[2],
                bgcolor=color.new(#00BCD4, 88), border_color=color.new(#00BCD4, 40), border_width=1)
    array.push(bull_fvg_bx, b)
    array.push(bull_fvg_hi, low)
    array.push(bull_fvg_lo, high[2])
    if array.size(bull_fvg_bx) > 6
        box.delete(array.shift(bull_fvg_bx))
        array.shift(bull_fvg_hi)
        array.shift(bull_fvg_lo)

if bear_fvg_cond and show_fvg
    b = box.new(bar_index - 2, low[2], bar_index + ob_ext, high,
                bgcolor=color.new(#FF9800, 88), border_color=color.new(#FF9800, 40), border_width=1)
    array.push(bear_fvg_bx, b)
    array.push(bear_fvg_hi, low[2])
    array.push(bear_fvg_lo, high)
    if array.size(bear_fvg_bx) > 6
        box.delete(array.shift(bear_fvg_bx))
        array.shift(bear_fvg_hi)
        array.shift(bear_fvg_lo)

// Near FVG (scoring factor)
near_bull_fvg = false
if array.size(bull_fvg_hi) > 0
    for i = 0 to array.size(bull_fvg_hi) - 1
        if (low <= array.get(bull_fvg_hi, i) + atr * 0.15 and
            low >= array.get(bull_fvg_lo, i) - atr * 0.15)
            near_bull_fvg := true
            break

near_bear_fvg = false
if array.size(bear_fvg_hi) > 0
    for i = 0 to array.size(bear_fvg_hi) - 1
        if (high >= array.get(bear_fvg_lo, i) - atr * 0.15 and
            high <= array.get(bear_fvg_hi, i) + atr * 0.15)
            near_bear_fvg := true
            break

// ── Liquidity Levels (Equal Highs / Equal Lows) ───────────────────────────────────
// Equal Highs = buy-side liquidity  (retail stop-losses above)
// Equal Lows  = sell-side liquidity (retail stop-losses below)
liq_tol_val  = atr * liq_tol
eq_high_1    = math.abs(high - high[1]) < liq_tol_val
eq_high_2    = math.abs(high - high[2]) < liq_tol_val
eq_low_1     = math.abs(low  - low[1])  < liq_tol_val
eq_low_2     = math.abs(low  - low[2])  < liq_tol_val
liq_buy_side = eq_high_1 or eq_high_2   // Equal highs = potential stop hunt up
liq_sell_side= eq_low_1  or eq_low_2    // Equal lows  = potential stop hunt down

// ── Break of Structure / Change of Character ──────────────────────────────────────
// BOS Bull: In downtrend, price closes above last swing high
// BOS Bear: In uptrend,   price closes below last swing low
bos_bull  = ms_bear and not na(last_ph) and ta.crossover(close, last_ph)
bos_bear  = ms_bull and not na(last_pl) and ta.crossunder(close, last_pl)

// ChoCH: First structural reversal (more significant than BOS)
// Aggressive detection: strong engulfing + bos_bull/bear
choch_bull = bos_bull and body > atr * 1.2 and is_bull_c
choch_bear = bos_bear and body > atr * 1.2 and is_bear_c

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 04  —  VOLATILITY SQUEEZE (TTM Style)
// ══════════════════════════════════════════════════════════════════════════════════
bb_basis  = ta.sma(close, sqz_len)
bb_upper  = bb_basis + bb_mult * ta.stdev(close, sqz_len)
bb_lower  = bb_basis - bb_mult * ta.stdev(close, sqz_len)
kc_basis  = ta.ema(close, sqz_len)
kc_atr    = ta.atr(sqz_len)
kc_upper  = kc_basis + kc_mult * kc_atr
kc_lower  = kc_basis - kc_mult * kc_atr

sqz_on    = bb_upper < kc_upper and bb_lower > kc_lower   // Compression
sqz_off   = not sqz_on
sqz_fire  = sqz_on[1] and sqz_off                         // Release event!
pre_sqz   = not sqz_on[2] and sqz_on[1] and sqz_on        // Entry into squeeze

// TTM Momentum (Linear regression of normalised close)
sqz_mom_src = close - math.avg(
    math.avg(ta.highest(high, sqz_len), ta.lowest(low, sqz_len)),
    ta.sma(close, sqz_len))
sqz_mom     = ta.linreg(sqz_mom_src, sqz_len, 0)
sqz_mom_bull= sqz_fire and sqz_mom > 0    // Squeeze fires bullish
sqz_mom_bear= sqz_fire and sqz_mom < 0    // Squeeze fires bearish

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 05  —  SESSION VOLUME POC (Point of Control Approximation)
// ══════════════════════════════════════════════════════════════════════════════════
var float sess_poc     = na
var float sess_poc_vol = 0.0
var float sess_vah     = na
var float sess_val     = na

if new_day
    sess_poc     := na
    sess_poc_vol := 0.0
    sess_vah     := na
    sess_val     := na

if in_market
    if volume > sess_poc_vol or na(sess_poc)
        sess_poc_vol := volume
        sess_poc     := (high + low) / 2.0
        sess_vah     := high
        sess_val     := low
    else
        // Expand value area
        if not na(sess_vah) and high > sess_vah
            sess_vah := high
        if not na(sess_val) and low < sess_val
            sess_val := low

near_poc = not na(sess_poc) and math.abs(close - sess_poc) < atr * 0.5

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 06  —  MARKET PHASE DETECTOR
// ══════════════════════════════════════════════════════════════════════════════════
atr_avg    = ta.sma(atr, 20)
high_vol_m = atr > atr_avg * 1.7    // High volatility regime

phase_trend = adx_val > 25 and (ema_bull or ema_bear)
phase_range = adx_val < 20
phase_vol   = high_vol_m

market_phase = phase_trend ? "TREND" : phase_vol ? "VOLATILE" : phase_range ? "RANGE" : "TRANS"

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 07  —  ADVANCED PATTERNS
// ══════════════════════════════════════════════════════════════════════════════════

// ── Price Action Patterns ─────────────────────────────────────────────────────────
bull_pin   = (lower_wick >= body * pb_wbr and upper_wick <= body * 0.6 and
              body > 0 and lower_wick >= c_range * 0.55)
bear_pin   = (upper_wick >= body * pb_wbr and lower_wick <= body * 0.6 and
              body > 0 and upper_wick >= c_range * 0.55)

bull_eng   = (is_bear_c[1] and is_bull_c and open <= close[1] and
              close >= open[1] and body >= body[1] * eng_br)
bear_eng   = (is_bull_c[1] and is_bear_c and open >= close[1] and
              close <= open[1] and body >= body[1] * eng_br)

hammer     = lower_wick >= body * 2.5 and upper_wick <= body * 0.4 and body > 0
shoot_star = upper_wick >= body * 2.5 and lower_wick <= body * 0.4 and body > 0

// ── 3-Bar Reversal ────────────────────────────────────────────────────────────────
// Bullish: Bear[2] → Bar[1] makes new low → Bull[0] closes above Bar[2] high
bull_3bar  = is_bear_c[2] and low[1] < low[2] and is_bull_c and close > high[2]
// Bearish: Bull[2] → Bar[1] makes new high → Bear[0] closes below Bar[2] low
bear_3bar  = is_bull_c[2] and high[1] > high[2] and is_bear_c and close < low[2]

// ── Turtle Soup (False N-Bar Break) ──────────────────────────────────────────────
// Turtle Long: Price pierces 20-bar low, immediately closes back above it
ts_low     = ta.lowest(low, ts_len)[1]   // Prior N-bar low (exclude current)
ts_high    = ta.highest(high, ts_len)[1] // Prior N-bar high
turtle_long  = show_turtle and low < ts_low and close > ts_low and is_bull_c
turtle_short = show_turtle and high > ts_high and close < ts_high and is_bear_c

// ── Wick Rejection ────────────────────────────────────────────────────────────────
wick_rej_bull = (lower_wick / (c_range + 0.0001)) >= fake_wick_r and at_sup
wick_rej_bear = (upper_wick / (c_range + 0.0001)) >= fake_wick_r and at_res

// ── Combined PA Signal ────────────────────────────────────────────────────────────
pa_bull = (bull_pin or bull_eng or (hammer and at_sup) or bull_3bar or
           turtle_long or wick_rej_bull)
pa_bear = (bear_pin or bear_eng or (shoot_star and at_res) or bear_3bar or
           turtle_short or wick_rej_bear)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 08  —  F&O EXPIRY INTELLIGENCE  (NSE India)
// ══════════════════════════════════════════════════════════════════════════════════
// Weekly expiry: Every Thursday (Nifty, BankNifty options)
// Monthly expiry: Last Thursday of the month (when dayofmonth > 22)
is_thursday      = dayofweek == dayofweek.thursday
weekly_expiry    = is_thursday
monthly_expiry   = is_thursday and dayofmonth > 22

expiry_warn      = weekly_expiry or monthly_expiry
expiry_type      = monthly_expiry ? "MONTHLY EXPIRY" : weekly_expiry ? "WEEKLY EXPIRY" : ""

// On expiry days, markets can whipsaw. Raise score threshold automatically.
expiry_sc_add    = expiry_warn ? 1 : 0   // Require 1 extra point on expiry days

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 09  —  DIVERGENCE ENGINE
// ══════════════════════════════════════════════════════════════════════════════════
// Pivot highs/lows for divergence reference
rsi_ph  = ta.pivothigh(rsi_val,   div_lb, div_lb)
rsi_pl  = ta.pivotlow(rsi_val,    div_lb, div_lb)
prc_ph  = ta.pivothigh(high,      div_lb, div_lb)
prc_pl  = ta.pivotlow(low,        div_lb, div_lb)
mcd_ph  = ta.pivothigh(macd_line, div_lb, div_lb)
mcd_pl  = ta.pivotlow(macd_line,  div_lb, div_lb)

// Regular Bearish: Price HH, RSI LH
reg_bear_div = (show_rsi_d and not na(prc_ph) and
                prc_ph > ta.valuewhen(not na(prc_ph), prc_ph, 1) and
                rsi_val[div_lb] < ta.valuewhen(not na(rsi_ph), rsi_ph, 1))

// Regular Bullish: Price LL, RSI HL
reg_bull_div = (show_rsi_d and not na(prc_pl) and
                prc_pl < ta.valuewhen(not na(prc_pl), prc_pl, 1) and
                rsi_val[div_lb] > ta.valuewhen(not na(rsi_pl), rsi_pl, 1))

// Hidden Bullish (uptrend continuation): Price HL, RSI LL → buy
hid_bull_div = (show_hid_d and not na(prc_pl) and
                prc_pl > ta.valuewhen(not na(prc_pl), prc_pl, 1) and
                rsi_val[div_lb] < ta.valuewhen(not na(rsi_pl), rsi_pl, 1))

// Hidden Bearish (downtrend continuation): Price LH, RSI HH → sell
hid_bear_div = (show_hid_d and not na(prc_ph) and
                prc_ph < ta.valuewhen(not na(prc_ph), prc_ph, 1) and
                rsi_val[div_lb] > ta.valuewhen(not na(rsi_ph), rsi_ph, 1))

// MACD Divergence
macd_bull_div = (show_macd_d and not na(prc_pl) and not na(mcd_pl) and
                 prc_pl < ta.valuewhen(not na(prc_pl), prc_pl, 1) and
                 mcd_pl > ta.valuewhen(not na(mcd_pl), mcd_pl, 1))
macd_bear_div = (show_macd_d and not na(prc_ph) and not na(mcd_ph) and
                 prc_ph > ta.valuewhen(not na(prc_ph), prc_ph, 1) and
                 mcd_ph < ta.valuewhen(not na(mcd_ph), mcd_ph, 1))

any_bull_div = reg_bull_div or hid_bull_div or macd_bull_div
any_bear_div = reg_bear_div or hid_bear_div or macd_bear_div

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 10  —  FAKE BREAK SHIELD  (8 conditions)
// ══════════════════════════════════════════════════════════════════════════════════
vol_ok_for_break = not use_vol_gate or volume > vol_ma  // Must have vol to be real

// Resistance fakes (previous bar)
fk_r1  = high[1] > r1     and close[1] < r1     and not vol_ok_for_break[1]
fk_r2  = high[1] > r2     and close[1] < r2     and not vol_ok_for_break[1]
fk_cph = high[1] > cpr_hi and close[1] < cpr_hi and not vol_ok_for_break[1]
fk_orh = not na(or_hi) and high[1] > or_hi and close[1] < or_hi and not vol_ok_for_break[1]

// Support fakes (previous bar)
fk_s1  = low[1]  < s1     and close[1] > s1     and not vol_ok_for_break[1]
fk_s2  = low[1]  < s2     and close[1] > s2     and not vol_ok_for_break[1]
fk_cpl = low[1]  < cpr_lo and close[1] > cpr_lo and not vol_ok_for_break[1]
fk_orl = not na(or_lo) and low[1] < or_lo and close[1] > or_lo and not vol_ok_for_break[1]

// Turtle Soup acts as its own fake break by definition
fk_ts_up = turtle_short    // Price broke above N-bar high then reversed
fk_ts_dn = turtle_long     // Price broke below N-bar low then reversed

fake_up   = (fk_r1 or fk_r2 or fk_cph or fk_orh or fk_ts_up) and show_fake
fake_down = (fk_s1 or fk_s2 or fk_cpl or fk_orl or fk_ts_dn) and show_fake

no_fake_bull = not (fk_r1 or fk_r2 or fk_cph or fk_orh)
no_fake_bear = not (fk_s1 or fk_s2 or fk_cpl or fk_orl)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 11  —  15-FACTOR CONFLUENCE SCORING ENGINE
// ══════════════════════════════════════════════════════════════════════════════════

// ─── LONG SCORE (max 15) ────────────────────────────────────────────────────────
sl_01 = htf_bull      ? 1 : 0   // 01 HTF trend bullish
sl_02 = ema_bull      ? 1 : 0   // 02 EMA ribbon bullish
sl_03 = st_bull       ? 1 : 0   // 03 Supertrend bullish
sl_04 = ms_bull       ? 1 : 0   // 04 Market structure HH+HL
sl_05 = vwap_bull     ? 1 : 0   // 05 Price above VWAP
sl_06 = at_sup        ? 1 : 0   // 06 At key support level
sl_07 = pa_bull       ? 1 : 0   // 07 Bullish PA pattern
sl_08 = vol_surge     ? 1 : 0   // 08 Volume confirmed
sl_09 = (adx_ok and adx_bull) ? 1 : 0   // 09 ADX bullish
sl_10 = sqz_mom_bull  ? 1 : 0   // 10 Squeeze fired bullish
sl_11 = any_bull_div  ? 1 : 0   // 11 Divergence bullish
sl_12 = near_bull_ob  ? 1 : 0   // 12 Near bull order block
sl_13 = near_bull_fvg ? 1 : 0   // 13 Near bullish FVG
sl_14 = turtle_long   ? 1 : 0   // 14 Turtle Soup long
sl_15 = (rsi_val < 50 and rsi_buy) ? 1 : 0  // 15 RSI not overbought

score_long = sl_01+sl_02+sl_03+sl_04+sl_05+sl_06+sl_07+sl_08+sl_09+
             sl_10+sl_11+sl_12+sl_13+sl_14+sl_15

// ─── SHORT SCORE (max 15) ───────────────────────────────────────────────────────
ss_01 = htf_bear      ? 1 : 0
ss_02 = ema_bear      ? 1 : 0
ss_03 = st_bear       ? 1 : 0
ss_04 = ms_bear       ? 1 : 0
ss_05 = vwap_bear     ? 1 : 0
ss_06 = at_res        ? 1 : 0
ss_07 = pa_bear       ? 1 : 0
ss_08 = vol_surge     ? 1 : 0
ss_09 = (adx_ok and adx_bear) ? 1 : 0
ss_10 = sqz_mom_bear  ? 1 : 0
ss_11 = any_bear_div  ? 1 : 0
ss_12 = near_bear_ob  ? 1 : 0
ss_13 = near_bear_fvg ? 1 : 0
ss_14 = turtle_short  ? 1 : 0
ss_15 = (rsi_val > 50 and rsi_sell) ? 1 : 0

score_short = ss_01+ss_02+ss_03+ss_04+ss_05+ss_06+ss_07+ss_08+ss_09+
              ss_10+ss_11+ss_12+ss_13+ss_14+ss_15

// ── Signal Tier ──────────────────────────────────────────────────────────────────
tier_l = score_long  >= 10 ? "⭐⭐⭐⭐" : score_long  >= 7 ? "⭐⭐⭐" :
         score_long  >=  5 ? "⭐⭐"     : "⭐"
tier_s = score_short >= 10 ? "⭐⭐⭐⭐" : score_short >= 7 ? "⭐⭐⭐" :
         score_short >=  5 ? "⭐⭐"     : "⭐"

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 12  —  FINAL SIGNAL GENERATION
// ══════════════════════════════════════════════════════════════════════════════════
eff_min  = min_sc + expiry_sc_add   // Raise bar on expiry days
sqz_gate = (not use_sqz_g) or sqz_fire or sqz_mom_bull or sqz_mom_bear

long_sig  = (show_sigs and score_long  >= eff_min and pa_bull and
             no_fake_bull and session_ok and
             ((not use_adx_g) or adx_ok) and
             ((not use_rsi_g) or rsi_buy) and sqz_gate)

short_sig = (show_sigs and score_short >= eff_min and pa_bear and
             no_fake_bear and session_ok and
             ((not use_adx_g) or adx_ok) and
             ((not use_rsi_g) or rsi_sell) and sqz_gate)

// God Mode (highest quality): Score 10+ on both TF alignment
god_long  = long_sig  and score_long  >= 10
god_short = short_sig and score_short >= 10

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 13  —  DEMAND / SUPPLY ZONE BOXES
// ══════════════════════════════════════════════════════════════════════════════════
var box[] demand_bx = array.new_box()
var box[] supply_bx = array.new_box()

if long_sig and show_zones
    b = box.new(bar_index - 1, low - atr * 0.1, bar_index + 45,
                low + atr * 0.4,
                bgcolor=color.new(c_bull, 87),
                border_color=color.new(c_bull, 40), border_width=1)
    array.push(demand_bx, b)
    if array.size(demand_bx) > 5
        box.delete(array.shift(demand_bx))

if short_sig and show_zones
    b = box.new(bar_index - 1, high - atr * 0.4, bar_index + 45,
                high + atr * 0.1,
                bgcolor=color.new(c_bear, 87),
                border_color=color.new(c_bear, 40), border_width=1)
    array.push(supply_bx, b)
    if array.size(supply_bx) > 5
        box.delete(array.shift(supply_bx))

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 14  —  PLOTS & VISUALISATION
// ══════════════════════════════════════════════════════════════════════════════════

// ── EMA Ribbon ───────────────────────────────────────────────────────────────────
plot(show_ema ? ema9   : na, "EMA 9",   color=color.new(#FF9800, 10), linewidth=1)
plot(show_ema ? ema21  : na, "EMA 21",  color=color.new(#2196F3, 10), linewidth=1)
plot(show_ema ? ema50  : na, "EMA 50",  color=color.new(#9C27B0, 0),  linewidth=2)
plot(show_ema ? ema200 : na, "EMA 200", color=color.new(#F44336, 0),  linewidth=2)

// ── Supertrend ────────────────────────────────────────────────────────────────────
st_col = st_bull ? color.new(c_bull, 20) : color.new(c_bear, 20)
plot(show_st ? st_line : na, "Supertrend", color=st_col, linewidth=2)

// ── VWAP ─────────────────────────────────────────────────────────────────────────
plot(show_vwap ? vwap_val : na, "VWAP",     color=color.new(#FFD600, 0),  linewidth=2)
plot(show_vwap ? vwap_u1  : na, "VWAP+1σ", color=color.new(#4FC3F7, 50), linewidth=1)
plot(show_vwap ? vwap_l1  : na, "VWAP-1σ", color=color.new(#4FC3F7, 50), linewidth=1)
plot(show_vwap ? vwap_u2  : na, "VWAP+2σ", color=color.new(#E91E63, 55), linewidth=1, style=plot.style_circles)
plot(show_vwap ? vwap_l2  : na, "VWAP-2σ", color=color.new(#E91E63, 55), linewidth=1, style=plot.style_circles)

// ── CPR ──────────────────────────────────────────────────────────────────────────
plot(show_cpr ? cpr_hi  : na, "CPR Hi",  color=color.new(#4CAF50, 0), linewidth=1, style=plot.style_stepline)
plot(show_cpr ? cpr_piv : na, "CPR Piv", color=color.new(#FF9800, 0), linewidth=2, style=plot.style_stepline)
plot(show_cpr ? cpr_lo  : na, "CPR Lo",  color=color.new(#F44336, 0), linewidth=1, style=plot.style_stepline)

// ── Pivots ────────────────────────────────────────────────────────────────────────
plot(show_piv ? r3 : na, "R3", color=color.new(#B71C1C, 0),  linewidth=1, style=plot.style_circles)
plot(show_piv ? r2 : na, "R2", color=color.new(#E53935, 15), linewidth=1, style=plot.style_circles)
plot(show_piv ? r1 : na, "R1", color=color.new(#EF9A9A, 0),  linewidth=1, style=plot.style_circles)
plot(show_piv ? pp : na, "PP", color=color.new(#FFD600, 0),  linewidth=2, style=plot.style_circles)
plot(show_piv ? s1 : na, "S1", color=color.new(#A5D6A7, 0),  linewidth=1, style=plot.style_circles)
plot(show_piv ? s2 : na, "S2", color=color.new(#4CAF50, 15), linewidth=1, style=plot.style_circles)
plot(show_piv ? s3 : na, "S3", color=color.new(#1B5E20, 0),  linewidth=1, style=plot.style_circles)

// ── Opening Range ─────────────────────────────────────────────────────────────────
plot(show_or and not na(or_hi) ? or_hi : na, "ORH", color=color.new(#00BCD4, 0), linewidth=1, style=plot.style_stepline)
plot(show_or and not na(or_lo) ? or_lo : na, "ORL", color=color.new(#FF5722, 0), linewidth=1, style=plot.style_stepline)

// ── Session POC ───────────────────────────────────────────────────────────────────
plot(show_poc and not na(sess_poc) ? sess_poc : na, "POC",
     color=color.new(#FF6F00, 0), linewidth=2, style=plot.style_circles)

// ── Candle Coloring ───────────────────────────────────────────────────────────────
barcolor(ema_bull and st_bull ? color.new(#00C853, 65) :
         ema_bear and st_bear ? color.new(#FF1744, 65) : na)

// ── Background ────────────────────────────────────────────────────────────────────
bgcolor(in_or                          ? color.new(#FFF176, 92) : na, title="Opening 15-min")
bgcolor(sqz_on                         ? color.new(#7B1FA2, 97) : na, title="Squeeze ON")
bgcolor(expiry_warn and in_market      ? color.new(#FF6F00, 95) : na, title="Expiry Day")
bgcolor(htf_bull and st_bull and ema_bull ? color.new(#00C853, 97) : na, title="Bull Session")
bgcolor(htf_bear and st_bear and ema_bear ? color.new(#FF1744, 97) : na, title="Bear Session")

// ── Squeeze Dots ─────────────────────────────────────────────────────────────────
plotshape(show_sqz and sqz_on  and not sqz_on[1], "Squeeze ON",
          style=shape.circle, location=location.belowbar,
          color=color.new(#9C27B0, 30), size=size.tiny)
plotshape(show_sqz and sqz_fire and sqz_mom > 0,  "Squeeze Fire Bull",
          style=shape.diamond, location=location.belowbar,
          color=color.new(#00C853, 20), size=size.small)
plotshape(show_sqz and sqz_fire and sqz_mom < 0,  "Squeeze Fire Bear",
          style=shape.diamond, location=location.abovebar,
          color=color.new(#FF1744, 20), size=size.small)

// ── Structure ────────────────────────────────────────────────────────────────────
plotshape(show_str and not na(s_ph), "PH",
          style=shape.triangledown, location=location.abovebar,
          color=color.new(c_bear, 30), size=size.tiny, offset=-swing_lb)
plotshape(show_str and not na(s_pl), "PL",
          style=shape.triangleup, location=location.belowbar,
          color=color.new(c_bull, 30), size=size.tiny, offset=-swing_lb)

// ── Volume Climax ─────────────────────────────────────────────────────────────────
plotshape(vol_climax, "Climax Vol", style=shape.square,
          location=location.belowbar, color=color.new(#FF9800, 50), size=size.tiny)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 15  —  SIGNAL & SMC LABELS
// ══════════════════════════════════════════════════════════════════════════════════

// ── Level Labels (last bar) ───────────────────────────────────────────────────────
var label[] lev_lbls = array.new_label()

if barstate.islast
    for lb in lev_lbls
        label.delete(lb)
    array.clear(lev_lbls)
    off = bar_index + 3

    if show_piv
        array.push(lev_lbls, label.new(off, r3, "  R3 " + str.tostring(math.round(r3,1)), style=label.style_label_left, color=color.new(#B71C1C,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, r2, "  R2 " + str.tostring(math.round(r2,1)), style=label.style_label_left, color=color.new(#E53935,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, r1, "  R1 " + str.tostring(math.round(r1,1)), style=label.style_label_left, color=color.new(#EF9A9A,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, pp, "  PP " + str.tostring(math.round(pp,1)), style=label.style_label_left, color=color.new(#FF9800,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, s1, "  S1 " + str.tostring(math.round(s1,1)), style=label.style_label_left, color=color.new(#A5D6A7,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, s2, "  S2 " + str.tostring(math.round(s2,1)), style=label.style_label_left, color=color.new(#4CAF50,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, s3, "  S3 " + str.tostring(math.round(s3,1)), style=label.style_label_left, color=color.new(#1B5E20,75), textcolor=color.white, size=size.small))
    if show_cpr
        array.push(lev_lbls, label.new(off, cpr_hi,  "  CPR↑ " + str.tostring(math.round(cpr_hi,1)),  style=label.style_label_left, color=color.new(#4CAF50,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, cpr_piv, "  CPR  " + str.tostring(math.round(cpr_piv,1)), style=label.style_label_left, color=color.new(#FF9800,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, cpr_lo,  "  CPR↓ " + str.tostring(math.round(cpr_lo,1)),  style=label.style_label_left, color=color.new(#F44336,75), textcolor=color.white, size=size.small))
    if show_vwap
        array.push(lev_lbls, label.new(off, vwap_val, "  VWAP " + str.tostring(math.round(vwap_val,1)), style=label.style_label_left, color=color.new(#F9A825,75), textcolor=color.white, size=size.small))
    if show_poc and not na(sess_poc)
        array.push(lev_lbls, label.new(off, sess_poc, "  POC  " + str.tostring(math.round(sess_poc,1)), style=label.style_label_left, color=color.new(#FF6F00,75), textcolor=color.white, size=size.small))
    if show_or and not na(or_hi)
        array.push(lev_lbls, label.new(off, or_hi, "  ORH " + str.tostring(math.round(or_hi,1)), style=label.style_label_left, color=color.new(#00BCD4,75), textcolor=color.white, size=size.small))
        array.push(lev_lbls, label.new(off, or_lo, "  ORL " + str.tostring(math.round(or_lo,1)), style=label.style_label_left, color=color.new(#FF5722,75), textcolor=color.white, size=size.small))

// ── Long Signal Label ─────────────────────────────────────────────────────────────
if long_sig
    sl_l   = low  - atr * sl_m
    tp1_l  = close + atr * tp1_m
    tp2_l  = close + atr * tp2_m
    tp3_l  = close + atr * tp3_m
    rr_v   = math.round((tp1_l - close) / (close - sl_l), 1)
    bg_col = god_long ? color.new(#FFD600, 0) : c_bull
    txt    = (god_long ? "✦ GOD MODE LONG ✦" : "▲ LONG") + "  " + tier_l + "\n" +
             "Score  " + str.tostring(score_long) + " / 15\n" +
             "Entry  " + str.tostring(math.round(close,1)) + "\n" +
             "SL      " + str.tostring(math.round(sl_l,1))  + "\n" +
             "TP1    " + str.tostring(math.round(tp1_l,1)) + "\n" +
             "TP2    " + str.tostring(math.round(tp2_l,1)) + "\n" +
             "TP3    " + str.tostring(math.round(tp3_l,1)) + "\n" +
             "R:R    1 : " + str.tostring(rr_v)
    label.new(bar_index, low - atr * 0.7, txt,
              style=label.style_label_up, color=bg_col,
              textcolor=god_long ? color.black : color.white, size=size.normal)

// ── Short Signal Label ────────────────────────────────────────────────────────────
if short_sig
    sl_s   = high + atr * sl_m
    tp1_s  = close - atr * tp1_m
    tp2_s  = close - atr * tp2_m
    tp3_s  = close - atr * tp3_m
    rr_v   = math.round((close - tp1_s) / (sl_s - close), 1)
    bg_col = god_short ? color.new(#FFD600, 0) : c_bear
    txt    = (god_short ? "✦ GOD MODE SHORT ✦" : "▼ SHORT") + "  " + tier_s + "\n" +
             "Score  " + str.tostring(score_short) + " / 15\n" +
             "Entry  " + str.tostring(math.round(close,1)) + "\n" +
             "SL      " + str.tostring(math.round(sl_s,1))  + "\n" +
             "TP1    " + str.tostring(math.round(tp1_s,1)) + "\n" +
             "TP2    " + str.tostring(math.round(tp2_s,1)) + "\n" +
             "TP3    " + str.tostring(math.round(tp3_s,1)) + "\n" +
             "R:R    1 : " + str.tostring(rr_v)
    label.new(bar_index, high + atr * 0.7, txt,
              style=label.style_label_down, color=bg_col,
              textcolor=god_short ? color.black : color.white, size=size.normal)

// ── OB Labels ─────────────────────────────────────────────────────────────────────
if bull_ob_fire and show_ob
    label.new(bar_index - 1, math.min(open[1], close[1]) - atr * 0.25,
              "Bull OB", style=label.style_none,
              textcolor=color.new(#00C853, 10), size=size.tiny)

if bear_ob_fire and show_ob
    label.new(bar_index - 1, math.max(open[1], close[1]) + atr * 0.25,
              "Bear OB", style=label.style_none,
              textcolor=color.new(#FF1744, 10), size=size.tiny)

// ── FVG Labels ────────────────────────────────────────────────────────────────────
if bull_fvg_cond and show_fvg
    label.new(bar_index, high[2] + (low - high[2]) / 2,
              "FVG", style=label.style_none,
              textcolor=color.new(#00BCD4, 10), size=size.tiny)

if bear_fvg_cond and show_fvg
    label.new(bar_index, high + (low[2] - high) / 2,
              "FVG", style=label.style_none,
              textcolor=color.new(#FF9800, 10), size=size.tiny)

// ── BOS / ChoCH Labels ────────────────────────────────────────────────────────────
if show_bos
    if choch_bull
        label.new(bar_index, high + atr * 0.5, "ChoCH ▲",
                  style=label.style_label_down,
                  color=color.new(#00C853, 30), textcolor=color.white, size=size.small)
    else if bos_bull
        label.new(bar_index, high + atr * 0.5, "BOS ▲",
                  style=label.style_label_down,
                  color=color.new(#4CAF50, 50), textcolor=color.white, size=size.small)
    if choch_bear
        label.new(bar_index, low - atr * 0.5, "ChoCH ▼",
                  style=label.style_label_up,
                  color=color.new(#FF1744, 30), textcolor=color.white, size=size.small)
    else if bos_bear
        label.new(bar_index, low - atr * 0.5, "BOS ▼",
                  style=label.style_label_up,
                  color=color.new(#F44336, 50), textcolor=color.white, size=size.small)

// ── Liquidity Labels ─────────────────────────────────────────────────────────────
if show_liq
    if liq_buy_side
        label.new(bar_index, high + atr * 0.2, "BSL",
                  style=label.style_none,
                  textcolor=color.new(#FFD600, 20), size=size.tiny)
    if liq_sell_side
        label.new(bar_index, low - atr * 0.2, "SSL",
                  style=label.style_none,
                  textcolor=color.new(#FFD600, 20), size=size.tiny)

// ── Fake Break Labels ─────────────────────────────────────────────────────────────
if fake_up
    label.new(bar_index, high + atr * 0.4,
              "⚠ FAKE BREAK UP  →  SHORT",
              style=label.style_label_down,
              color=c_warn, textcolor=color.white, size=size.small)

if fake_down
    label.new(bar_index, low - atr * 0.4,
              "⚠ FAKE BREAK DOWN  →  LONG",
              style=label.style_label_up,
              color=c_warn, textcolor=color.white, size=size.small)

// ── Divergence Labels ─────────────────────────────────────────────────────────────
if reg_bull_div
    label.new(bar_index - div_lb, low[div_lb]  - atr, "↗ RSI DIV", style=label.style_label_up,   color=color.new(#00BCD4,25), textcolor=color.white, size=size.tiny)
if hid_bull_div
    label.new(bar_index - div_lb, low[div_lb]  - atr, "↗ HID DIV", style=label.style_label_up,   color=color.new(#4CAF50,25), textcolor=color.white, size=size.tiny)
if reg_bear_div
    label.new(bar_index - div_lb, high[div_lb] + atr, "↘ RSI DIV", style=label.style_label_down, color=color.new(#E91E63,25), textcolor=color.white, size=size.tiny)
if hid_bear_div
    label.new(bar_index - div_lb, high[div_lb] + atr, "↘ HID DIV", style=label.style_label_down, color=color.new(#9C27B0,25), textcolor=color.white, size=size.tiny)

// ── Turtle Soup Labels ────────────────────────────────────────────────────────────
if turtle_long and show_turtle
    label.new(bar_index, low - atr * 0.35, "🐢 Turtle Long", style=label.style_label_up,
              color=color.new(#00C853, 30), textcolor=color.white, size=size.tiny)
if turtle_short and show_turtle
    label.new(bar_index, high + atr * 0.35, "🐢 Turtle Short", style=label.style_label_down,
              color=color.new(#FF1744, 30), textcolor=color.white, size=size.tiny)

// ── 3-Bar Reversal Labels ─────────────────────────────────────────────────────────
if bull_3bar and show_3bar
    label.new(bar_index, low - atr * 0.2, "3BR ▲", style=label.style_none,
              textcolor=color.new(c_bull, 20), size=size.tiny)
if bear_3bar and show_3bar
    label.new(bar_index, high + atr * 0.2, "3BR ▼", style=label.style_none,
              textcolor=color.new(c_bear, 20), size=size.tiny)

// ── Market Structure Labels ───────────────────────────────────────────────────────
if show_str and not na(s_ph)
    s_txt = ms_hh ? "HH" : ms_lh ? "LH" : "PH"
    label.new(bar_index - swing_lb, high[swing_lb] + atr * 0.4, s_txt,
              style=label.style_none, textcolor=ms_hh ? c_bull : c_bear, size=size.small)

if show_str and not na(s_pl)
    s_txt = ms_hl ? "HL" : ms_ll ? "LL" : "PL"
    label.new(bar_index - swing_lb, low[swing_lb] - atr * 0.4, s_txt,
              style=label.style_none, textcolor=ms_hl ? c_bull : c_bear, size=size.small)

// ── Expiry Warning ────────────────────────────────────────────────────────────────
if (expiry_warn and in_market and ta.change(time("D")) == 0 and
    hour == 9 and minute == 15)
    label.new(bar_index, high + atr * 1.5,
              "📅 " + expiry_type + "\nRaise threshold · Expect whipsaw",
              style=label.style_label_down,
              color=c_warn, textcolor=color.white, size=size.normal)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 16  —  LIVE DASHBOARD  (26 cells)
// ══════════════════════════════════════════════════════════════════════════════════
var table dash = table.new(position.top_right, 2, 20,
    bgcolor      = color.new(#050D1A, 82),
    border_color = color.new(#1565C0, 45),
    border_width = 1,
    frame_color  = color.new(#0D47A1, 35),
    frame_width  = 2)

if barstate.islast and show_dash
    c_on   = color.new(#00C853, 0)
    c_off  = color.new(#FF1744, 0)
    c_neu  = color.new(#90A4AE, 0)
    c_hdr  = color.new(#FFD600, 0)
    c_txt  = color.new(#CFD8DC, 0)
    c_smc  = color.new(#CE93D8, 0)
    c_vol  = color.new(#80CBC4, 0)

    trend_s  = ema_bull and st_bull ? "BULL ▲" : ema_bear and st_bear ? "BEAR ▼" : "MIXED ↔"
    trend_c  = ema_bull and st_bull ? c_on : ema_bear and st_bear ? c_off : c_neu
    htf_s    = htf_bull ? "BULL ▲" : htf_bear ? "BEAR ▼" : "MIXED ↔"
    htf_c    = htf_bull ? c_on : htf_bear ? c_off : c_neu
    ms_s     = ms_bull ? "HH+HL ▲" : ms_bear ? "LH+LL ▼" : "MIXED ↔"
    ms_c     = ms_bull ? c_on : ms_bear ? c_off : c_neu
    ph_s     = market_phase
    ph_c     = phase_trend ? c_on : phase_vol ? color.new(#FF9800,0) : c_neu
    sqz_s    = sqz_on ? "ON  ●" : sqz_fire ? "FIRED ⚡" : "OFF  ○"
    sqz_c    = sqz_on ? color.new(#CE93D8,0) : sqz_fire ? c_on : c_neu
    cpr_s    = cpr_narrow ? "NARROW → Trend" : "WIDE → Range"
    vwap_s   = vwap_bull ? "ABOVE  ✔" : "BELOW  ✘"
    rsi_s    = str.tostring(math.round(rsi_val,1)) + (rsi_val >= rsi_ob ? "  OB" : rsi_val <= rsi_os ? "  OS" : "  OK")
    adx_s    = str.tostring(math.round(adx_val,1)) + (adx_ok ? " ✔" : " ✘")
    vol_s    = vol_climax ? "CLIMAX ⚡⚡" : vol_surge ? "SURGE  ⚡" : "Normal"
    vol_c    = vol_climax ? c_hdr : vol_surge ? color.new(#80CBC4,0) : c_neu
    div_s    = any_bull_div ? "BULL DIV ↗" : any_bear_div ? "BEAR DIV ↘" : "None"
    div_c    = any_bull_div ? c_on : any_bear_div ? c_off : c_neu
    smc_bull_s = (near_bull_ob ? "OB" : "") + (near_bull_fvg ? " FVG" : "") + (bos_bull or choch_bull ? " BOS" : "")
    smc_bear_s = (near_bear_ob ? "OB" : "") + (near_bear_fvg ? " FVG" : "") + (bos_bear or choch_bear ? " BOS" : "")
    exp_s    = expiry_warn ? "⚠ " + expiry_type : "None"
    exp_c    = expiry_warn ? c_warn : c_neu
    sc_l_s   = str.tostring(score_long)  + " / 15  " + tier_l
    sc_s_s   = str.tostring(score_short) + " / 15  " + tier_s
    sc_l_c   = score_long  >= 10 ? c_hdr : score_long  >= 7 ? c_on : c_neu
    sc_s_c   = score_short >= 10 ? c_hdr : score_short >= 7 ? c_off : c_neu

    // Header
    table.cell(dash, 0, 0,  "PT·GOD·MODE",   text_color=c_hdr,   text_size=size.normal, bgcolor=color.new(#0D47A1,75))
    table.cell(dash, 1, 0,  "DASHBOARD",      text_color=c_hdr,   text_size=size.normal, bgcolor=color.new(#0D47A1,75))
    // Trend Block
    table.cell(dash, 0, 1,  "Trend (LTF)",    text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 1,  trend_s,          text_color=trend_c, text_size=size.small)
    table.cell(dash, 0, 2,  "HTF (" + htf_tf + "m)", text_color=c_txt, text_size=size.small)
    table.cell(dash, 1, 2,  htf_s,            text_color=htf_c,   text_size=size.small)
    table.cell(dash, 0, 3,  "Supertrend",      text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 3,  st_bull ? "BULL ▲" : "BEAR ▼", text_color=st_bull ? c_on : c_off, text_size=size.small)
    table.cell(dash, 0, 4,  "Structure",       text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 4,  ms_s,             text_color=ms_c,    text_size=size.small)
    table.cell(dash, 0, 5,  "Market Phase",    text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 5,  ph_s,             text_color=ph_c,    text_size=size.small)
    // S/R Block
    table.cell(dash, 0, 6,  "vs VWAP",         text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 6,  vwap_s,           text_color=vwap_bull ? c_on : c_off, text_size=size.small)
    table.cell(dash, 0, 7,  "CPR Type",        text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 7,  cpr_s,            text_color=c_hdr,   text_size=size.small)
    table.cell(dash, 0, 8,  "ATR",             text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 8,  str.tostring(math.round(atr,1)), text_color=color.new(#90CAF9,0), text_size=size.small)
    // Momentum Block
    table.cell(dash, 0, 9,  "ADX",             text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 9,  adx_s,            text_color=adx_ok ? c_on : c_off, text_size=size.small)
    table.cell(dash, 0, 10, "RSI",             text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 10, rsi_s,            text_color=rsi_val >= rsi_ob ? c_off : rsi_val <= rsi_os ? c_on : c_neu, text_size=size.small)
    table.cell(dash, 0, 11, "Squeeze",         text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 11, sqz_s,            text_color=sqz_c,   text_size=size.small)
    // Volume Block
    table.cell(dash, 0, 12, "Volume",          text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 12, vol_s,            text_color=vol_c,   text_size=size.small)
    table.cell(dash, 0, 13, "Divergence",      text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 13, div_s,            text_color=div_c,   text_size=size.small)
    // SMC Block
    table.cell(dash, 0, 14, "SMC Bull",        text_color=c_smc,   text_size=size.small)
    table.cell(dash, 1, 14, smc_bull_s == "" ? "—" : smc_bull_s, text_color=str.length(smc_bull_s) > 0 ? c_on : c_neu, text_size=size.small)
    table.cell(dash, 0, 15, "SMC Bear",        text_color=c_smc,   text_size=size.small)
    table.cell(dash, 1, 15, smc_bear_s == "" ? "—" : smc_bear_s, text_color=str.length(smc_bear_s) > 0 ? c_off : c_neu, text_size=size.small)
    // F&O Block
    table.cell(dash, 0, 16, "F&O Expiry",      text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 16, exp_s,            text_color=exp_c,   text_size=size.small)
    // Score Block
    table.cell(dash, 0, 17, "Long Score",      text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 17, sc_l_s,           text_color=sc_l_c,  text_size=size.small)
    table.cell(dash, 0, 18, "Short Score",     text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 18, sc_s_s,           text_color=sc_s_c,  text_size=size.small)
    table.cell(dash, 0, 19, "Min Score",       text_color=c_txt,   text_size=size.small)
    table.cell(dash, 1, 19, str.tostring(eff_min) + (expiry_warn ? " +1 expiry" : ""), text_color=c_hdr, text_size=size.small)

// ══════════════════════════════════════════════════════════════════════════════════
//  MODULE 17  —  ALERT SUITE  (12 conditions)
// ══════════════════════════════════════════════════════════════════════════════════

alertcondition(long_sig,
    "🟢 GOD MODE — Long",
    "GOD MODE ▲ LONG on {{ticker}} @ {{close}} | Score {{plot_0}}/15 | TF: {{interval}}")

alertcondition(short_sig,
    "🔴 GOD MODE — Short",
    "GOD MODE ▼ SHORT on {{ticker}} @ {{close}} | Score {{plot_0}}/15 | TF: {{interval}}")

alertcondition(god_long,
    "✦ GOD MODE — God-Level LONG  (Score 10+)",
    "GOD MODE ✦ LONG on {{ticker}} @ {{close}} | SCORE 10+/15 | MAXIMUM CONFIDENCE")

alertcondition(god_short,
    "✦ GOD MODE — God-Level SHORT (Score 10+)",
    "GOD MODE ✦ SHORT on {{ticker}} @ {{close}} | SCORE 10+/15 | MAXIMUM CONFIDENCE")

alertcondition(fake_up,
    "⚠️ GOD MODE — Fake Breakout UP",
    "GOD MODE ⚠ Fake Break UP on {{ticker}} @ {{close}} → SHORT setup")

alertcondition(fake_down,
    "⚠️ GOD MODE — Fake Breakdown DOWN",
    "GOD MODE ⚠ Fake Break DOWN on {{ticker}} @ {{close}} → LONG setup")

alertcondition(sqz_mom_bull,
    "⚡ GOD MODE — Squeeze Fired BULL",
    "GOD MODE ⚡ Squeeze BULL FIRE on {{ticker}} @ {{close}}")

alertcondition(sqz_mom_bear,
    "⚡ GOD MODE — Squeeze Fired BEAR",
    "GOD MODE ⚡ Squeeze BEAR FIRE on {{ticker}} @ {{close}}")

alertcondition(choch_bull or bos_bull,
    "🔵 GOD MODE — BOS / ChoCH Bullish",
    "GOD MODE BOS/ChoCH ▲ on {{ticker}} @ {{close}} — Structural reversal up")

alertcondition(choch_bear or bos_bear,
    "🔴 GOD MODE — BOS / ChoCH Bearish",
    "GOD MODE BOS/ChoCH ▼ on {{ticker}} @ {{close}} — Structural reversal down")

alertcondition(weekly_expiry and in_market,
    "📅 GOD MODE — Weekly F&O Expiry (Thursday)",
    "GOD MODE 📅 WEEKLY EXPIRY on {{ticker}} — Raise score threshold, expect whipsaw")

alertcondition(monthly_expiry and in_market,
    "📅 GOD MODE — Monthly F&O Expiry (Last Thursday)",
    "GOD MODE 📅 MONTHLY EXPIRY on {{ticker}} — Raise score threshold, expect whipsaw")
alertcondition(any_bull_div or any_bear_div,
    "🔄 GOD MODE — Divergence Detected",
    "GOD MODE DIVERGENCE on {{ticker}} @ {{close}} — Check dashboard for type")

// ══════════════════════════════════════════════════════════════════════════════════
//  USAGE  ·  READ BEFORE TRADING
//  ──────────────────────────────────────────────────────────────────────────────
//  RECOMMENDED SETTINGS  (Nifty / BankNifty / Sensex):
//  • 5-min  chart  →  HTF = 15, Min Score = 5,  SL = 1.0× ATR
//  • 15-min chart  →  HTF = 60, Min Score = 6,  SL = 1.2× ATR
//  • 1-hr   chart  →  HTF = D,  Min Score = 7,  SL = 1.5× ATR
//
//  SIGNAL TIERS:
//  ⭐         Score  5–6  →  Small size, strict SL
//  ⭐⭐       Score  7–9  →  Normal size
//  ⭐⭐⭐     Score 10–12 →  Full size, trail to TP3
//  ✦ GOD MODE  Score 13–15 →  Maximum confidence, scale in at TP1
//
//  SMC COLOUR CODE:
//  Green box  = Bullish Order Block (expect bounce here)
//  Red box    = Bearish Order Block (expect rejection here)
//  Cyan box   = Bullish FVG (price should return to fill)
//  Orange box = Bearish FVG
//  BSL label  = Buyside Liquidity (stops above — potential stop hunt up)
//  SSL label  = Sellside Liquidity (stops below — potential stop hunt down)
//
//  BACKGROUND COLOURS:
//  Yellow     = Opening 15-min blackout zone — NO ENTRIES
//  Purple     = Volatility Squeeze ON — explosive move imminent
//  Orange     = F&O Expiry day — reduce size, raise threshold
//  Green/Red  = Confirmed trend sessions
//
//  RISK RULES:
//  1% max capital per trade (non-negotiable)
//  Never move SL against your position
//  On expiry day: use eff_min = min_sc + 1 (automatic)
//  Exit ALL intraday positions before 3:15 PM IST
// ══════════════════════════════════════════════════════════════════════════════════
