var SessionData asiaSess = SessionData.new(na, na, false, na, na)
var SessionData lonSess  = SessionData.new(na, na, false, na, na)
var SessionData nySess   = SessionData.new(na, na, false, na, na)

// VRVP persistent drawing objects
var box[]  vrvpBoxes   = array.new_box()
var line   vrvpPOCLine = na
var label  vrvpLblPOC  = na
var label  vrvpLblVAH  = na
var label  vrvpLblVAL  = na

// HTF OB persistent state
var float htfBullOBH = na, var float htfBullOBL = na
var float htfBearOBH = na, var float htfBearOBL = na
var box   htfBullBox = na, var box   htfBearBox = na

// Pivot Point persistent levels (updated each new period)
var float _ppP  = na
var float _ppR1 = na, var float _ppR2 = na, var float _ppR3 = na, var float _ppR4 = na
var float _ppS1 = na, var float _ppS2 = na, var float _ppS3 = na, var float _ppS4 = na
var line[]  _ppLines  = array.new_line()
var label[] _ppLabels = array.new_label()

// ==========================================================================================================
// █ 5. DYNAMIC ANCHORING & HELPER FUNCTIONS
// ==========================================================================================================

getSize() =>
    dashSize == "Tiny"   ? size.tiny   :
     dashSize == "Small"  ? size.small  :
     dashSize == "Normal" ? size.normal : size.large

isNewDay   = ta.change(time("D"))   != 0
isNewWeek  = ta.change(time("W"))   != 0
isNewMonth = ta.change(time("M"))   != 0

var bool isNewPeriod = false
if timeframe.isintraday
    isNewPeriod := ta.change(time("D")) != 0
else if timeframe.isdaily
    isNewPeriod := ta.change(time("M")) != 0
else
    isNewPeriod := ta.change(time("12M")) != 0

avgVol  = ta.sma(volume, 50)
avgBody = ta.sma(math.abs(close - open), 50)
isHighVol       = volume > (avgVol * 1.5)
isOperatorCandle = (volume > avgVol * 1.8) and (math.abs(close - open) > avgBody * 2)

getMTFRSI(res) => request.security(syminfo.tickerid, res, ta.rsi(close, rsiPeriod))
rsi_curr = ta.rsi(close, rsiPeriod)
rsi_15m  = getMTFRSI("15")
bool rsiBullConfirm = rsi_curr > rsiUpper and rsi_15m > 50
bool rsiBearConfirm = rsi_curr < rsiLower and rsi_15m < 50

getMTFTrend(res) =>
    c = request.security(syminfo.tickerid, res, close)
    ta.ema(c, 9) > ta.ema(c, 21) ? 1 : -1

// ==========================================================================================================
// █ 6. SYNTHETIC RENKO ENGINE
// ==========================================================================================================

string renkoTkr = ticker.renko(syminfo.tickerid, renkoMode, renkoParam)
[rOpen, rClose, rHigh, rLow] = request.security(renkoTkr, timeframe.period, [open, close, high, low])

var int   renkoTrend = 0
var float rRes = na
var float rSup = na
var line  lineRRes = na
var line  lineRSup = na

bool newBrick = rClose != rClose[1]

if newBrick
    if rClose > rOpen
        if renkoTrend == -1
            rSup := rLow[1]
            if showRenkoSR
                line.delete(lineRSup)
                lineRSup := line.new(bar_index, rSup, bar_index + 50, rSup, color=colRenkoSup, style=line.style_dashed, width=2, extend=extend.right)
        renkoTrend := 1
    else if rClose < rOpen
        if renkoTrend == 1
            rRes := rHigh[1]
            if showRenkoSR
                line.delete(lineRRes)
                lineRRes := line.new(bar_index, rRes, bar_index + 50, rRes, color=colRenkoRes, style=line.style_dashed, width=2, extend=extend.right)
        renkoTrend := -1

// ==========================================================================================================
// █ 7. INITIAL BALANCE ENGINE
// ==========================================================================================================

inIBSession = time(timeframe.period, ibSession)
isEndIB     = not inIBSession and inIBSession[1]

if isNewDay
    ibHigh := na, ibLow := na, ibMid := na, ibLocked := false

if inIBSession
    ibHigh := na(ibHigh) ? high : math.max(ibHigh, high)
    ibLow  := na(ibLow)  ? low  : math.min(ibLow,  low)

var line lineIBH    = na, var line lineIBL    = na, var line lineIBMid  = na
var line lineIBExt1H= na, var line lineIBExt1L= na, var line lineIBExt2H= na, var line lineIBExt2L= na

if isEndIB
    ibLocked := true
    ibMid := ibLow + ((ibHigh - ibLow) / 2)
    float ibRange = ibHigh - ibLow

    if showIB
        lineIBH   := line.new(bar_index, ibHigh, bar_index + 10, ibHigh, color=colIBHigh, style=line.style_dashed, extend=extend.right)
        lineIBL   := line.new(bar_index, ibLow,  bar_index + 10, ibLow,  color=colIBLow,  style=line.style_dashed, extend=extend.right)
        lineIBMid := line.new(bar_index, ibMid,  bar_index + 10, ibMid,  color=color.gray, style=line.style_dotted, extend=extend.right)
    if showIBExt
        lineIBExt1H := line.new(bar_index, ibHigh + (ibRange * 0.5), bar_index + 10, ibHigh + (ibRange * 0.5), color=colIBExt, style=line.style_dotted, extend=extend.right)
        lineIBExt1L := line.new(bar_index, ibLow  - (ibRange * 0.5), bar_index + 10, ibLow  - (ibRange * 0.5), color=colIBExt, style=line.style_dotted, extend=extend.right)
        lineIBExt2H := line.new(bar_index, ibHigh + (ibRange * 1.0), bar_index + 10, ibHigh + (ibRange * 1.0), color=colIBExt, style=line.style_dotted, extend=extend.right)
        lineIBExt2L := line.new(bar_index, ibLow  - (ibRange * 1.0), bar_index + 10, ibLow  - (ibRange * 1.0), color=colIBExt, style=line.style_dotted, extend=extend.right)

// ==========================================================================================================
// █ 8. SESSION KILLZONES & LIQUIDITY
// ==========================================================================================================

inIndian = time(timeframe.period, kzIndian)
inAsian  = time(timeframe.period, kzAsian)
inLondon = time(timeframe.period, kzLondon)
inNY     = time(timeframe.period, kzNY)

bgcolor(showSessions and inIndian ? colKZIndian : na, title="Indian Killzone")
bgcolor(showSessions and inAsian  ? colKZAsian  : na, title="Asian Killzone")
bgcolor(showSessions and inLondon ? colKZLondon : na, title="London Killzone")
bgcolor(showSessions and inNY     ? colKZNY     : na, title="NY Killzone")

if inAsian and not inAsian[1]
    asiaSess.sHigh := high, asiaSess.sLow := low, asiaSess.isActive := true
else if inAsian
    asiaSess.sHigh := math.max(asiaSess.sHigh, high), asiaSess.sLow := math.min(asiaSess.sLow, low)
else if not inAsian and inAsian[1]
    asiaSess.isActive := false
    if drawSessionLiq
        asiaSess.lineHigh := line.new(bar_index, asiaSess.sHigh, bar_index + 10, asiaSess.sHigh, color=colKZAsian, style=line.style_solid, width=1, extend=extend.right)
        asiaSess.lineLow  := line.new(bar_index, asiaSess.sLow,  bar_index + 10, asiaSess.sLow,  color=colKZAsian, style=line.style_solid, width=1, extend=extend.right)

if inLondon and not inLondon[1]
    lonSess.sHigh := high, lonSess.sLow := low, lonSess.isActive := true
else if inLondon
    lonSess.sHigh := math.max(lonSess.sHigh, high), lonSess.sLow := math.min(lonSess.sLow, low)
else if not inLondon and inLondon[1]
    lonSess.isActive := false
    if drawSessionLiq
        lonSess.lineHigh := line.new(bar_index, lonSess.sHigh, bar_index + 10, lonSess.sHigh, color=colKZLondon, style=line.style_solid, width=1, extend=extend.right)
        lonSess.lineLow  := line.new(bar_index, lonSess.sLow,  bar_index + 10, lonSess.sLow,  color=colKZLondon, style=line.style_solid, width=1, extend=extend.right)

// ==========================================================================================================
// █ 9. MULTI-TIMEFRAME LIQUIDITY EXTRACTION
// ==========================================================================================================

[pdh, pdl, pdc] = request.security(syminfo.tickerid, "D", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
[pwh, pwl, pwc] = request.security(syminfo.tickerid, "W", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)
[pmh, pml, pmc] = request.security(syminfo.tickerid, "M", [high[1], low[1], close[1]], lookahead=barmerge.lookahead_on)

var line[] d_lines = array.new_line()
var line[] w_lines = array.new_line()
var line[] m_lines = array.new_line()

if isNewDay and showDaily
    if array.size(d_lines) > 0
        for i = 0 to array.size(d_lines) - 1
            line.delete(array.get(d_lines, i))
        array.clear(d_lines)
    array.push(d_lines, line.new(bar_index, pdh, bar_index + 1, pdh, color=colLiqDaily, style=line.style_dashed, extend=extend.right))
    array.push(d_lines, line.new(bar_index, pdl, bar_index + 1, pdl, color=colLiqDaily, style=line.style_dashed, extend=extend.right))
    array.push(d_lines, line.new(bar_index, pdc, bar_index + 1, pdc, color=colLiqDaily, style=line.style_dotted, extend=extend.right))

if isNewWeek and showWeekly
    if array.size(w_lines) > 0
        for i = 0 to array.size(w_lines) - 1
            line.delete(array.get(w_lines, i))
        array.clear(w_lines)
    array.push(w_lines, line.new(bar_index, pwh, bar_index + 1, pwh, color=colLiqWeekly, style=line.style_dashed, width=2, extend=extend.right))
    array.push(w_lines, line.new(bar_index, pwl, bar_index + 1, pwl, color=colLiqWeekly, style=line.style_dashed, width=2, extend=extend.right))

// ==========================================================================================================
// █ 9B. HTF ORDER BLOCK CONFLUENCE ENGINE
// ==========================================================================================================
// Fetches the last completed HTF candle via request.security (no lookahead bias).
// A candle qualifies as an OB if it is a displacement move: body > avgBody × mult
// AND volume > avgVol × mult.  The zone persists until price fully closes through it.

float _htfH       = request.security(syminfo.tickerid, htfTF, high[1],   lookahead=barmerge.lookahead_on)
float _htfL       = request.security(syminfo.tickerid, htfTF, low[1],    lookahead=barmerge.lookahead_on)
float _htfO       = request.security(syminfo.tickerid, htfTF, open[1],   lookahead=barmerge.lookahead_on)
float _htfC       = request.security(syminfo.tickerid, htfTF, close[1],  lookahead=barmerge.lookahead_on)
float _htfVol     = request.security(syminfo.tickerid, htfTF, volume[1], lookahead=barmerge.lookahead_on)
float _htfAvgVol  = request.security(syminfo.tickerid, htfTF, ta.sma(volume, 20), lookahead=barmerge.lookahead_on)
float _htfAvgBody = request.security(syminfo.tickerid, htfTF, ta.sma(math.abs(close - open), 20), lookahead=barmerge.lookahead_on)
int   _htfBarTime = request.security(syminfo.tickerid, htfTF, time, lookahead=barmerge.lookahead_on)
bool  _htfNewBar  = ta.change(_htfBarTime) != 0

bool _htfBullDisp = _htfC > _htfO and _htfVol > _htfAvgVol * htfDisplaceMult and (_htfC - _htfO) > _htfAvgBody * htfDisplaceMult
bool _htfBearDisp = _htfC < _htfO and _htfVol > _htfAvgVol * htfDisplaceMult and (_htfO - _htfC) > _htfAvgBody * htfDisplaceMult

if showHTFOB and _htfNewBar
    if _htfBullDisp
        htfBullOBH := _htfH
        htfBullOBL := _htfL
        box.delete(htfBullBox)
        htfBullBox := box.new(bar_index, htfBullOBH, bar_index + 1, htfBullOBL, bgcolor=colHTFOBBull, border_color=color.new(colHTFOBBull, 0), border_width=1, extend=extend.right)
    if _htfBearDisp
        htfBearOBH := _htfH
        htfBearOBL := _htfL
        box.delete(htfBearBox)
        htfBearBox := box.new(bar_index, htfBearOBH, bar_index + 1, htfBearOBL, bgcolor=colHTFOBBear, border_color=color.new(colHTFOBBear, 0), border_width=1, extend=extend.right)

// Invalidate HTF OB if price closes fully through it
if not na(htfBullOBL) and close < htfBullOBL
    htfBullOBH := na, htfBullOBL := na
    box.delete(htfBullBox)
if not na(htfBearOBH) and close > htfBearOBH
    htfBearOBH := na, htfBearOBL := na
    box.delete(htfBearBox)

bool inHTFBullOB = showHTFOB and not na(htfBullOBL) and close >= htfBullOBL and close <= htfBullOBH
bool inHTFBearOB = showHTFOB and not na(htfBearOBH) and close >= htfBearOBL and close <= htfBearOBH

// ==========================================================================================================
// █ 10. PREMIUM & DISCOUNT MATRIX & ELEPHANT ZONES
// ==========================================================================================================

dayRange  = pdh - pdl
dayPivot  = (pdh + pdl + pdc) / 3
var box premBox = na, var box discBox = na

if isNewDay and showPremDisc
    box.delete(premBox[1]), box.delete(discBox[1])
    premBox := box.new(bar_index, pdh,                  bar_index + 1, pdl + (dayRange / 2), border_color=na, bgcolor=colPremium,  extend=extend.right)
    discBox := box.new(bar_index, pdl + (dayRange / 2), bar_index + 1, pdl,                  border_color=na, bgcolor=colDiscount, extend=extend.right)

float res1   = (2 * dayPivot) - pdl
float res2   = dayPivot + dayRange
float sup1   = (2 * dayPivot) - pdh
float sup2   = dayPivot - dayRange
float zThick = dayRange * zoneThick

var box[] eeBoxes = array.new_box()
if isNewDay and showEE
    if not showHistoricalEE and array.size(eeBoxes) > 0
        for i = 0 to array.size(eeBoxes) - 1
            box.delete(array.get(eeBoxes, i))
        array.clear(eeBoxes)
    color _eSell1 = color.new(colEESell1, 100 - opacityEESupply)
    color _eSell2 = color.new(colEESell2, 100 - opacityEESupply)
    color _eBuy1  = color.new(colEEBuy1,  100 - opacityEEDemand)
    color _eBuy2  = color.new(colEEBuy2,  100 - opacityEEDemand)
    array.push(eeBoxes, box.new(bar_index, res2 + zThick/2, bar_index + 1, res2 - zThick/2, border_color=na, bgcolor=_eSell2, extend=extend.right))
    array.push(eeBoxes, box.new(bar_index, res1 + zThick/2, bar_index + 1, res1 - zThick/2, border_color=na, bgcolor=_eSell1, extend=extend.right))
    array.push(eeBoxes, box.new(bar_index, sup1 + zThick/2, bar_index + 1, sup1 - zThick/2, border_color=na, bgcolor=_eBuy1,  extend=extend.right))
    array.push(eeBoxes, box.new(bar_index, sup2 + zThick/2, bar_index + 1, sup2 - zThick/2, border_color=na, bgcolor=_eBuy2,  extend=extend.right))

bool operatorBullBreak = isOperatorCandle and close > open and close > res1 and (not enableRSIFilter or rsiBullConfirm)
bool operatorBearBreak = isOperatorCandle and close < open and close < sup1 and (not enableRSIFilter or rsiBearConfirm)
plotshape(detectOperatorCandles and operatorBullBreak, "Shark Buy",  shape.triangleup,   location.belowbar, color.lime, size=size.small, text="SHARK BUY")
plotshape(detectOperatorCandles and operatorBearBreak, "Shark Sell", shape.triangledown, location.abovebar, color.red,  size=size.small, text="SHARK SELL")

// ==========================================================================================================
// █ 11. SMC ENGINE: FRACTAL MARKET STRUCTURE
// ==========================================================================================================

ext_ph = ta.pivothigh(high, swingLenExt, swingLenExt)
ext_pl = ta.pivotlow (low,  swingLenExt, swingLenExt)
int_ph = ta.pivothigh(high, swingLenInt, swingLenInt)
int_pl = ta.pivotlow (low,  swingLenInt, swingLenInt)

if not na(ext_ph)
    if extTrend == 1
        if high[swingLenExt] > extLastH.price and not extLastH.isBroken
            if showBOS
                line.new(extLastH.index, extLastH.price, bar_index - swingLenExt, extLastH.price, color=colBOSBull, style=line.style_solid, width=2)
            extLastH.isBroken := true
    else if extTrend == -1
        if high[swingLenExt] > extLastH.price and not extLastH.isBroken
            if showBOS
                line.new(extLastH.index, extLastH.price, bar_index - swingLenExt, extLastH.price, color=colBOSBull, style=line.style_dashed, width=2)
            extTrend := 1, extLastH.isBroken := true
    extLastH := SwingPoint.new(bar_index - swingLenExt, ext_ph, true, false, true)

if not na(ext_pl)
    if extTrend == -1
        if low[swingLenExt] < extLastL.price and not extLastL.isBroken
            if showBOS
                line.new(extLastL.index, extLastL.price, bar_index - swingLenExt, extLastL.price, color=colBOSBear, style=line.style_solid, width=2)
            extLastL.isBroken := true
    else if extTrend == 1
        if low[swingLenExt] < extLastL.price and not extLastL.isBroken
            if showBOS
                line.new(extLastL.index, extLastL.price, bar_index - swingLenExt, extLastL.price, color=colBOSBear, style=line.style_dashed, width=2)
            extTrend := -1, extLastL.isBroken := true
    extLastL := SwingPoint.new(bar_index - swingLenExt, ext_pl, false, false, true)

if not na(int_ph)
    if intTrend == 1
        if high[swingLenInt] > intLastH.price and not intLastH.isBroken
            if showBOS
                line.new(intLastH.index, intLastH.price, bar_index - swingLenInt, intLastH.price, color=colBOSBull, style=line.style_dotted, width=1)
            intLastH.isBroken := true
            if showOB and (not filterOBVol or isHighVol[swingLenInt])
                if array.size(activeOBs) >= obLimit
                    ob_old = array.shift(activeOBs)
                    box.delete(ob_old.visualBox)
                    if not na(ob_old.mtLine)
                        line.delete(ob_old.mtLine)
                idx = bar_index - swingLenInt - 1
                bool  _obHTFConfl = not na(htfBullOBL) and low[bar_index - idx] <= htfBullOBH and high[bar_index - idx] >= htfBullOBL
                color _obBullFill = color.new(colOBBull,       100 - opacityOBBullFill)
                color _obBullBord = color.new(colOBBullBorder, 100 - opacityOBBorder)
                bx  = box.new(idx, high[bar_index - idx], idx, low[bar_index - idx], border_color=_obBullBord, bgcolor=_obBullFill, border_width=_obHTFConfl ? 2 : 1, extend=extend.right)
                if _obHTFConfl
                    box.set_text(bx, "◆ HTF"), box.set_text_color(bx, color.white), box.set_text_size(bx, size.tiny)
                ln  = showOBThreshold ? line.new(idx, low[bar_index - idx] + ((high[bar_index - idx] - low[bar_index - idx]) / 2), idx, low[bar_index - idx] + ((high[bar_index - idx] - low[bar_index - idx]) / 2), color=_obBullBord, style=line.style_dotted, extend=extend.right) : na
                array.push(activeOBs, OrderBlock.new(idx, idx, high[bar_index - idx], low[bar_index - idx], 0, true, false, 0, volume[bar_index - idx], bx, ln, _obHTFConfl, 0, bar_index))
    else if intTrend == -1
        if high[swingLenInt] > intLastH.price and not intLastH.isBroken
            if showBOS
                line.new(intLastH.index, intLastH.price, bar_index - swingLenInt, intLastH.price, color=colBOSBull, style=line.style_dotted, width=1)
            intTrend := 1, intLastH.isBroken := true
    intLastH := SwingPoint.new(bar_index - swingLenInt, int_ph, true, false, false)

if not na(int_pl)
    if intTrend == -1
        if low[swingLenInt] < intLastL.price and not intLastL.isBroken
            if showBOS
                line.new(intLastL.index, intLastL.price, bar_index - swingLenInt, intLastL.price, color=colBOSBear, style=line.style_dotted, width=1)
            intLastL.isBroken := true
            if showOB and (not filterOBVol or isHighVol[swingLenInt])
                if array.size(activeOBs) >= obLimit
                    ob_old = array.shift(activeOBs)
                    box.delete(ob_old.visualBox)
                    if not na(ob_old.mtLine)
                        line.delete(ob_old.mtLine)
                idx = bar_index - swingLenInt - 1
                bool  _obHTFConfl = not na(htfBearOBH) and low[bar_index - idx] <= htfBearOBH and high[bar_index - idx] >= htfBearOBL
                color _obBearFill = color.new(colOBBear,       100 - opacityOBBearFill)
                color _obBearBord = color.new(colOBBearBorder, 100 - opacityOBBorder)
                bx  = box.new(idx, high[bar_index - idx], idx, low[bar_index - idx], border_color=_obBearBord, bgcolor=_obBearFill, border_width=_obHTFConfl ? 2 : 1, extend=extend.right)
                if _obHTFConfl
                    box.set_text(bx, "◆ HTF"), box.set_text_color(bx, color.red), box.set_text_size(bx, size.tiny)
                ln  = showOBThreshold ? line.new(idx, low[bar_index - idx] + ((high[bar_index - idx] - low[bar_index - idx]) / 2), idx, low[bar_index - idx] + ((high[bar_index - idx] - low[bar_index - idx]) / 2), color=_obBearBord, style=line.style_dotted, extend=extend.right) : na
                array.push(activeOBs, OrderBlock.new(idx, idx, high[bar_index - idx], low[bar_index - idx], 0, false, false, 0, volume[bar_index - idx], bx, ln, _obHTFConfl, 0, bar_index))
    else if intTrend == 1
        if low[swingLenInt] < intLastL.price and not intLastL.isBroken
            if showBOS
                line.new(intLastL.index, intLastL.price, bar_index - swingLenInt, intLastL.price, color=colBOSBear, style=line.style_dotted, width=1)
            intTrend := -1, intLastL.isBroken := true
    intLastL := SwingPoint.new(bar_index - swingLenInt, int_pl, false, false, false)

// ==========================================================================================================
// █ 12. OB & FVG MITIGATION ENGINE
// ==========================================================================================================
// Per-bar hard limit enforcement — runs every bar so changing obLimit / fvgLimit
// in the settings takes effect on the very next chart update, not just when a
// new swing point happens to be detected.

while array.size(activeOBs) > obLimit
    ob_trim = array.shift(activeOBs)
    box.delete(ob_trim.visualBox)
    if not na(ob_trim.mtLine)
        line.delete(ob_trim.mtLine)

while array.size(activeFVGs) > fvgLimit
    fvg_trim = array.shift(activeFVGs)
    box.delete(fvg_trim.visualBox)
    if not na(fvg_trim.ceLine)
        line.delete(fvg_trim.ceLine)

if showOB and array.size(activeOBs) > 0
    for i = array.size(activeOBs) - 1 to 0
        ob = array.get(activeOBs, i)
        if not ob.mitigated
            bool _touch = (ob.isBullish and low <= ob.topPrice and bar_index > ob.topIndex + 2) or (not ob.isBullish and high >= ob.bottomPrice and bar_index > ob.topIndex + 2)
            if _touch
                // Full break: close through the entire zone = mitigated
                bool _fullBreak = ob.isBullish ? close < ob.bottomPrice : close > ob.topPrice
                if _fullBreak
                    ob.mitigated := true
                    box.set_extend(ob.visualBox, extend.none), box.set_right(ob.visualBox, bar_index)
                    if not na(ob.mtLine)
                        line.set_extend(ob.mtLine, extend.none), line.set_x2(ob.mtLine, bar_index)
                else if bar_index > ob.lastVisitBar + 3
                    // Visit: price entered zone but did not close through it
                    ob.visitCount    += 1
                    ob.lastVisitBar   := bar_index
                    string _vTxt = (ob.hasHTFConfl ? "◆ " : "") + str.tostring(ob.visitCount) + "×"
                    color  _vCol = ob.visitCount == 1 ? color.yellow : color.orange
                    box.set_text(ob.visualBox, _vTxt)
                    box.set_text_color(ob.visualBox, _vCol)
                    box.set_text_size(ob.visualBox, size.tiny)
        if ob.mitigated
            array.remove(activeOBs, i)

if showFVG
    // Displacement gate: middle candle must be a genuine institutional move
    bool _fvgDispl = not filterFVGDisplace or (volume[1] > avgVol * fvgDisplaceMult and math.abs(close[1] - open[1]) > avgBody * fvgDisplaceMult)
    if low > high[2] and close[1] > open[1] and _fvgDispl
        // FIFO eviction: remove oldest FVG when limit is reached
        if array.size(activeFVGs) >= fvgLimit
            fvg_old = array.shift(activeFVGs)
            box.delete(fvg_old.visualBox)
            if not na(fvg_old.ceLine)
                line.delete(fvg_old.ceLine)
        fTop = low, fBot = high[2], fCE = fBot + ((fTop - fBot) / 2)
        color _fvgBullC = color.new(colFVGBull, 100 - opacityFVGBull)
        bx = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=na, bgcolor=_fvgBullC, extend=extend.right)
        ln = showFVGCE ? line.new(bar_index - 2, fCE, bar_index, fCE, color=_fvgBullC, style=line.style_dotted, extend=extend.right) : na
        array.push(activeFVGs, FairValueGap.new(bar_index - 2, fTop, fBot, fCE, true, false, bx, ln))
    if high < low[2] and close[1] < open[1] and _fvgDispl
        // FIFO eviction: remove oldest FVG when limit is reached
        if array.size(activeFVGs) >= fvgLimit
            fvg_old = array.shift(activeFVGs)
            box.delete(fvg_old.visualBox)
            if not na(fvg_old.ceLine)
                line.delete(fvg_old.ceLine)
        fTop = low[2], fBot = high, fCE = fBot + ((fTop - fBot) / 2)
        bx = box.new(bar_index - 2, fTop, bar_index, fBot, border_color=na, bgcolor=colFVGBear, extend=extend.right)
        ln = showFVGCE ? line.new(bar_index - 2, fCE, bar_index, fCE, color=color.new(colFVGBear, 0), style=line.style_dotted, extend=extend.right) : na
        array.push(activeFVGs, FairValueGap.new(bar_index - 2, fTop, fBot, fCE, false, false, bx, ln))

if array.size(activeFVGs) > 0
    for i = array.size(activeFVGs) - 1 to 0
        fvg = array.get(activeFVGs, i)
        if not fvg.mitigated
            if (fvg.isBullish and low <= fvg.bottomPrice) or (not fvg.isBullish and high >= fvg.topPrice)
                fvg.mitigated := true
                box.set_extend(fvg.visualBox, extend.none), box.set_right(fvg.visualBox, bar_index)
                if not na(fvg.ceLine)
                    line.set_extend(fvg.ceLine, extend.none), line.set_x2(fvg.ceLine, bar_index)
        if fvg.mitigated
            array.remove(activeFVGs, i)

// ==========================================================================================================
// █ 13. SESSION VOLUME PROFILE & POC  [original — bars grow RIGHTWARD into blank space]
// ==========================================================================================================

if isNewPeriod
    sessHighVP := high, sessLowVP := low, totalSessVol := 0.0, array.fill(volBins, 0.0)
else
    sessHighVP := math.max(sessHighVP, high), sessLowVP := math.min(sessLowVP, low)

if showVP
    rowSize := math.max(syminfo.mintick, (sessHighVP - sessLowVP) / vpRows)
    idxTop   = math.floor((high - sessLowVP) / rowSize)
    idxBot   = math.floor((low  - sessLowVP) / rowSize)
    idxTop  := math.min(idxTop, vpRows - 1)
    idxBot  := math.max(idxBot, 0)

    volPerBin = volume / math.max(1, (idxTop - idxBot + 1))
    for i = idxBot to idxTop
        if i >= 0 and i < vpRows
            currentVol = array.get(volBins, i)
            array.set(volBins, i, currentVol + volPerBin)
            totalSessVol += volPerBin

var box[]  vpBoxes         = array.new_box()
var float  pocPriceTracker = na
var float  vahTracker      = na
var float  valTracker      = na

if showVP and barstate.islast and rowSize > 0
    if array.size(vpBoxes) > 0
        for i = 0 to array.size(vpBoxes) - 1
            box.delete(array.get(vpBoxes, i))
        array.clear(vpBoxes)

    float maxVol = 0.0, int pocIndex = 0
    for i = 0 to vpRows - 1
        vol = array.get(volBins, i)
        if vol > maxVol
            maxVol := vol, pocIndex := i

    float targetVol    = totalSessVol * (valueAreaPct / 100.0)
    float currentVolVA = maxVol
    int   upIndex      = pocIndex + 1
    int   downIndex    = pocIndex - 1
    int[] inVA         = array.new_int(vpRows, 0)
    array.set(inVA, pocIndex, 1)

    while currentVolVA < targetVol and (upIndex < vpRows or downIndex >= 0)
        float volUp   = upIndex   < vpRows ? array.get(volBins, upIndex)   : 0.0
        float volDown = downIndex >= 0     ? array.get(volBins, downIndex) : 0.0
        if volUp > volDown
            currentVolVA += volUp
            if upIndex >= 0 and upIndex < vpRows
                array.set(inVA, upIndex, 1)
            upIndex += 1
        else
            currentVolVA += volDown
            if downIndex >= 0 and downIndex < vpRows
                array.set(inVA, downIndex, 1)
            downIndex -= 1

    vahTracker := sessLowVP + (upIndex   * rowSize)
    valTracker := sessLowVP + (downIndex * rowSize)

    // Session VP boxes grow RIGHTWARD from bar_index into blank space
    for i = 0 to vpRows - 1
        vol = array.get(volBins, i)
        if vol > 0
            int   boxLength  = math.round((vol / maxVol) * maxProfileWidth)
            float priceLevel = sessLowVP + (i * rowSize)
            boxColor = i == pocIndex ? colPOC : array.get(inVA, i) == 1 ? colVA : colVPBg
            array.push(vpBoxes, box.new(bar_index, priceLevel + rowSize, bar_index + boxLength, priceLevel, border_color=na, bgcolor=boxColor))
    pocPriceTracker := sessLowVP + (pocIndex * rowSize) + (rowSize / 2)

// ==========================================================================================================
// █ 13B. VISIBLE RANGE VOLUME PROFILE  [new — bars grow LEFTWARD from bar_index toward price axis]
// ==========================================================================================================
//
//  Geometry (no overlap with Session VP):
//  ┌─────────────────────────────────────┬──────────────────────────────────────┐
//  │   VRVP bars  ◄────────────────────  │ bar_index │  Session VP ──────────►  │
//  │   (grow left into chart body)        │  (price   │  (grow right into blank) │
//  └─────────────────────────────────────┴───────────┴──────────────────────────┘
//
//  The right edge of every VRVP box = bar_index  (flush with the live price axis).
//  The left  edge of every VRVP box = bar_index - scaled_bar_length.

if showVRVP and barstate.islast

    // ── wipe previous render ─────────────────────────────────────────────────
    if array.size(vrvpBoxes) > 0
        for i = 0 to array.size(vrvpBoxes) - 1
            box.delete(array.get(vrvpBoxes, i))
        array.clear(vrvpBoxes)
    line.delete(vrvpPOCLine)
    label.delete(vrvpLblPOC)
    label.delete(vrvpLblVAH)
    label.delete(vrvpLblVAL)

    // ── identify visible bar time window ─────────────────────────────────────
    int leftT  = chart.left_visible_bar_time
    int rightT = chart.right_visible_bar_time
    int lb     = math.min(bar_index, vrvpMaxLookback)

    // ── Pass A: find price range of visible bars ─────────────────────────────
    float vrvpH = na
    float vrvpL = na
    for i = 0 to lb
        int t = time[i]
        if t >= leftT and t <= rightT
            vrvpH := na(vrvpH) ? high[i] : math.max(vrvpH, high[i])
            vrvpL := na(vrvpL) ? low[i]  : math.min(vrvpL, low[i])

    if not na(vrvpH) and not na(vrvpL) and (vrvpH - vrvpL) > 0

        float  vrvpRowSz = math.max(syminfo.mintick, (vrvpH - vrvpL) / vrvpRows)
        float[] vBins    = array.new_float(vrvpRows, 0.0)
        float  totVol    = 0.0

        // ── Pass B: accumulate volume ─────────────────────────────────────────
        for i = 0 to lb
            int t = time[i]
            if t >= leftT and t <= rightT
                int   iTop = math.min(math.floor((high[i] - vrvpL) / vrvpRowSz), vrvpRows - 1)
                int   iBot = math.max(math.floor((low[i]  - vrvpL) / vrvpRowSz), 0)
                float vpb  = volume[i] / math.max(1, iTop - iBot + 1)
                for j = iBot to iTop
                    if j >= 0 and j < vrvpRows
                        array.set(vBins, j, array.get(vBins, j) + vpb)
                        totVol += vpb

        // ── find POC ──────────────────────────────────────────────────────────
        float vMaxVol = 0.0
        int   vPocIdx = 0
        for i = 0 to vrvpRows - 1
            float v = array.get(vBins, i)
            if v > vMaxVol
                vMaxVol := v, vPocIdx := i

        // ── expand value area outward from POC ────────────────────────────────
        float  vTargetVA = totVol * (vrvpVAPct / 100.0)
        float  vCurVA    = array.get(vBins, vPocIdx)
        int    vUp       = vPocIdx + 1
        int    vDown     = vPocIdx - 1
        int[]  vInVA     = array.new_int(vrvpRows, 0)
        array.set(vInVA, vPocIdx, 1)

        // Bounded for loop — guaranteed to run at most vrvpRows iterations.
        // Replaces the while loop which could stall on zero-volume bins.
        for _iter = 0 to vrvpRows - 1
            if vCurVA >= vTargetVA
                break
            if vUp >= vrvpRows and vDown < 0
                break
            float vVolUp   = vUp   < vrvpRows ? array.get(vBins, vUp)   : 0.0
            float vVolDown = vDown >= 0        ? array.get(vBins, vDown) : 0.0
            if vVolUp > vVolDown
                vCurVA += vVolUp
                if vUp >= 0 and vUp < vrvpRows
                    array.set(vInVA, vUp, 1)
                vUp += 1
            else
                vCurVA += vVolDown
                if vDown >= 0 and vDown < vrvpRows
                    array.set(vInVA, vDown, 1)
                vDown -= 1

        // Price levels for labels
        float vPocPrice = vrvpL + (vPocIdx                        * vrvpRowSz) + (vrvpRowSz / 2)
        float vVAH      = vrvpL + (math.min(vUp,   vrvpRows)      * vrvpRowSz)
        float vVAL      = vrvpL + (math.max(vDown + 1, 0)         * vrvpRowSz)

        // ── draw VRVP boxes offset to the right ───────────────────────────────
        // _vrvpRight = the right edge anchor; bars grow leftward from it.
        // With offset=90, the entire profile floats in the blank space beyond
        // the last candle — zero overlap with price action.
        int _vrvpRight = bar_index + vrvpRightOffset
        for i = 0 to vrvpRows - 1
            float v = array.get(vBins, i)
            if v > 0
                int   bLen   = math.max(1, math.round((v / vMaxVol) * vrvpMaxWidth))
                float pLow   = vrvpL + (i * vrvpRowSz)
                float pHigh  = pLow + vrvpRowSz
                color bColor = i == vPocIdx ? colVRVPPOC : array.get(vInVA, i) == 1 ? colVRVPVA : colVRVPBg
                array.push(vrvpBoxes, box.new(_vrvpRight - bLen, pHigh, _vrvpRight, pLow, border_color=na, bgcolor=bColor))

        // ── optional POC line extends from chart into profile ─────────────────
        if showVRVPPOCLine
            vrvpPOCLine := line.new(bar_index - vrvpMaxWidth, vPocPrice, _vrvpRight, vPocPrice, color=colVRVPPOCLine, style=line.style_dashed, width=1)

        // ── labels placed just right of the profile right edge ───────────────
        if showVRVPLabels
            int lblX = _vrvpRight + 1
            vrvpLblPOC := label.new(lblX, vPocPrice, "POC " + str.tostring(vPocPrice, format.mintick), color=color.new(colVRVPPOC, 100), textcolor=colVRVPPOC, style=label.style_label_left, size=size.small)
            vrvpLblVAH := label.new(lblX, vVAH, "VAH " + str.tostring(vVAH, format.mintick), color=color.new(colVRVPVA, 100), textcolor=colVRVPVA, style=label.style_label_left, size=size.small)
            vrvpLblVAL := label.new(lblX, vVAL, "VAL " + str.tostring(vVAL, format.mintick), color=color.new(colVRVPVA, 100), textcolor=colVRVPVA, style=label.style_label_left, size=size.small)

// ==========================================================================================================
// █ 14. AUTO-FIBONACCI MATRIX
// ==========================================================================================================
// Fib levels are rendered as plot() series so each level's line thickness and style
// can be configured individually in the chart's Style tab (right-click → Settings → Style).
// Default linewidth = 2 for all levels.  Colors are set in the Inputs tab as before.

bool  _fibValid = showAutoFib and extLastH.price > 0 and extLastL.price > 0
float _fibDiff  = _fibValid ? math.abs(extLastH.price - extLastL.price) : na
float _fib0     = _fibValid ? (extTrend == 1 ? extLastH.price : extLastL.price) : na
float _fib1     = _fibValid ? (extTrend == 1 ? extLastL.price : extLastH.price) : na
float _fib382   = _fibValid ? (extTrend == 1 ? extLastL.price + (_fibDiff * 0.382) : extLastH.price - (_fibDiff * 0.382)) : na
float _fib500   = _fibValid ? (extTrend == 1 ? extLastL.price + (_fibDiff * 0.500) : extLastH.price - (_fibDiff * 0.500)) : na
float _fib618   = _fibValid ? (extTrend == 1 ? extLastL.price + (_fibDiff * 0.618) : extLastH.price - (_fibDiff * 0.618)) : na
float _fib786   = _fibValid ? (extTrend == 1 ? extLastL.price + (_fibDiff * 0.786) : extLastH.price - (_fibDiff * 0.786)) : na

plot(_fib0,   "Fib 0.000", color=colFib0,   linewidth=2)
plot(_fib382, "Fib 0.382", color=colFib382, linewidth=2)
plot(_fib500, "Fib 0.500", color=colFib500, linewidth=2)
plot(_fib618, "Fib 0.618", color=colFib618, linewidth=2)
plot(_fib786, "Fib 0.786", color=colFib786, linewidth=2)
plot(_fib1,   "Fib 1.000", color=colFib0,   linewidth=2)

// ==========================================================================================================
// █ 15. DYNAMIC VWAP & DEVIATIONS
// ==========================================================================================================

var float vwapAnchor = na, var float vwapSum = 0.0, var float volSum = 0.0, var float vwapDevSum = 0.0

if isNewPeriod
    vwapSum := 0.0, volSum := 0.0, vwapDevSum := 0.0

vwapSum    += hlc3 * volume
volSum     += volume
vwapAnchor := vwapSum / volSum
vwapDevSum += volume * math.pow(hlc3 - vwapAnchor, 2)
float stdev = math.sqrt(vwapDevSum / volSum)

float upperDev1 = vwapAnchor + (stdev * devMult1), float lowerDev1 = vwapAnchor - (stdev * devMult1)
float upperDev2 = vwapAnchor + (stdev * devMult2), float lowerDev2 = vwapAnchor - (stdev * devMult2)
float upperDev3 = vwapAnchor + (stdev * devMult3), float lowerDev3 = vwapAnchor - (stdev * devMult3)

plot(showVWAP    ? vwapAnchor : na, "Session VWAP",  color=colVWAP, linewidth=2)
plot(showVWAPDev ? upperDev1  : na, "Upper Dev 1",   color=colDev1, linewidth=1, style=plot.style_circles)
plot(showVWAPDev ? lowerDev1  : na, "Lower Dev 1",   color=colDev1, linewidth=1, style=plot.style_circles)
plot(showVWAPDev ? upperDev2  : na, "Upper Dev 2",   color=colDev2, linewidth=1, style=plot.style_cross)
plot(showVWAPDev ? lowerDev2  : na, "Lower Dev 2",   color=colDev2, linewidth=1, style=plot.style_cross)
plot(showVWAPDev ? upperDev3  : na, "Upper Dev 3",   color=colDev3, linewidth=1, style=plot.style_cross)
plot(showVWAPDev ? lowerDev3  : na, "Lower Dev 3",   color=colDev3, linewidth=1, style=plot.style_cross)

// ==========================================================================================================
// █ 16. HOVER TOOLTIP ENGINE
// ==========================================================================================================

var label ttVWAP  = na, var label ttIBH  = na, var label ttIBL = na
var label ttPDH   = na, var label ttPDL  = na, var label ttRes1 = na
var label ttSup1  = na, var label ttRenko= na

if barstate.islast
    if showVWAP
        label.delete(ttVWAP[1])
        string vwapTxt = "🎯 VWAP ANCHOR\nValue: " + str.tostring(vwapAnchor, "#.##") + "\nBias: " + (close > vwapAnchor ? "BULLISH" : "BEARISH")
        ttVWAP := label.new(bar_index + 2, vwapAnchor, "V", color=color.new(colVWAP, 100), textcolor=colVWAP, style=label.style_label_left, size=size.small, tooltip=vwapTxt)

    if showIB and ibLocked
        label.delete(ttIBH[1]), label.delete(ttIBL[1])
        string ibhTxt = "⏳ INITIAL BALANCE HIGH\nValue: " + str.tostring(ibHigh, "#.##")
        string iblTxt = "⏳ INITIAL BALANCE LOW\nValue: "  + str.tostring(ibLow,  "#.##")
        ttIBH := label.new(bar_index + 2, ibHigh, "IBH", color=color.new(colIBHigh, 100), textcolor=colIBHigh, style=label.style_label_left, size=size.small, tooltip=ibhTxt)
        ttIBL := label.new(bar_index + 2, ibLow,  "IBL", color=color.new(colIBLow,  100), textcolor=colIBLow,  style=label.style_label_left, size=size.small, tooltip=iblTxt)

    if showRenkoSR
        label.delete(ttRenko[1])
        string renkoTxt = "🧱 SYNTHETIC RENKO S/R\nMode: " + renkoMode + " (" + str.tostring(renkoParam) + ")\nActive Res: " + str.tostring(rRes, "#.##") + "\nActive Sup: " + str.tostring(rSup, "#.##")
        float midP = na(rRes) or na(rSup) ? close : (rRes + rSup) / 2
        ttRenko := label.new(bar_index + 2, midP, "RENKO", color=color.new(color.white, 100), textcolor=color.gray, style=label.style_label_left, size=size.small, tooltip=renkoTxt)

// ==========================================================================================================
// █ 17. ENTERPRISE DASHBOARD
// ==========================================================================================================

trend5m  = getMTFTrend("5"),  trend15m = getMTFTrend("15")
trend1H  = getMTFTrend("60"), trend4H  = getMTFTrend("240")
int totalTrendScore = trend5m + trend15m + trend1H + trend4H

// EMA values — computed here so the dashboard row can reference them
float emaF = ta.ema(close, emaFast)
float emaS = ta.ema(close, emaSlow)
bool emaBullCross = ta.crossover(emaF,  emaS)
bool emaBearCross = ta.crossunder(emaF, emaS)

// ── Trend Strength Score (0–10) ──────────────────────────────────────────────
// Each factor casts a bullish vote (+1). Score ≥6 = bullish bias, ≤4 = bearish.
int _tss = (trend5m  == 1 ? 1 : 0)
         + (trend15m == 1 ? 1 : 0)
         + (trend1H  == 1 ? 1 : 0)
         + (trend4H  == 1 ? 1 : 0)
         + (close > vwapAnchor       ? 1 : 0)
         + (rsi_curr > 50            ? 1 : 0)
         + (extTrend == 1            ? 1 : 0)
         + (emaF > emaS              ? 1 : 0)
         + (not na(pocPriceTracker) and close > pocPriceTracker ? 1 : 0)
         + (inHTFBullOB              ? 1 : 0)
string _tssLabel = _tss >= 8 ? "STRONG BULL" : _tss >= 6 ? "BULL" : _tss == 5 ? "NEUTRAL" : _tss >= 3 ? "BEAR" : "STRONG BEAR"
color  _tssColor = _tss >= 6 ? color.lime : _tss == 5 ? color.yellow : color.red

var table hud = table.new(dashPosition == "Top Right" ? position.top_right : dashPosition == "Top Left" ? position.top_left : dashPosition == "Bottom Right" ? position.bottom_right : dashPosition == "Bottom Left" ? position.bottom_left : dashPosition == "Middle Right" ? position.middle_right : position.middle_left, 5, 17, border_width=1, border_color=colDashBorder)

if showDashboard and barstate.islast
    table.cell(hud, 0, 0, "GOD MODE V8.0: THE RENKO MATRIX", text_color=colDashAccent, bgcolor=colDashBg, text_size=getSize(), text_halign=text.align_center)
    table.merge_cells(hud, 0, 0, 4, 0)

    table.cell(hud, 0, 1, "METRIC",   text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 1, "STATUS",   text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 1, "VALUE 1",  text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 1, "VALUE 2",  text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 1, "CONTEXT",  text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 2, "Global MTF Bias",       text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 2, totalTrendScore >= 2 ? "STRONG BULL" : totalTrendScore <= -2 ? "STRONG BEAR" : "NEUTRAL",
                 text_color=totalTrendScore >= 2 ? color.lime : totalTrendScore <= -2 ? color.red : color.yellow, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 2, "Score: " + str.tostring(totalTrendScore), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 2, "-",                     text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 2, "5m/15m/1H/4H",          text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 3, "SMC Macro Trend",        text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 3, extTrend == 1 ? "BULLISH" : "BEARISH",
                 text_color=extTrend == 1 ? color.lime : color.red, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 3, str.tostring(extLastH.price, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 3, str.tostring(extLastL.price, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 3, "Ext Swing H/L",          text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 4, "5th Element RSI",        text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 4, rsiBullConfirm ? "CONFIRMED BUY" : rsiBearConfirm ? "CONFIRMED SELL" : "NO SIGNAL",
                 text_color=rsiBullConfirm ? color.lime : rsiBearConfirm ? color.red : color.yellow, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 4, "Cur: " + str.tostring(rsi_curr, "#"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 4, "15m: " + str.tostring(rsi_15m,  "#"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 4, "MTF Alignment",           text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 5, "Session VP POC",          text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 5, close > pocPriceTracker ? "ABOVE POC" : "BELOW POC",
                 text_color=close > pocPriceTracker ? color.lime : color.red, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 5, str.tostring(pocPriceTracker, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 5, "VAH: " + str.tostring(vahTracker, "#"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 5, "Session VP →",            text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 6, "VWAP Flow Matrix",        text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 6, close > vwapAnchor ? "PREMIUM" : "DISCOUNT",
                 text_color=close > vwapAnchor ? color.lime : color.red, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 6, "VWAP: " + str.tostring(vwapAnchor, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 6, "Dev1: " + str.tostring(upperDev1,  "#"),    text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 6, "Anchor",                  text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 7, "Synthetic Renko S/R",     text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 7, close > rRes ? "BRK RES" : close < rSup ? "BRK SUP" : "RANGING",
                 text_color=close > rRes ? color.lime : close < rSup ? color.red : color.yellow, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 7, "Res: " + str.tostring(rRes, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 7, "Sup: " + str.tostring(rSup, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 7, renkoMode + " Engine",     text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 8, "Initial Balance (IB)",    text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 8, ibLocked ? (close > ibHigh ? "BROKEN HIGH" : close < ibLow ? "BROKEN LOW" : "INSIDE IB") : "FORMING",
                 text_color=ibLocked ? (close > ibHigh ? color.lime : close < ibLow ? color.red : color.yellow) : color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 8, "IBH: " + str.tostring(ibHigh, "#"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 8, "IBL: " + str.tostring(ibLow,  "#"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 8, "First Hour",              text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 9, "Orange Supply Zone",      text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 9, "SHARK SELL ZONE",         text_color=color.orange, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 9, "Top: " + str.tostring(res2, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 9, "Bot: " + str.tostring(res1, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 9, "Elephant Edge",           text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 10, "Green Demand Zone",      text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 10, "SHARK BUY ZONE",         text_color=color.green, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 10, "Top: " + str.tostring(sup1, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 10, "Bot: " + str.tostring(sup2, "#.##"), text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 10, "Elephant Edge",          text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    string currentKZ = not na(inIndian) ? "INDIAN" : not na(inLondon) ? "LONDON" : not na(inNY) ? "NEW YORK" : not na(inAsian) ? "ASIAN" : "NONE"
    table.cell(hud, 0, 11, "Active Session",         text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 11, currentKZ,                text_color=currentKZ != "NONE" ? color.yellow : color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 11, "-",                      text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 11, "-",                      text_color=color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 11, "Killzone Tracker",       text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 12, "EMA Cross Signal",       text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 12, emaF > emaS ? "BULLISH" : "BEARISH", text_color=emaF > emaS ? color.lime : color.red, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 12, "F: " + str.tostring(emaF, "#.##"), text_color=colEMAFast, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 12, "S: " + str.tostring(emaS, "#.##"), text_color=colEMASlow, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 12, str.tostring(emaFast) + "/" + str.tostring(emaSlow) + " EMA", text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 13, "Trend Score (0-10)",     text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 13, _tssLabel,                text_color=_tssColor, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 13, str.tostring(_tss) + " / 10", text_color=_tssColor, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 13, inHTFBullOB ? "+HTF BULL" : inHTFBearOB ? "+HTF BEAR" : "No HTF OB", text_color=inHTFBullOB ? color.lime : inHTFBearOB ? color.red : color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 13, "MTF+VWAP+EMA+RSI",      text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

    table.cell(hud, 0, 14, "HTF OB Confluence",      text_color=colDashText, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 1, 14, inHTFBullOB ? "IN BULL OB" : inHTFBearOB ? "IN BEAR OB" : "NO ZONE", text_color=inHTFBullOB ? color.lime : inHTFBearOB ? color.red : color.gray, bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 2, 14, not na(htfBullOBH) ? "BZ " + str.tostring(htfBullOBH, "#.##") : "-", text_color=color.new(#00bfa5, 0), bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 3, 14, not na(htfBearOBH) ? "SZ " + str.tostring(htfBearOBH, "#.##") : "-", text_color=color.new(#ff1744, 0), bgcolor=colDashBg, text_size=getSize())
    table.cell(hud, 4, 14, htfTF + " TF",            text_color=color.gray, bgcolor=colDashBg, text_size=getSize())

// ==========================================================================================================
// █ 16B. EMA CROSSOVER ENGINE (9/21 configurable)
// ==========================================================================================================
// Both EMAs are always computed so alert conditions fire even when the lines are hidden.
// Cross-connect lines persist on the chart forming a visual "path" between consecutive crosses.
// Fill between the two EMAs shifts color as the fast EMA crosses above / below the slow EMA.

// ── EMA line plots (captured for fill()) — emaF/emaS computed above dashboard ─
// EMA lines — fill() removed to stay within Pine's 64-plot limit
plot(showEMA ? emaF : na, "Fast EMA", color=colEMAFast, linewidth=emaWidth)
plot(showEMA ? emaS : na, "Slow EMA", color=colEMASlow, linewidth=emaWidth)

// ── Multi-EMA Lines (50 / 100 / 150) ─────────────────────────────────────────
float _ema50  = ta.ema(close, ema50Period)
float _ema100 = ta.ema(close, ema100Period)
float _ema150 = ta.ema(close, ema150Period)
plot(showEMA50  ? _ema50  : na, "EMA 50",  color=colEMA50,  linewidth=emaMultiWidth)
plot(showEMA100 ? _ema100 : na, "EMA 100", color=colEMA100, linewidth=emaMultiWidth)
plot(showEMA150 ? _ema150 : na, "EMA 150", color=colEMA150, linewidth=emaMultiWidth)

// ── Cross markers ─────────────────────────────────────────────────────────────
plotshape(showEMA and showEMACrossMarkers and emaBullCross, "EMA Bull Cross", shape.triangleup,   location.belowbar, colCrossBull, size=size.normal)
plotshape(showEMA and showEMACrossMarkers and emaBearCross, "EMA Bear Cross", shape.triangledown, location.abovebar, colCrossBear, size=size.normal)

// ── BUY / SELL labels at cross points ────────────────────────────────────────
if showEMA and showCrossLabel
    float _atr = ta.atr(14)
    if emaBullCross
        label.new(bar_index, low  - _atr * 0.8, "▲ BUY",  color=color.new(colCrossBull, 20), textcolor=color.white, style=label.style_label_up,   size=size.small)
    if emaBearCross
        label.new(bar_index, high + _atr * 0.8, "▼ SELL", color=color.new(colCrossBear, 20), textcolor=color.white, style=label.style_label_down, size=size.small)

// ── Connect consecutive crosses with a line ───────────────────────────────────
// Each new cross draws a line FROM the previous cross price TO the current cross price,
// forming a step-chain that shows the momentum of crossing events over time.
var int   _lastCrossBar   = na
var float _lastCrossPrice = na

if showEMA and showCrossConnect and (emaBullCross or emaBearCross)
    float _crossPx = emaF
    if not na(_lastCrossBar)
        line.new(_lastCrossBar, _lastCrossPrice, bar_index, _crossPx, color=colCrossConnect, width=crossConnectWidth, style=crossConnectStyle == "Solid" ? line.style_solid : crossConnectStyle == "Dotted" ? line.style_dotted : crossConnectStyle == "Arrow" ? line.style_arrow_right : line.style_dashed)
    _lastCrossBar   := bar_index
    _lastCrossPrice := _crossPx

// ==========================================================================================================
// █ 17C. PIVOT POINTS ENGINE
// ==========================================================================================================
// Supports: Traditional, Fibonacci, Woodie, Classic, DM (DeMark), Camarilla.
// Levels are redrawn when the selected timeframe rolls over (Daily/Weekly/Monthly).
// Previous period H/L/C/O are fetched via request.security with no lookahead bias.

// Auto-select pivot timeframe based on chart resolution
string _pvEffTF = pivotAutoTF ? (timeframe.isintraday ? "D" : timeframe.isdaily ? "W" : timeframe.isweekly ? "M" : "12M") : pivotTF
[_pvH, _pvL, _pvC, _pvO] = request.security(syminfo.tickerid, _pvEffTF, [high[1], low[1], close[1], open[1]], lookahead=barmerge.lookahead_on)
int  _pvTime = request.security(syminfo.tickerid, _pvEffTF, time, lookahead=barmerge.lookahead_on)
bool _pvNew  = ta.change(_pvTime) != 0

if showPivots and _pvNew and not na(_pvH) and not na(_pvL)

    // ── Clear previous period drawings ────────────────────────────────────────
    if array.size(_ppLines) > 0
        for _di = array.size(_ppLines) - 1 to 0
            line.delete(array.get(_ppLines, _di))
        array.clear(_ppLines)
    if array.size(_ppLabels) > 0
        for _di = array.size(_ppLabels) - 1 to 0
            label.delete(array.get(_ppLabels, _di))
        array.clear(_ppLabels)

    // ── Compute pivot levels ──────────────────────────────────────────────────
    float _rng = _pvH - _pvL

    if pivotType == "Traditional" or pivotType == "Classic"
        _ppP  := (_pvH + _pvL + _pvC) / 3
        _ppR1 := 2 * _ppP - _pvL
        _ppR2 := _ppP + _rng
        _ppR3 := _pvH + 2 * (_ppP - _pvL)
        _ppS1 := 2 * _ppP - _pvH
        _ppS2 := _ppP - _rng
        _ppS3 := _pvL - 2 * (_pvH - _ppP)
        _ppR4 := na, _ppS4 := na

    if pivotType == "Fibonacci"
        _ppP  := (_pvH + _pvL + _pvC) / 3
        _ppR1 := _ppP + 0.382 * _rng
        _ppR2 := _ppP + 0.618 * _rng
        _ppR3 := _ppP + 1.000 * _rng
        _ppS1 := _ppP - 0.382 * _rng
        _ppS2 := _ppP - 0.618 * _rng
        _ppS3 := _ppP - 1.000 * _rng
        _ppR4 := na, _ppS4 := na

    if pivotType == "Woodie"
        _ppP  := (_pvH + _pvL + 2 * _pvC) / 4
        _ppR1 := 2 * _ppP - _pvL
        _ppR2 := _ppP + _rng
        _ppR3 := _pvH + 2 * (_ppP - _pvL)
        _ppS1 := 2 * _ppP - _pvH
        _ppS2 := _ppP - _rng
        _ppS3 := _pvL - 2 * (_pvH - _ppP)
        _ppR4 := na, _ppS4 := na

    if pivotType == "DM"
        float _X = _pvC < _pvO ? _pvH + 2 * _pvL + _pvC : _pvC > _pvO ? 2 * _pvH + _pvL + _pvC : _pvH + _pvL + 2 * _pvC
        _ppP  := _X / 4
        _ppR1 := _X / 2 - _pvL
        _ppS1 := _X / 2 - _pvH
        _ppR2 := na, _ppR3 := na, _ppR4 := na
        _ppS2 := na, _ppS3 := na, _ppS4 := na

    if pivotType == "Camarilla"
        _ppP  := (_pvH + _pvL + _pvC) / 3
        _ppR1 := _pvC + 1.1 * _rng / 12
        _ppR2 := _pvC + 1.1 * _rng / 6
        _ppR3 := _pvC + 1.1 * _rng / 4
        _ppR4 := _pvC + 1.1 * _rng / 2
        _ppS1 := _pvC - 1.1 * _rng / 12
        _ppS2 := _pvC - 1.1 * _rng / 6
        _ppS3 := _pvC - 1.1 * _rng / 4
        _ppS4 := _pvC - 1.1 * _rng / 2

    // ── Draw lines + labels ──────────────────────────────────────────────────
    // Each non-na level → dashed horizontal line extending right + label at right edge
    if not na(_ppP)
        array.push(_ppLines, line.new(bar_index, _ppP, bar_index+1, _ppP, color=colPivot, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppP, "P  " + str.tostring(_ppP, format.mintick), color=color.new(colPivot, 100), textcolor=colPivot, style=label.style_label_right, size=size.tiny))
    if not na(_ppR1)
        array.push(_ppLines, line.new(bar_index, _ppR1, bar_index+1, _ppR1, color=colPivotR, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppR1, "R1 " + str.tostring(_ppR1, format.mintick), color=color.new(colPivotR, 100), textcolor=colPivotR, style=label.style_label_right, size=size.tiny))
    if not na(_ppR2)
        array.push(_ppLines, line.new(bar_index, _ppR2, bar_index+1, _ppR2, color=colPivotR, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppR2, "R2 " + str.tostring(_ppR2, format.mintick), color=color.new(colPivotR, 100), textcolor=colPivotR, style=label.style_label_right, size=size.tiny))
    if not na(_ppR3)
        array.push(_ppLines, line.new(bar_index, _ppR3, bar_index+1, _ppR3, color=colPivotR, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppR3, "R3 " + str.tostring(_ppR3, format.mintick), color=color.new(colPivotR, 100), textcolor=colPivotR, style=label.style_label_right, size=size.tiny))
    if not na(_ppR4)
        array.push(_ppLines, line.new(bar_index, _ppR4, bar_index+1, _ppR4, color=colPivotR, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppR4, "R4 " + str.tostring(_ppR4, format.mintick), color=color.new(colPivotR, 100), textcolor=colPivotR, style=label.style_label_right, size=size.tiny))
    if not na(_ppS1)
        array.push(_ppLines, line.new(bar_index, _ppS1, bar_index+1, _ppS1, color=colPivotS, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppS1, "S1 " + str.tostring(_ppS1, format.mintick), color=color.new(colPivotS, 100), textcolor=colPivotS, style=label.style_label_right, size=size.tiny))
    if not na(_ppS2)
        array.push(_ppLines, line.new(bar_index, _ppS2, bar_index+1, _ppS2, color=colPivotS, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppS2, "S2 " + str.tostring(_ppS2, format.mintick), color=color.new(colPivotS, 100), textcolor=colPivotS, style=label.style_label_right, size=size.tiny))
    if not na(_ppS3)
        array.push(_ppLines, line.new(bar_index, _ppS3, bar_index+1, _ppS3, color=colPivotS, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppS3, "S3 " + str.tostring(_ppS3, format.mintick), color=color.new(colPivotS, 100), textcolor=colPivotS, style=label.style_label_right, size=size.tiny))
    if not na(_ppS4)
        array.push(_ppLines, line.new(bar_index, _ppS4, bar_index+1, _ppS4, color=colPivotS, width=pivotLineWidth, style=line.style_dashed, extend=extend.right))
        if showPivotLabels
            array.push(_ppLabels, label.new(bar_index+2, _ppS4, "S4 " + str.tostring(_ppS4, format.mintick), color=color.new(colPivotS, 100), textcolor=colPivotS, style=label.style_label_right, size=size.tiny))

// ==========================================================================================================
// █ 17D. HEIKEN ASHI SIGNAL ENGINE
// ==========================================================================================================
// Heiken Ashi smooths price noise by averaging OHLC — making trend direction cleaner than raw candles.
//
// Three signal tiers (visually distinct from EMA 9/21 signals):
//   ◉ HA  (circle)  — HA color change after N consecutive candles  → cyan/magenta
//   ◆ HA+ (diamond) — No-shadow candle = institutional conviction   → bright cyan/pink
//   [plotcandle]    — Optional semi-transparent HA overlay
//
// EMA signals use triangles at 0.8× ATR offset.
// HA  signals use circles  at 1.6× ATR offset.
// HA+ signals use diamonds at 2.4× ATR offset.
// → No visual overlap even when all fire on the same bar.

// ── Heiken Ashi OHLC ─────────────────────────────────────────────────────────
float _haC = (open + high + low + close) / 4
var float _haO = (open + close) / 2
_haO := (nz(_haO[1], (open[1] + close[1]) / 2) + nz(_haC[1], (open[1] + high[1] + low[1] + close[1]) / 4)) / 2
float _haH = math.max(high, math.max(_haO, _haC))
float _haL = math.min(low,  math.min(_haO, _haC))

bool _haBull = _haC >= _haO
bool _haBear = _haC <  _haO

// ── Consecutive candle counter ────────────────────────────────────────────────
var int _haCntBull = 0
var int _haCntBear = 0
_haCntBull := _haBull ? _haCntBull[1] + 1 : 0
_haCntBear := _haBear ? _haCntBear[1] + 1 : 0

// ── Signal conditions ─────────────────────────────────────────────────────────
// Basic: fires on the Nth consecutive candle of a new direction
bool _haBuyBasic  = showHASignals and showHABasic and _haBull and _haCntBull == haConsecutive
bool _haSellBasic = showHASignals and showHABasic and _haBear and _haCntBear == haConsecutive

// Strong: HA candle with no shadow on conviction side (floating point safe)
bool _haNoLowShadow = math.abs(_haL - math.min(_haO, _haC)) < syminfo.mintick
bool _haNoUpShadow  = math.abs(_haH - math.max(_haO, _haC)) < syminfo.mintick
bool _haStrongBuy   = showHASignals and showHAStrong and _haBull and _haNoLowShadow
bool _haStrongSell  = showHASignals and showHAStrong and _haBear and _haNoUpShadow

// When both basic AND strong fire → show strong only (avoids stacking on same bar)
bool _showHABuyBasic  = _haBuyBasic  and not _haStrongBuy
bool _showHASellBasic = _haSellBasic and not _haStrongSell

// ── Signal quality filters ───────────────────────────────────────────────────
// 1. Body strength: HA body must be >= haBodyFilter% of ATR (no tiny candles)
// 2. Cooldown:      suppress new signals for haMinBars bars after one fires
// 3. Trend align:   buy only above emaS, sell only below emaS

float _haAtr14   = ta.atr(14)
float _haBody    = math.abs(_haC - _haO)
bool  _haBodyOK  = haBodyFilter == 0 or _haBody >= _haAtr14 * (haBodyFilter / 100.0)
bool  _haTrendOK_bull = not haUseTrendFilter or close > emaS
bool  _haTrendOK_bear = not haUseTrendFilter or close < emaS

var int _haLastBuyBar  = -1000
var int _haLastSellBar = -1000
bool _haCooldownBuyOK  = (bar_index - _haLastBuyBar)  >= haMinBars
bool _haCooldownSellOK = (bar_index - _haLastSellBar) >= haMinBars

// Apply all filters to final gated signals
bool _haGatedBuyBasic   = _showHABuyBasic  and _haBodyOK and _haTrendOK_bull and _haCooldownBuyOK
bool _haGatedSellBasic  = _showHASellBasic and _haBodyOK and _haTrendOK_bear and _haCooldownSellOK
bool _haGatedStrongBuy  = _haStrongBuy     and _haBodyOK and _haTrendOK_bull and _haCooldownBuyOK
bool _haGatedStrongSell = _haStrongSell    and _haBodyOK and _haTrendOK_bear and _haCooldownSellOK

// Update cooldown trackers
if _haGatedBuyBasic  or _haGatedStrongBuy
    _haLastBuyBar  := bar_index
if _haGatedSellBasic or _haGatedStrongSell
    _haLastSellBar := bar_index

// ── Labels only (plotshape removed to stay within 64-plot limit) ─────────────
// Labels do NOT count toward Pine's plot limit.
// ◉ HA  = basic color-change signal  (Cyan buy / Magenta sell)
// ◆ HA+ = strong no-shadow signal    (Bright Cyan / Pink) — rarer, higher conviction

if showHASignals
    if _haGatedStrongBuy
        label.new(bar_index, low  - _haAtr14 * 2.4, "◆ HA+", color=color.new(colHAStrongBuy,  100), textcolor=colHAStrongBuy,  style=label.style_label_up,   size=size.small)
    else if _haGatedBuyBasic
        label.new(bar_index, low  - _haAtr14 * 1.6, "◉ HA",  color=color.new(colHABuy,        100), textcolor=colHABuy,        style=label.style_label_up,   size=size.small)
    if _haGatedStrongSell
        label.new(bar_index, high + _haAtr14 * 2.4, "◆ HA+", color=color.new(colHAStrongSell, 100), textcolor=colHAStrongSell, style=label.style_label_down, size=size.small)
    else if _haGatedSellBasic
        label.new(bar_index, high + _haAtr14 * 1.6, "◉ HA",  color=color.new(colHASell,       100), textcolor=colHASell,       style=label.style_label_down, size=size.small)

// ==========================================================================================================
// █ 18. GLOBAL ALERTS MATRIX
// ==========================================================================================================

alertcondition(operatorBullBreak and alertOnShark, title="[V8.0] Shark Buy",  message="Institutional Breakout of Demand Zone.")
alertcondition(operatorBearBreak and alertOnShark, title="[V8.0] Shark Sell", message="Institutional Breakout of Supply Zone.")
alertcondition(emaBullCross, title="[V8.0] EMA Bull Cross", message="EMA Bull Cross — Fast EMA crossed ABOVE Slow EMA. Bullish signal.")
alertcondition(emaBearCross,   title="[V8.0] EMA Bear Cross",    message="EMA Bear Cross — Fast EMA crossed BELOW Slow EMA. Bearish signal.")
alertcondition(_haGatedBuyBasic,   title="[V8.0] HA Buy Signal",   message="Heiken Ashi Bullish — color change, body strength, trend and cooldown filters passed.")
alertcondition(_haGatedSellBasic,  title="[V8.0] HA Sell Signal",  message="Heiken Ashi Bearish — color change, body strength, trend and cooldown filters passed.")
alertcondition(_haGatedStrongBuy,  title="[V8.0] HA Strong Buy",   message="Strong HA Bull — no lower shadow, all quality filters passed.")
alertcondition(_haGatedStrongSell, title="[V8.0] HA Strong Sell",  message="Strong HA Bear — no upper shadow, all quality filters passed.")
