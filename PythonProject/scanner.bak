# Initialize Fyers API
fyers = fyersModel.FyersModel(client_id=client_id, is_async=False, token=access_token, log_path="")

def fetch_data_macro(fyers_symbol):
    # Create a safe filename (e.g., NSE:RELIANCE-EQ -> NSE_RELIANCE-EQ.csv)
    file_path = os.path.join(CACHE_DIR, f"{fyers_symbol.replace(':', '_')}.csv")
    today_str = datetime.now().strftime('%Y-%m-%d')

    df_local = None

    # Check if we have local data
    if os.path.exists(file_path):
        try:
            df_local = pd.read_csv(file_path, index_col=0, parse_dates=True)
            if not df_local.empty:
                last_date = df_local.index[-1].strftime('%Y-%m-%d')

                # If already updated today, return immediately (Speed: <0.01s)
                if last_date == today_str:
                    return df_local

                # If old, we only need data from the day after the last saved date
                start_date = (df_local.index[-1] + timedelta(days=1)).strftime('%Y-%m-%d')
        except Exception as e:
            print(f"Cache error for {fyers_symbol}: {e}")

    # If no local data, fetch full 5 years (One-time event)
    if df_local is None:
        start_date = (datetime.now() - timedelta(days=1825)).strftime('%Y-%m-%d')

    # Fetch the "Gap" from Fyers
    data = {
        "symbol": fyers_symbol, "resolution": "1D", "date_format": "1",
        "range_from": start_date, "range_to": today_str, "cont_flag": "1"
    }

    response = fyers.history(data=data)

    if response.get('s') == 'ok' and response.get('candles'):
        df_new = pd.DataFrame(response['candles'], columns=['Datetime', 'Open', 'High', 'Low', 'Close', 'Volume'])
        df_new['Datetime'] = pd.to_datetime(df_new['Datetime'], unit='s')
        df_new.set_index('Datetime', inplace=True)

        # Merge new data with local data
        if df_local is not None:
            df_final = pd.concat([df_local, df_new]).sort_index()
            # Remove any overlaps (important for weekends/holidays)
            df_final = df_final[~df_final.index.duplicated(keep='last')]
        else:
            df_final = df_new

        # Save to your Mac for next time
        df_final.to_csv(file_path)
        return df_final

    return df_local  # Fallback to local if API fails

# ==========================================
# 2. FETCH DATA FUNCTIONS
# ==========================================
def fetch_live_fyers_symbols():
    """Fetches and cleans the Fyers NSE Master CSV."""
    print("Downloading Fyers NSE Master List...")
    url = "https://public.fyers.in/sym_details/NSE_CM.csv"

    try:
        # Load the CSV without headers to prevent column mismatch errors
        df = pd.read_csv(url, header=None)

        # In Fyers CSV, Column Index 9 is ALWAYS the Fyers Symbol (e.g., NSE:RELIANCE-EQ)
        symbol_col = 9

        # Filter for rows where the Fyers Symbol ends with '-EQ' (Regular Equities)
        eq_df = df[df[symbol_col].astype(str).str.endswith('-EQ')]

        fyers_dict = {}
        for _, row in eq_df.iterrows():
            fyers_symbol = str(row[symbol_col])

            # Clean the name for your HTML dashboard: "NSE:RELIANCE-EQ" -> "RELIANCE"
            clean_name = fyers_symbol.replace("NSE:", "").replace("-EQ", "")

            fyers_dict[clean_name] = fyers_symbol

        print(f"✅ Extracted {len(fyers_dict)} NSE Equity symbols.")
        return fyers_dict

    except Exception as e:
        print(f"❌ Failed to get master list: {e}")
        return {}


def fetch_data(fyers_symbol, timeframe="1D"):
    """Fetches 5 years of historical data from Fyers by chunking 365 days at a time."""
    df_list = []
    end_date = datetime.now()

    # Loop 5 times to get exactly 5 years of data
    for _ in range(5):
        # Calculate the start date for this chunk (364 days back)
        start_date = end_date - timedelta(days=364)

        data = {
            "symbol": fyers_symbol,
            "resolution": timeframe,
            "date_format": "1",
            "range_from": start_date.strftime('%Y-%m-%d'),
            "range_to": end_date.strftime('%Y-%m-%d'),
            "cont_flag": "1"
        }

        response = fyers.history(data=data)

        # If the API returns valid data, convert it and save the chunk
        if response.get('s') == 'ok' and response.get('candles'):
            temp_df = pd.DataFrame(response['candles'], columns=['Datetime', 'Open', 'High', 'Low', 'Close', 'Volume'])
            df_list.append(temp_df)

        # Shift our time-window backwards by 1 day for the next loop
        end_date = start_date - timedelta(days=1)

        # ⚠️ CRITICAL: Fyers allows 10 API calls per second.
        # This slight pause prevents them from banning us for spamming.
        time.sleep(0.35)

        # If the stock is brand new and has absolutely no data, skip it
    if not df_list:
        return None

    # Stitch all 5 chunks of data together!
    df = pd.concat(df_list, ignore_index=True)

    # Format the dates and ensure they are sorted chronologically (Oldest -> Newest)
    df['Datetime'] = pd.to_datetime(df['Datetime'], unit='s')
    df.set_index('Datetime', inplace=True)
    df.sort_index(inplace=True)

    # Remove any accidental overlapping days just in case
    df = df[~df.index.duplicated(keep='first')]

    return df


# ==========================================
# 3. TRADING LOGIC
# ==========================================
def check_zone(df):
    """Checks for institutional Demand or Supply Zones."""
    if df is None or len(df) < 5:
        return ""

    # ⚠️ PASTE YOUR EXISTING DEMAND/SUPPLY LOGIC HERE ⚠️
    # Example placeholder:
    # if condition: return "DEMAND"
    # elif condition: return "SUPPLY"

    return ""


def check_high_low(df):
    """Checks for Multi-Year Breakouts OR Proximity (within 5%)."""
    if df is None or len(df) < 240:
        return "-"

    curr_close = df['Close'].iloc[-1] # Using Close for proximity is more stable

    # 5% Proximity Buffer
    buffer_percent = 0.05

    periods = {
        "5-Year": 1190,
        "4-Year": 950,
        "3-Year": 710,
        "2-Year": 470,
        "1-Year": 240
    }

    for label, days in periods.items():
        if len(df) >= days:
            window_df = df.tail(days)
            period_high = window_df['High'].max()
            period_low = window_df['Low'].min()

            # 1. Check for exact breakouts today
            if curr_close >= period_high:
                return f"🚀 {label} Breakout"
            elif curr_close <= period_low:
                return f"🩸 {label} Breakdown"

            # 2. Check for PROXIMITY (Within 5% of the zone)
            elif curr_close >= (period_high * (1 - buffer_percent)):
                return f"👀 Near {label} High"
            elif curr_close <= (period_low * (1 + buffer_percent)):
                return f"⚠️ Near {label} Low"

    return "-"


# ==========================================
# 4. HTML DASHBOARD GENERATOR
# ==========================================
def generate_html_popup(results):
    """
    Generates a Macro-Analysis Dashboard for Supply/Demand and Multi-Year levels.
    Expects results to contain: Stock, Zone, HighLow, and Price.
    """

    file_path = os.path.abspath("macro_dashboard.html")

    # Start building the HTML String
    html_content = f"""
    <!DOCTYPE html>
    <html>
    <head>
        <title>Macro Structure Dashboard</title>
        <style>
            body {{ font-family: -apple-system, sans-serif; background-color: #1a1a1a; color: #e0e0e0; padding: 25px; }}
            h2 {{ color: #ffffff; text-align: center; border-bottom: 2px solid #333; padding-bottom: 15px; }}
            table {{ width: 100%; border-collapse: collapse; background: #252525; border-radius: 10px; overflow: hidden; margin-top: 20px; }}
            th {{ background-color: #333; color: #888; padding: 18px; text-align: left; text-transform: uppercase; font-size: 12px; letter-spacing: 1px; }}
            td {{ padding: 15px; border-bottom: 1px solid #333; }}
            tr:hover {{ background-color: #2d2d2d; }}

            /* Zone Tags */
            .zone-demand {{ background-color: #1e4620; color: #4caf50; padding: 5px 10px; border-radius: 4px; font-weight: bold; font-size: 13px; }}
            .zone-supply {{ background-color: #4a1c1c; color: #f44336; padding: 5px 10px; border-radius: 4px; font-weight: bold; font-size: 13px; }}
            .zone-none {{ color: #666; }}

            /* Macro Level Highlighting */
            .level-text {{ font-weight: 500; color: #bbdefb; }}
            .price-text {{ font-family: "SF Mono", "Monaco", monospace; color: #ffd54f; font-weight: bold; }}
        </style>
    </head>
    <body>
        <h2>🏛️ MACRO STRUCTURE & INSTITUTIONAL ZONES</h2>
        <p style="text-align: center; color: #888;">Scan Date: {datetime.now().strftime('%d %b %Y | %H:%M')}</p>
        <table>
            <thead>
                <tr>
                    <th>Symbol</th>
                    <th>Institutional Zone</th>
                    <th>Macro High/Low Status</th>
                    <th>Current Price</th>
                </tr>
            </thead>
            <tbody>
    """

    for res in results:
        stock = res.get('Stock', '-')
        zone = res.get('Zone', '-')
        hl_status = res.get('HighLow', '-')
        price = res.get('Price', 0.0)

        # Determine CSS Class for Zone
        if "DEMAND" in zone.upper():
            zone_html = f'<span class="zone-demand">{zone}</span>'
        elif "SUPPLY" in zone.upper():
            zone_html = f'<span class="zone-supply">{zone}</span>'
        else:
            zone_html = f'<span class="zone-none">-</span>'

        html_content += f"""
                <tr>
                    <td><strong>{stock}</strong></td>
                    <td>{zone_html}</td>
                    <td class="level-text">{hl_status}</td>
                    <td class="price-text">₹{price:.2f}</td>
                </tr>
        """

    html_content += """
            </tbody>
        </table>
        <div style="margin-top: 30px; padding: 15px; background: #222; border-radius: 8px; font-size: 13px; color: #777;">
            <strong>Analysis Legend:</strong><br>
            • <b>Demand Zone:</b> Institutional buying area based on 52-week volatility.<br>
            • <b>Macro Status:</b> Proximity to 1, 2, 3, 4, or 5-year historical pivots.<br>
            • <b>Price:</b> Latest daily closing price.
        </div>
    </body>
    </html>
    """

    # Write and Open
    with open(file_path, "w", encoding="utf-8") as f:
        f.write(html_content)

    webbrowser.open(f"file://{file_path}")


# Create a local storage to track thread names
thread_local = threading.local()


def process_stock(stock_data):
    stock_name, fyers_symbol = stock_data

    # 1. This call is now 99% local SSD reading
    df = fetch_data_macro(fyers_symbol)

    if df is not None and len(df) > 10:
        # 2. Compare data (The functions you already wrote)
        zone = check_zone(df)
        hl_status = check_high_low(df)  # This will check all 5 years in milliseconds

        if zone or hl_status != "-":
            # Print to terminal
            print(f"✅ MACRO HIT: {stock_name:<12} | Zone: {zone:<10} | Level: {hl_status}")

            return {
                "Stock": stock_name,
                "Zone": zone if zone else "-",
                "HighLow": hl_status,
                "Price": df['Close'].iloc[-1]
            }
    return None
# ==========================================
# 5. MAIN EXECUTION
# ==========================================
def run_scanner():
    # --- POINT 1: Verify the list isn't empty ---
    all_stocks = fetch_live_fyers_symbols()
    stock_items = list(all_stocks.items())

    print(f"DEBUG: Total stocks found: {len(stock_items)}")
    if not stock_items:
        print("❌ ERROR: No stocks found. Check your symbol fetching logic.")
        return

    # --- POINT 2: Ensure the Executor is calling the RIGHT worker ---
    with concurrent.futures.ThreadPoolExecutor(max_workers=15) as executor:
        # This calls 'process_stock', which we define below
        futures = [executor.submit(process_stock, item) for item in stock_items]

        for future in concurrent.futures.as_completed(futures):
            try:
                future.result()  # This forces any hidden errors to show up
            except Exception as e:
                print(f"Thread Error: {e}")


